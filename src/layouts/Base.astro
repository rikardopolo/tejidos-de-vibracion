---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  bodyClass?: string;
  pageId?: string;
  jsonLd?: Record<string, unknown>;
  nivel?: 0 | 1 | 2 | 3;
}

const {
  title,
  description,
  canonical,
  ogImage = '/og/default.svg',
  bodyClass,
  pageId,
  jsonLd,
  nivel = 0,
} = Astro.props;

const siteUrl = 'https://tejidosdevibracion.com';
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, siteUrl).href;
const ogImageUrl = ogImage.startsWith('http') ? ogImage : new URL(ogImage, siteUrl).href;

const defaultJsonLd: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Tejidos de Vibración',
  description: 'Tejidos de Vibración · Volumen I del proyecto Tejidos de Realidad · Por Ricardo Polo',
  url: siteUrl,
  author: {
    '@type': 'Person',
    name: 'Ricardo Polo',
  },
};

const schema = jsonLd ?? defaultJsonLd;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{title}</title>
    <meta name="description" content={description} />

    {/* Base.astro lo usa SOLO el 404 (el contenido usa LecturaLarga /
        OberturaLayout / CapituloLayout, indexables). noindex es intencional
        para la página de error — no es un bloqueo global. */}
    <meta name="robots" content="noindex,nofollow,noarchive" />

    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:locale" content="es_ES" />
    <meta property="og:site_name" content="Tejidos de Vibración" />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <!-- JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </head>
  <body class={bodyClass} data-page={pageId} data-nivel={nivel}>
    <a href="#main-content" class="skip-link">Saltar al contenido</a>
    <slot />
  </body>
</html>
