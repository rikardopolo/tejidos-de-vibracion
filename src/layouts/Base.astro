---
import '../styles/global.css';
import { OG_IMAGE_HEIGHT, OG_IMAGE_TYPE, OG_IMAGE_WIDTH, SITE, resolveOgImage } from '@/lib/seo';

const HOME_OG_IMAGE_PATH = '/og/og-home.jpg';
const HOME_OG_IMAGE_ALT = 'Tejidos de VibraciÃ³n Â· Volumen I';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  ogImageAlt?: string;
  bodyClass?: string;
  pageId?: string;
  jsonLd?: Record<string, unknown>;
  robots?: string;
  nivel?: 0 | 1 | 2 | 3;
}

const {
  title,
  description,
  canonical,
  ogImage = HOME_OG_IMAGE_PATH,
  ogImageAlt = HOME_OG_IMAGE_ALT,
  bodyClass,
  pageId,
  jsonLd,
  robots = 'noindex,nofollow,noarchive',
  nivel = 0,
} = Astro.props;

const siteUrl = SITE;
const canonicalUrl = canonical ?? new URL(Astro.url.pathname, siteUrl).href;
const ogImageUrl = resolveOgImage(ogImage);

const defaultJsonLd: Record<string, unknown> = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: 'Tejidos de VibraciÃ³n',
  description: 'Tejidos de VibraciÃ³n Â· Volumen I del proyecto Tejidos de Realidad Â· Por Ricardo Polo',
  url: siteUrl,
  author: {
    '@type': 'Person',
    name: 'Ricardo Polo',
  },
};

const schema = jsonLd ?? defaultJsonLd;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    <title>{title}</title>
    <meta name="description" content={description} />

    {/* robots Â· default noindex (404 + pÃ¡ginas de utilidad: privacidad, buscar,
        confirmaciÃ³n). Las pÃ¡ginas pÃºblicas pasan robots="index,follow" por prop.
        Obertura/capÃ­tulos son indexables vÃ­a BookReader. LecturaLarga reenvÃ­a
        esta prop â†’ su default tambiÃ©n es noindex salvo opt-in explÃ­cito. */}
    <meta name="robots" content={robots} />

    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:secure_url" content={ogImageUrl} />
    <meta property="og:image:width" content={String(OG_IMAGE_WIDTH)} />
    <meta property="og:image:height" content={String(OG_IMAGE_HEIGHT)} />
    <meta property="og:image:type" content={OG_IMAGE_TYPE} />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta property="og:locale" content="es_ES" />
    <meta property="og:site_name" content="Tejidos de VibraciÃ³n" />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={ogImageAlt} />

    <!-- JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  </head>
  <body class={bodyClass} data-page={pageId} data-nivel={nivel}>
    <a href="#main-content" class="skip-link">Saltar al contenido</a>
    <slot />
  </body>
</html>
