---
/**
 * <PausaCientifica> · contenido científico citable (Obertura).
 *
 * Sprint unificación de estilo · decisión 3 (B3a · restyle in-place).
 * Migrado del formato ELABORADO (doble borde índigo arriba/abajo + panel
 * + label mono con ▸ + badge de nivel de evidencia) al formato SOBRIO de
 * Capítulos (border-left + eyebrow índigo), para unificar el look.
 *
 * El eyebrow conserva su color semántico (índigo · carril científico).
 * El badge "Nivel N · …" se RETIRA · coherente con la limpieza de
 * andamiaje epistémico (la línea "Nivel de evidencia" se elimino del
 * contenido en la tarea previa).
 *
 * Compat: `level`/`levelLabel` se mantienen en la interfaz (las piezas
 * los pasan) pero ya NO se renderiza el badge.
 */

interface Props {
  /** Título del bloque científico. */
  title: string;
  /** Nivel de evidencia · CONSERVADO por compat · ya no se renderiza. */
  level?: 1 | 2 | 3 | 4;
  /** Etiqueta de nivel · CONSERVADO por compat · ya no se renderiza. */
  levelLabel?: string;
}

const { title } = Astro.props;
---

<aside class="pausa-cientifica">
  <p class="pausa-cientifica__kind">Pausa Científica</p>
  <h3 class="pausa-cientifica__title">{title}</h3>
  <div class="pausa-cientifica__body">
    <slot />
  </div>
</aside>

{/* Estilos en el GLOBAL de OberturaLayout (.pausa-cientifica*), NO scoped
    aquí: el <style> scoped de un .astro usado dentro de MDX genera un
    selector [data-astro-cid-…] que el build de producción no aplica →
    caja sin estilo en prod. Ver OberturaLayout `<style is:global>`. */}
