---
/**
 * LecturaLarga · layout para páginas de lectura larga (capítulos, obertura, etc.)
 * Extiende Base con: header sticky, progress rail, footer, y script de comportamiento.
 */
import Base from './Base.astro';
import BookHeader from '../components/BookHeader.astro';
import BookFooter from '../components/BookFooter.astro';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  bodyClass?: string;
  pageId?: string;
  jsonLd?: Record<string, unknown>;
}

const { title, description, canonical, ogImage, bodyClass, pageId, jsonLd } = Astro.props;
---

<Base
  title={title}
  description={description}
  canonical={canonical}
  ogImage={ogImage}
  bodyClass={bodyClass}
  pageId={pageId}
  jsonLd={jsonLd}
>
  <BookHeader />

  <main>
    <slot />
  </main>

  <BookFooter />

  <script src="/libro-init.js" defer></script>
</Base>
