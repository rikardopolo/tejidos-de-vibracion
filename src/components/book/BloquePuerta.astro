---
/**
 * BloquePuerta · bloque ceremonial que aparece cuando el lector
 * NO tiene acceso al contenido restante.
 *
 * Props:
 *   tipo: "obertura" — con formulario (Nivel 0 → 1, al final de obertura corta)
 *   tipo: "cap-espera" — sin formulario (Nivel 1, contenido en gestación)
 *   tipo: "cap-bloqueado" — con formulario (capítulos del libro N0 bloqueados)
 *   tipo: "obertura-pieza" — con formulario (piezas N1 de la Obertura · /obertura/[slug])
 *   capitulo?: string — número de capítulo (ej. "Capítulo 2") para textos contextuales
 *   titulo?: string — override del título por defecto
 *   subtitulo?: string — texto del cuerpo override
 */
import FormularioTejedor from './FormularioTejedor.astro';

export interface Props {
  tipo: 'obertura' | 'cap-espera' | 'cap-bloqueado' | 'obertura-pieza';
  capitulo?: string;
  titulo?: string;
  subtitulo?: string;
}

const { tipo, capitulo, titulo, subtitulo } = Astro.props;

// Defaults según tipo
const defaults = {
  obertura: {
    eyebrow: 'Continúa el umbral',
    titulo: 'La Obertura sigue más allá',
    cuerpo: 'El umbral apenas se entreabre. Lo que has leído es la primera respiración de un libro que dura tres actos. Para cruzar la Obertura completa — y para encontrar, al final, el primer movimiento del Capítulo 1 — déjame tu nombre y tu correo.',
    conFormulario: true,
    notaPie: 'Sin spam. Sin venta de datos. Al final de cada correo hay un enlace para darte de baja con un solo clic.',
    firma: undefined as string | undefined,
  },
  'cap-bloqueado': {
    eyebrow: 'Cruzar el umbral',
    titulo: capitulo ? `${capitulo} requiere cruzar la Obertura` : 'Este capítulo requiere cruzar la Obertura',
    cuerpo: `${capitulo ?? 'Este capítulo'} es parte del Volumen I, libre para los tejedores registrados. Si aún no has dado tu nombre y tu correo, esta es la puerta.`,
    conFormulario: true,
    notaPie: 'Sin spam. Sin venta de datos.',
    firma: undefined as string | undefined,
  },
  'cap-espera': {
    eyebrow: 'El capítulo sigue',
    titulo: capitulo ? `${capitulo} se está abriendo despacio` : 'El capítulo se está abriendo despacio',
    cuerpo: 'Has cruzado el umbral, y la primera respiración de este capítulo ya está en ti. Lo que sigue se abrirá en su tiempo. Te avisaré por este mismo correo cuando cada sección esté lista. El libro encuentra su ritmo, y vamos juntos. Estás en la lista. Espera bien.',
    conFormulario: false,
    notaPie: undefined as string | undefined,
    firma: '— El Tejedor\nOrion',
  },
  'obertura-pieza': {
    eyebrow: 'Continúa el umbral',
    titulo: 'Esta pieza espera al otro lado',
    cuerpo: 'La Obertura completa — las quince piezas, los tres interludios, el mapa conceptual — es libre para los tejedores registrados. Un nombre y un correo. Eso es todo.',
    conFormulario: true,
    // notaPie undefined · delegamos al built-in form-tejedor__nota (evita duplicación)
    notaPie: undefined as string | undefined,
    firma: undefined as string | undefined,
  },
} as const;

const d = defaults[tipo];
const tituloFinal = titulo ?? d.titulo;
const cuerpoFinal = subtitulo ?? d.cuerpo;
const conFormulario = d.conFormulario;
const notaPie = 'notaPie' in d ? d.notaPie : undefined;
const firma = 'firma' in d ? d.firma : undefined;

const formId = `form-tejedor-puerta-${tipo}`;
---

<aside class={`bloque-puerta bloque-puerta--${tipo}`} data-bloque-puerta>
  <div class="bloque-puerta__ornament" aria-hidden="true">◆</div>

  <p class="bloque-puerta__eyebrow">{d.eyebrow}</p>

  <h2 class="bloque-puerta__titulo">{tituloFinal}</h2>

  <p class="bloque-puerta__cuerpo">{cuerpoFinal}</p>

  {conFormulario && (
    <div class="bloque-puerta__form">
      <FormularioTejedor id={formId} variant="inline" />
      {notaPie && <p class="bloque-puerta__nota">{notaPie}</p>}
    </div>
  )}

  {firma && (
    <div class="bloque-puerta__firma">
      {firma.split('\n').map((linea: string) => <p>{linea}</p>)}
    </div>
  )}

  <div class="bloque-puerta__ornament bloque-puerta__ornament--bottom" aria-hidden="true">◆</div>
</aside>

<style>
  /* Estilos SOLO para tipo="obertura-pieza" (BloquePuerta dentro de
   * OberturaLayout). Scoped al modificador `.bloque-puerta--obertura-pieza`
   * para no afectar los otros tipos (cap-bloqueado, cap-espera, obertura)
   * que viven en LecturaLarga y usan system.css.
   *
   * OberturaLayout no carga system.css → estos estilos restituyen el layout
   * vertical de los inputs (sin esto el navegador los renderiza inline,
   * label+input lado a lado) y aplican la paleta paper-and-ink.
   */

  .bloque-puerta--obertura-pieza {
    max-width: 36rem;
    margin: 5rem auto 4rem;
    padding: 3rem 2rem;
    background: var(--obertura-paper-warm, #e5dbbe);
    border-top: 1px solid var(--obertura-rule, rgba(26, 22, 18, 0.18));
    border-bottom: 1px solid var(--obertura-rule, rgba(26, 22, 18, 0.18));
    text-align: center;
    font-family: var(--obertura-serif, 'EB Garamond', Georgia, serif);
    color: var(--obertura-ink, #1a1a1a);
  }
  .bloque-puerta--obertura-pieza .bloque-puerta__ornament {
    font-size: 1.25rem;
    color: var(--obertura-thread, #8b2e2e);
    margin: 0 0 1.5rem 0;
    letter-spacing: 0;
  }
  .bloque-puerta--obertura-pieza .bloque-puerta__ornament--bottom {
    margin: 1.5rem 0 0 0;
  }
  .bloque-puerta--obertura-pieza .bloque-puerta__eyebrow {
    font-family: var(--obertura-sans, 'Inter', sans-serif);
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--obertura-thread, #8b2e2e);
    margin: 0 0 1.4rem 0;
  }
  .bloque-puerta--obertura-pieza .bloque-puerta__titulo {
    font-family: var(--obertura-serif, 'EB Garamond', serif);
    font-style: italic;
    font-weight: 500;
    font-size: 1.65rem;
    color: var(--obertura-ink, #1a1a1a);
    margin: 0 0 1.5rem 0;
    line-height: 1.3;
    text-wrap: balance;
  }
  .bloque-puerta--obertura-pieza .bloque-puerta__cuerpo {
    font-family: var(--obertura-serif, 'EB Garamond', serif);
    font-size: 1.08rem;
    line-height: 1.65;
    color: var(--obertura-ink-soft, #3a3530);
    margin: 0 0 2rem 0;
    text-wrap: pretty;
    text-align: left;
    padding: 0 0.5rem;
  }
  .bloque-puerta--obertura-pieza .bloque-puerta__form {
    margin: 1.5rem auto 0;
    max-width: 24rem;
    text-align: left;
  }

  /* FormularioTejedor interno · :global() porque las clases vienen del
   * componente hijo. Solo aplican cuando el form está dentro de un
   * .bloque-puerta--obertura-pieza. */
  .bloque-puerta--obertura-pieza :global(.form-tejedor) {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    max-width: 100%;
    margin: 0 auto;
  }
  .bloque-puerta--obertura-pieza :global(.form-tejedor__field) {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }
  .bloque-puerta--obertura-pieza :global(.form-tejedor__label) {
    font-family: var(--obertura-sans, 'Inter', sans-serif);
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--obertura-ink-faded, #6b5f4d);
  }
  .bloque-puerta--obertura-pieza :global(.form-tejedor input[type="text"]:not([name="website"])),
  .bloque-puerta--obertura-pieza :global(.form-tejedor input[type="email"]) {
    font-family: var(--obertura-serif, 'EB Garamond', serif);
    font-size: 1.05rem;
    padding: 0.65rem 0.9rem;
    border: 1px solid var(--obertura-rule, rgba(26, 22, 18, 0.18));
    background: var(--obertura-paper, #f2ead5);
    color: var(--obertura-ink, #1a1a1a);
    border-radius: 2px;
    transition: border-color 180ms ease;
    width: 100%;
    box-sizing: border-box;
  }
  .bloque-puerta--obertura-pieza :global(.form-tejedor input:focus) {
    outline: none;
    border-color: var(--obertura-thread, #8b2e2e);
  }
  .bloque-puerta--obertura-pieza :global(.form-tejedor__consent) {
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
    font-family: var(--obertura-serif, 'EB Garamond', serif);
    font-size: 0.95rem;
    line-height: 1.55;
    color: var(--obertura-ink-soft, #3a3530);
  }
  .bloque-puerta--obertura-pieza :global(.form-tejedor__consent input[type="checkbox"]) {
    width: 1.1rem;
    height: 1.1rem;
    margin-top: 0.2em;
    accent-color: var(--obertura-thread, #8b2e2e);
    flex-shrink: 0;
  }
  .bloque-puerta--obertura-pieza :global(.form-tejedor__honeypot) {
    position: absolute !important;
    left: -9999px !important;
    width: 1px !important;
    height: 1px !important;
    overflow: hidden !important;
  }
  .bloque-puerta--obertura-pieza :global(.form-tejedor__submit) {
    margin-top: 0.5rem;
    padding: 0.8rem 1.5rem;
    font-family: var(--obertura-serif, 'EB Garamond', serif);
    font-size: 1.05rem;
    font-weight: 500;
    color: var(--obertura-paper, #f2ead5);
    background: var(--obertura-thread, #8b2e2e);
    border: 1px solid var(--obertura-thread, #8b2e2e);
    border-radius: 2px;
    cursor: pointer;
    transition: background 180ms ease, border-color 180ms ease;
    letter-spacing: 0.02em;
  }
  .bloque-puerta--obertura-pieza :global(.form-tejedor__submit:hover) {
    background: var(--obertura-thread-deep, #5a1818);
    border-color: var(--obertura-thread-deep, #5a1818);
  }
  .bloque-puerta--obertura-pieza :global(.form-tejedor__submit:disabled) {
    opacity: 0.6;
    cursor: wait;
  }
  .bloque-puerta--obertura-pieza :global(.form-tejedor__nota) {
    font-family: var(--obertura-sans, 'Inter', sans-serif);
    font-size: 0.78rem;
    line-height: 1.55;
    color: var(--obertura-ink-faded, #6b5f4d);
    text-align: center;
    margin: 0.75rem 0 0;
  }
  .bloque-puerta--obertura-pieza :global(.form-tejedor__status) {
    font-family: var(--obertura-serif, 'EB Garamond', serif);
    font-size: 1.05rem;
    font-style: italic;
    color: var(--obertura-thread, #8b2e2e);
    text-align: center;
    margin: 1.25rem 0 0;
    min-height: 1.5em;
  }
  .bloque-puerta--obertura-pieza :global(.form-tejedor a.lit-link) {
    color: var(--obertura-thread, #8b2e2e);
    text-decoration: underline;
    text-decoration-thickness: 1px;
    text-underline-offset: 2px;
  }

  @media (max-width: 540px) {
    .bloque-puerta--obertura-pieza {
      margin: 3rem auto;
      padding: 2.2rem 1.4rem;
    }
    .bloque-puerta--obertura-pieza .bloque-puerta__titulo { font-size: 1.4rem; }
    .bloque-puerta--obertura-pieza .bloque-puerta__cuerpo { font-size: 1rem; padding: 0; }
  }
</style>
