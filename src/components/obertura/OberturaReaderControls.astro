---
/**
 * <ReaderControls> · controles flotantes de lectura para la Obertura.
 *
 * - Tamaño de fuente: S · M · L · XL (atributo data-font-size en <body>).
 * - Tema:             paper / dark    (atributo data-theme en <body>).
 *
 * Persistido en localStorage por el script inline. Se inicializa antes del
 * primer paint emitiendo un script no-blocking en <head> via slot del
 * layout (ver OberturaLayout). Ese script aplica los attrs al <body>
 * tan pronto como el <body> exista, evitando flash visual.
 *
 * Posición: esquina superior derecha en desktop, inferior derecha en móvil.
 */
---

<details class="reader-controls" id="reader-controls">
  <summary class="reader-controls-toggle" aria-label="Abrir controles de lectura">
    <span class="reader-controls-icon" aria-hidden="true">⚙</span>
    <span class="reader-controls-label">Lectura</span>
  </summary>
  <div class="reader-controls-panel" role="group" aria-label="Controles de lectura">
    <div class="reader-controls-row">
      <span class="reader-controls-row-label">Tamaño</span>
      <div class="reader-controls-buttons" role="radiogroup" aria-label="Tamaño de letra">
        <button type="button" data-font-size="s"  aria-label="Pequeño">S</button>
        <button type="button" data-font-size="m"  aria-label="Mediano (predeterminado)">M</button>
        <button type="button" data-font-size="l"  aria-label="Grande">L</button>
        <button type="button" data-font-size="xl" aria-label="Muy grande">XL</button>
      </div>
    </div>
    <div class="reader-controls-row">
      <span class="reader-controls-row-label">Tema</span>
      <div class="reader-controls-buttons" role="radiogroup" aria-label="Tema visual">
        <button type="button" data-theme="paper" aria-label="Papel (claro)">☀ Papel</button>
        <button type="button" data-theme="dark"  aria-label="Tinta (modo noche)">☾ Tinta</button>
      </div>
    </div>
  </div>
</details>

<style>
  .reader-controls {
    position: fixed;
    top: 1.2rem;
    right: 1.2rem;
    z-index: 90;
  }
  .reader-controls-toggle {
    list-style: none;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
    padding: 0.55rem 0.95rem;
    background: rgba(241, 233, 216, 0.92);
    border: 1px solid var(--obertura-rule);
    color: var(--obertura-ink);
    font-family: var(--obertura-sans);
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    backdrop-filter: blur(6px);
    transition: border-color 0.2s, background 0.2s;
  }
  .reader-controls-toggle::-webkit-details-marker { display: none; }
  .reader-controls-toggle::marker { content: ''; }
  .reader-controls-toggle:hover {
    border-color: var(--obertura-thread);
    background: rgba(241, 233, 216, 1);
  }
  .reader-controls-icon {
    color: var(--obertura-thread);
    font-size: 1rem;
    line-height: 1;
  }
  body[data-theme="dark"] .reader-controls-toggle {
    background: rgba(20, 17, 13, 0.92);
  }
  body[data-theme="dark"] .reader-controls-toggle:hover {
    background: rgba(20, 17, 13, 1);
  }

  .reader-controls[open] .reader-controls-panel {
    position: fixed;
    top: 4rem;
    right: 1.2rem;
    width: min(280px, calc(100vw - 2.4rem));
    padding: 1.2rem 1.3rem;
    background: var(--obertura-paper-warm);
    border: 1px solid var(--obertura-rule);
    box-shadow: 0 12px 36px rgba(26, 22, 18, 0.18);
    z-index: 91;
  }
  body[data-theme="dark"] .reader-controls[open] .reader-controls-panel {
    box-shadow: 0 12px 36px rgba(0, 0, 0, 0.5);
  }
  .reader-controls-row {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-bottom: 1rem;
  }
  .reader-controls-row:last-child { margin-bottom: 0; }
  .reader-controls-row-label {
    font-family: var(--obertura-sans);
    font-size: 0.65rem;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--obertura-ink-faded);
  }
  .reader-controls-buttons {
    display: flex;
    gap: 0.4rem;
  }
  .reader-controls-buttons button {
    flex: 1;
    padding: 0.45rem 0.5rem;
    background: transparent;
    border: 1px solid var(--obertura-rule);
    color: var(--obertura-ink);
    font-family: var(--obertura-serif);
    font-size: 0.85rem;
    cursor: pointer;
    transition: border-color 0.15s, background 0.15s, color 0.15s;
  }
  .reader-controls-buttons button:hover {
    border-color: var(--obertura-thread);
  }
  .reader-controls-buttons button[aria-pressed="true"] {
    background: var(--obertura-thread);
    color: var(--obertura-paper);
    border-color: var(--obertura-thread);
  }

  @media (max-width: 640px) {
    .reader-controls {
      top: auto;
      bottom: 1rem;
      right: 1rem;
    }
    .reader-controls[open] .reader-controls-panel {
      top: auto;
      bottom: 4rem;
      right: 1rem;
    }
  }
</style>

<!-- Comportamiento externalizado a /obertura-reader.js para cumplir CSP
     'script-src self' (sin 'unsafe-inline'). El no-flash init vive
     aparte en /obertura-init.js · este script wirea los clicks. -->
<script is:inline src="/obertura-reader.js" defer></script>
