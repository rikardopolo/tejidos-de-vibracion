---
import LecturaLarga from '@/layouts/LecturaLarga.astro';
import { verifyAccessToken } from '@/lib/token';
import { addContactToList } from '@/lib/brevo';

export const prerender = false;

const readEnv = (key: string): string | undefined => {
  if (typeof process !== 'undefined' && process.env) {
    const p = process.env[key];
    if (p !== undefined && p !== '') return p;
  }
  const m = (import.meta.env as Record<string, string | undefined>)[key];
  if (m !== undefined && m !== '') return m;
  return undefined;
};

const token = Astro.url.searchParams.get('t');
const secret = readEnv('ACCESS_TOKEN_SECRET');
const apiKey = readEnv('BREVO_API_KEY');
const listIdRaw = readEnv('BREVO_LISTA_LIBRO');
let confirmado = false;
let emailConfirmado: string | undefined;

if (token && secret) {
  const result = verifyAccessToken(token, secret);
  if (result.valid) {
    Astro.cookies.set('tejedor-access', token, {
      httpOnly: true,
      secure: true,
      sameSite: 'lax',
      path: '/',
      maxAge: 30 * 24 * 60 * 60, // 30 días
    });
    confirmado = true;
    emailConfirmado = result.email;

    // Añadir contacto a la lista #9 → dispara workflow → envía template #7 (bienvenida)
    // Esto es idempotente: si ya está en la lista, Brevo devuelve 400 que tratamos como éxito.
    if (apiKey && listIdRaw && emailConfirmado) {
      const listId = Number(listIdRaw);
      if (!Number.isNaN(listId)) {
        const added = await addContactToList({ email: emailConfirmado, listId, apiKey });
        if (!added.ok) {
          console.error('[bienvenido] addContactToList failed:', added);
          // No bloqueamos al usuario: la cookie ya está seteada, el contacto existe
          // El admin puede añadirlo manualmente si hace falta.
        }
      }
    }
  }
}

// Si el token es válido, redirige directo a la Obertura.
// El "momento ceremonial" lo vive el lector al cruzar el umbral de la lectura, no en una
// página intermedia. Aquí solo nos quedamos si el token no es válido (mensaje de fallback).
if (confirmado) {
  return Astro.redirect('/obertura', 302);
}
---
<LecturaLarga
  title="Enlace caducado · Tejidos de Vibración"
  description="Tu enlace de confirmación no coincidió. Vuelve a registrarte."
  pageId="bienvenido"
>
  <article class="measure" style="padding-top: 5rem;">
    <header class="center">
      <p class="eyebrow">Tejidos de Vibración</p>
      <h1 class="title-1" style="font-style: italic;">El enlace ya no abre</h1>
    </header>

    <div class="flourish flourish--triple" style="margin-top: 2.5rem;"></div>

    <div class="prose">
      <p class="no-indent">
        Algo no coincidió con tu enlace de confirmación. Puede que haya caducado, o que haya viajado
        a través de demasiados clientes de correo y se haya cortado en alguna parte.
      </p>
      <p>
        No es nada grave. Vuelve a <a href="/recibir" class="lit-link">empezar el registro</a> con el mismo
        correo: Brevo se encarga de no duplicarte y te enviará un nuevo enlace.
      </p>
    </div>

    <div class="center" style="margin-top: 4rem; margin-bottom: 6rem;">
      <a class="lit-link lit-link--lg" href="/recibir">
        Volver a registrarme →
      </a>
    </div>
  </article>
</LecturaLarga>
