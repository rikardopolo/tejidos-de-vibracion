---
/**
 * <PausaReflexiva> (Obertura) · adaptador delgado sobre <Marginalia>.
 *
 * Refactor de deduplicación (2026-05-31): UNA sola base de cajas
 * (Marginalia · system.css GLOBAL → prod-safe). Mapea la API histórica
 * (title/duration/label) al kind 'pausa-reflexiva'.
 *
 * CAMBIO DE APARIENCIA ACEPTADO (decisión Ricardo · "todas las cajas"):
 * pierde el fondo tintado (--obertura-thread-soft) y la viñeta de disco
 * relleno para igualar la versión sobria del libro. Esto ADEMÁS resuelve
 * el bug de scoped-styles-en-MDX que dejaba la caja sin estilo en prod.
 * `label` permite reusar como "Anclaje Experiencial" sin duplicar CSS.
 */
import Marginalia from '@/components/book/Marginalia.astro';

interface Props {
  /** Título corto del ejercicio (ej. "El primer noto"). */
  title: string;
  /** Duración aproximada en texto libre (ej. "2-3 minutos"). */
  duration?: string;
  /** Etiqueta del eyebrow · default "Pausa Reflexiva". */
  label?: string;
}

const { title, duration, label = 'Pausa Reflexiva' } = Astro.props;
---

<Marginalia kind="pausa-reflexiva" titulo={title} duracion={duration} label={label}>
  <slot />
</Marginalia>
