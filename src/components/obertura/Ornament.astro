---
/**
 * <Ornament> · separador ornamental largo · variantes.
 *
 * - default: "— ◇ —" (umbral, transición suave)
 * - large: "◇ ◆ ◇" (cambio mayor, fin de sección)
 *
 * Doctrina: matchea `.ornament` y `.ornament.large` (styles.css · 181-200).
 */

interface Props {
  /** Variante del ornamento · 'default' para "— ◇ —", 'large' para "◇ ◆ ◇". */
  variant?: 'default' | 'large';
}

const { variant = 'default' } = Astro.props;
const glyph = variant === 'large' ? '◇   ◆   ◇' : '— ◇ —';
---

<div class={`ornament ornament--${variant}`} aria-hidden="true">{glyph}</div>

<style>
  .ornament {
    text-align: center;
    font-family: var(--obertura-serif);
    color: var(--obertura-thread);
    margin: 2.6rem 0;
    font-size: 1.1rem;
    letter-spacing: 0.6em;
    user-select: none;
  }
  .ornament--large {
    margin: 4.5rem 0;
    font-size: 1.25rem;
    letter-spacing: 1.2em;
  }
</style>
