---
/**
 * <VozTejido> (Obertura) · adaptador delgado sobre <Marginalia>.
 *
 * Refactor de deduplicación (2026-05-31): UNA sola base de cajas para todo
 * el libro (Marginalia · estilada en system.css GLOBAL → prod-safe, sin el
 * problema de scoped-styles-en-MDX). Mapea la API histórica de la pieza
 * (name/dates/portrait) al kind 'voz-del-tejido'.
 *
 * La paleta paper-and-ink de la Obertura (borde oro-suave #B68914 · eyebrow
 * verde) se preserva con overrides scoped a `.obertura-body .marginalia`
 * en OberturaLayout `<style is:global>`. `portrait` se ignora (compat).
 */
import Marginalia from '@/components/book/Marginalia.astro';

interface Props {
  /** Iniciales del autor · CONSERVADO por compat · ya no se renderiza. */
  portrait?: string;
  /** Nombre completo. */
  name: string;
  /** Fechas de vida (ej. "1842 — 1910"). */
  dates?: string;
}

const { name, dates } = Astro.props;
const titulo = dates ? `${name} (${dates})` : name;
---

<Marginalia kind="voz-del-tejido" titulo={titulo} label="Voz del Tejido">
  <slot />
</Marginalia>
