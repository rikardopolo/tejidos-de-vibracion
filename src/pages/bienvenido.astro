---
import LecturaLarga from '@/layouts/LecturaLarga.astro';
import { verifyAccessToken } from '@/lib/token';
import { addContactToList } from '@/lib/brevo';
import { getServerClient } from '@/lib/supabase';

export const prerender = false;

const readEnv = (key: string): string | undefined => {
  if (typeof process !== 'undefined' && process.env) {
    const p = process.env[key];
    if (p !== undefined && p !== '') return p;
  }
  const m = (import.meta.env as Record<string, string | undefined>)[key];
  if (m !== undefined && m !== '') return m;
  return undefined;
};

// El token llega por query (GET, desde el correo) o por el form (POST, clic humano).
// SOLO el POST sella la confirmación. Así un prefetch del cliente de correo o un
// escáner corporativo (que hacen GET sobre el enlace) nunca confirma sin un cruce
// de umbral deliberado · `confirmed_at` nace de un gesto humano real.
const isPost = Astro.request.method === 'POST';
let token = Astro.url.searchParams.get('t') ?? '';
if (isPost) {
  try {
    const form = await Astro.request.formData();
    token = String(form.get('t') ?? '') || token;
  } catch {
    /* token se queda como el de query si lo hubiera */
  }
}

const secret = readEnv('ACCESS_TOKEN_SECRET');
const tokenResult =
  token && secret
    ? verifyAccessToken(token, secret)
    : ({ valid: false, reason: 'malformed' } as const);

type Estado = 'pending' | 'confirmado' | 'caducado';
const estado: Estado = tokenResult.valid ? (isPost ? 'confirmado' : 'pending') : 'caducado';

// ── Sellado · SOLO en POST con token válido ───────────────────────────────
if (estado === 'confirmado' && tokenResult.valid) {
  const emailConfirmado = tokenResult.email;

  Astro.cookies.set('tejedor-access', token, {
    httpOnly: true,
    secure: true,
    sameSite: 'lax',
    path: '/',
    maxAge: 30 * 24 * 60 * 60, // 30 días
  });

  // Sellar la confirmación del DOI en la Supabase unificada (best-effort, idempotente).
  // `is confirmed_at null` evita re-sellar o duplicar el evento si reenvía el form.
  const supabase = getServerClient();
  if (supabase) {
    try {
      const { data: confirmedLead } = await supabase
        .from('leads')
        .update({ confirmed_at: new Date().toISOString() })
        .eq('email', emailConfirmado)
        .is('confirmed_at', null)
        .select('id')
        .maybeSingle();
      if (confirmedLead?.id) {
        await supabase.from('events').insert({
          lead_id: confirmedLead.id,
          type: 'confirmed',
          source: 'api',
          metadata: { endpoint: 'bienvenido', issuedAt: tokenResult.issuedAt },
        });
      }
    } catch (err) {
      console.error('[bienvenido] supabase confirm stamp threw:', err);
    }
  }

  // Alta en la lista del libro → dispara el workflow de bienvenida en Brevo.
  const apiKey = readEnv('BREVO_API_KEY');
  const listIdRaw = readEnv('BREVO_LISTA_LIBRO');
  if (apiKey && listIdRaw) {
    const listId = Number(listIdRaw);
    if (!Number.isNaN(listId)) {
      const added = await addContactToList({ email: emailConfirmado, listId, apiKey });
      if (!added.ok) {
        console.error('[bienvenido] addContactToList failed:', added);
      }
    }
  }
}

const TITLE: Record<Estado, string> = {
  pending: 'Confirma tu correo · Tejidos de Vibración',
  confirmado: 'La puerta se abrió · Tejidos de Vibración',
  caducado: 'Enlace caducado · Tejidos de Vibración',
};
const DESC: Record<Estado, string> = {
  pending: 'Un gesto más para cruzar el umbral y abrir la Obertura.',
  confirmado: 'Tu correo está confirmado. La Obertura está abierta.',
  caducado: 'Tu enlace de confirmación no coincidió.',
};
---
<LecturaLarga title={TITLE[estado]} description={DESC[estado]} pageId="bienvenido">
  <article class="measure pt-5">
    {estado === 'pending' && (
      <>
        <header class="center">
          <p class="eyebrow eyebrow--gold">Estás a un paso</p>
          <h1 class="title-1" style="font-style: italic;">El umbral del tejido</h1>
        </header>

        <div class="flourish flourish--triple mt-2h"></div>

        <div class="prose">
          <p class="no-indent">
            Tu enlace es válido. Falta un gesto tuyo — el que cruza el umbral. Al confirmar, la Obertura
            del libro se abre para ti, y la primera carta del Tejedor se pone en camino.
          </p>
        </div>

        <form method="POST" action="/bienvenido" class="confirm-form center mt-4 mb-6">
          <input type="hidden" name="t" value={token} />
          <button type="submit" class="confirm-cta">Confirmar · Entrar al tejido →</button>
        </form>
      </>
    )}

    {estado === 'confirmado' && (
      <>
        <header class="center">
          <p class="eyebrow eyebrow--gold">Bienvenido al tejido</p>
          <h1 class="title-1" style="font-style: italic;">La puerta se abrió</h1>
        </header>

        <div class="flourish flourish--triple mt-2h"></div>

        <div class="prose">
          <p class="no-indent">
            Tu correo está confirmado. La Obertura del libro está abierta para ti, y al final del
            recorrido, el primer movimiento del Capítulo 1 te espera.
          </p>
          <p>
            Si la primera carta del Tejedor nunca llega — revisa la carpeta de promociones o spam.
            A veces los correos del tejido se pierden en el ruido del mundo.
          </p>
        </div>

        <div class="center mt-4">
          <a class="lit-link lit-link--lg" href="/obertura">Empezar por la Obertura →</a>
        </div>

        <div class="center mt-2 mb-6">
          <a class="lit-link" href="/sobre-el-libro">Conocer el libro →</a>
        </div>
      </>
    )}

    {estado === 'caducado' && (
      <>
        <header class="center">
          <p class="eyebrow">Tejidos de Vibración</p>
          <h1 class="title-1" style="font-style: italic;">El enlace ya no abre</h1>
        </header>

        <div class="flourish flourish--triple mt-2h"></div>

        <div class="prose">
          <p class="no-indent">
            Algo no coincidió con tu enlace de confirmación. Puede que haya caducado, o que haya viajado
            a través de demasiados clientes de correo y se haya cortado en alguna parte.
          </p>
          <p>
            No es nada grave. Vuelve a <a href="/recibir" class="lit-link">empezar el registro</a> con el mismo
            correo: Brevo se encarga de no duplicarte y te enviará un nuevo enlace.
          </p>
        </div>

        <div class="center mt-4 mb-6">
          <a class="lit-link lit-link--lg" href="/recibir">Volver a registrarme →</a>
        </div>
      </>
    )}
  </article>
</LecturaLarga>

<style>
  .confirm-form { margin-inline: auto; }
  .confirm-cta {
    font-family: var(--sans, 'Inter', sans-serif);
    font-size: 0.78rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    padding: 0.9rem 1.9rem;
    background: var(--tinta, #1a1a1a);
    color: var(--pergamino, #f2ead5);
    border: 1px solid var(--tinta, #1a1a1a);
    border-radius: 2px;
    cursor: pointer;
    transition: background 0.2s ease, color 0.2s ease;
  }
  .confirm-cta:hover {
    background: transparent;
    color: var(--tinta, #1a1a1a);
  }
  @media (prefers-reduced-motion: reduce) {
    .confirm-cta { transition: none; }
  }
</style>
