---
/**
 * OberturaLayout · wrapper delgado sobre <BookReader> para la Obertura.
 * (refactor de deduplicación · 2026-05-31)
 *
 * Todo el chrome común (header de 3 slots, reading-progress, thread-strip,
 * paper-grain, reader-controls, pre-paint de prefs) vive en BookReader.
 * Este wrapper sólo inyecta:
 *   - su TOC (OberturaToc) en el slot izquierdo del header
 *   - su breadcrumb central (◆ {headerLabel}) · omitido en el índice
 *   - su SEO (hreflang · OG og-libro.png · base schema + schemas · indexable)
 *   - su tipografía/paleta propias (EB Garamond · vars --obertura-* ·
 *     frontispiece · copyright · h2.chapter / h3.sub / h4.sub-sub · flourishes)
 *
 * Prefs de lectura migradas al sistema canónico del libro:
 *   - tamaño:  html[data-reader-size="small|default|large"]  (libro-reader.js)
 *   - modo:    html[data-reader-mode="day|night"]
 * La Obertura conserva su escala propia (19/21/23px · sin XL) y su paleta
 * "night" propia, vía overrides scoped a `.obertura-body`.
 *
 * La estética paper-and-ink (EB Garamond · acentos en hilo oro · indigo de
 * los carriles científicos) se conserva intacta en la columna de lectura;
 * sólo el chrome se unifica con los Capítulos.
 */
import BookReader from '@/layouts/BookReader.astro';
import OberturaToc from '@/components/obertura/OberturaToc.astro';
import { baseSchemaGraph, SITE as SEO_SITE } from '@/lib/seo';

interface Props {
  /** Título HTML para el <head>. */
  title: string;
  /** Descripción meta. */
  description?: string;
  /** Etiqueta del breadcrumb · "00 · Frontispicio", "Interludio i", etc.
   *  Omitir en el índice de la Obertura (no muestra breadcrumb). */
  headerLabel?: string;
  /** Slug actual · highlightea la pieza activa en el TOC. */
  currentSlug?: string;
  /** Schema.org JSON-LD adicional · array de bloques. */
  schemas?: Record<string, unknown>[];
  /** Nivel de acceso del lector (0=anónimo, 1=tejedor, 2=suscriptor).
   *  Se propaga a body[data-nivel="..."] para CSS de gating. Default: 1. */
  nivel?: 0 | 1 | 2;
}

const {
  title,
  description,
  headerLabel,
  currentSlug,
  schemas = [],
  nivel = 1,
} = Astro.props;

const SITE = SEO_SITE;
// OG image · `/og/og-libro.png` (1200x630 paper-and-ink). Compartida por la
// biblioteca y los 15 capítulos.
const ogImage = `${SITE}/og/og-libro.png`;
// Schema.org base · Organization + WebSite + Person · misma fuente que antes.
const baseGraph = baseSchemaGraph();
const allSchemas = [{ '@context': 'https://schema.org', '@graph': baseGraph }, ...schemas];
---

<BookReader
  title={title}
  description={description}
  hreflang={true}
  og={{
    type: 'article',
    siteName: 'Tejidos de Realidad',
    locale: 'es_CO',
    image: ogImage,
    imageAlt: `${title} · Obertura del Volumen I · Tejidos de Vibración`,
  }}
  schemas={allSchemas}
  nivel={nivel}
  bodyClass="obertura-body"
  mainClass="obertura-main"
  breadcrumb={headerLabel ? { ornament: '◆', text: headerLabel } : undefined}
>
  <OberturaToc slot="toc" current={currentSlug} />
  <slot />
</BookReader>

<style is:global>
  /* ─── Custom properties Obertura ─────────────────────────────
     Sub-paleta paper-and-ink de la Obertura · armonizada con el canon
     Pergamino del libro (2026-05-18 · migración portal→libro · Opción C).
     - Alineados al canon Pergamino: paper, paper-warm, ink, ink-soft
     - Preservados con identidad paper-and-ink: ink-faded (cálido), gold (apagado)
     - Canon intocable: thread (Hilo del Tejedor) + sus 5 variantes alpha
     Ver decisión documentada en CANON.md sección "Sub-paleta Obertura". */
  :root {
    --obertura-paper: #f2ead5;         /* alineado al canon --pergamino */
    --obertura-paper-warm: #e5dbbe;    /* alineado al canon --pergamino-2 */
    --obertura-paper-deep: #e2d5b8;    /* preservado · profundidad propia */
    --obertura-ink: #1a1a1a;           /* alineado al canon --tinta */
    --obertura-ink-soft: #3a3530;      /* alineado al canon --tinta-suave */
    --obertura-ink-faded: #6b5f4d;     /* PRESERVADO · faded cálido sobre paper */
    /* Sprint unificación de estilo · el "hilo" del chrome migra de
       carmesí (#8b2e2e) a ORO para unificar con Capítulos. Los colores
       semánticos de las cajas (indigo abajo · teal/verde) se conservan. */
    --obertura-thread: #B68914;        /* oro-suave · era carmesí #8b2e2e */
    --obertura-thread-deep: #8a6a10;   /* oro deep · era #5a1818 */
    /* Variantes alpha del hilo · ahora en oro rgb(182,137,20) */
    --obertura-thread-hover: rgba(182, 137, 20, 0.05);    /* hover de TOC/nav-links */
    --obertura-thread-ambient: rgba(182, 137, 20, 0.03);  /* gradient ambient sutil */
    --obertura-thread-soft: rgba(182, 137, 20, 0.08);     /* bg PausaReflexiva */
    --obertura-thread-mark: rgba(182, 137, 20, 0.10);     /* bg badge VozTejido */
    --obertura-thread-quote: rgba(182, 137, 20, 0.32);    /* border-left blockquotes */
    --obertura-indigo: #1f2547;
    --obertura-indigo-soft: #3b446e;
    --obertura-gold: #9c7a2a;          /* PRESERVADO · oro apagado p/ indicadores epistémicos */
    --obertura-rule: rgba(26, 22, 18, 0.18);
    --obertura-rule-soft: rgba(26, 22, 18, 0.08);

    --obertura-serif: 'EB Garamond', 'EB Garamond Fallback', 'Iowan Old Style', Georgia, serif;
    --obertura-sans: 'Inter', 'Inter Fallback', -apple-system, BlinkMacSystemFont, sans-serif;
    --obertura-mono: 'JetBrains Mono', 'SF Mono', Menlo, monospace;

    --obertura-col: 34rem;
    --obertura-rhythm: 1.5rem;
  }

  /* ─── Cuerpo de la Obertura ───────────────────────────────────
     Scoped a `.obertura-body` para ganar a las reglas de `body` de
     system.css (importado por BookReader vía global.css). */
  body.obertura-body {
    background: var(--obertura-paper);
    color: var(--obertura-ink);
    font-family: var(--obertura-serif);
    font-size: 21px;                /* default · = data-reader-size="default" */
    line-height: 1.62;
    font-feature-settings: "kern", "liga", "onum";
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
  }

  /* ─── Main · columna de lectura ──────────────────────────────── */
  .obertura-main {
    position: relative;
    z-index: 1;
    max-width: var(--obertura-col);
    margin: 0 auto;
    padding: 4rem 1.5rem 8rem;
  }

  /* ─── Tipografía base ────────────────────────────────────────── */
  .obertura-main p {
    margin: 0 0 var(--obertura-rhythm);
    text-wrap: pretty;
    hyphens: auto;
    -webkit-hyphens: auto;
  }
  .obertura-main p.lead {
    font-size: 1.18em;
    line-height: 1.55;
    color: var(--obertura-ink-soft);
  }
  .obertura-main p.dropcap::first-letter,
  .obertura-main p.lead.dropcap::first-letter {
    font-family: var(--obertura-serif);
    font-weight: 600;
    font-size: 4.4em;
    line-height: 0.85;
    float: left;
    padding: 0.05em 0.12em 0 0;
    color: var(--obertura-thread);
    font-style: italic;
  }

  .obertura-main em,
  .obertura-main i { font-style: italic; }
  .obertura-main strong,
  .obertura-main b { font-weight: 600; color: var(--obertura-ink); }

  /* ─── Separadores .flourish ───────────────────────────────────
     Emitidos por remark-separators.mjs (B.2) al gildar los literales
     standalone (— ◇ —, ◆, ◇ ◆ ◇). En oro vía --obertura-thread.
     Capítulos define lo mismo en system.css · misma apariencia. */
  .flourish {
    text-align: center;
    font-family: var(--obertura-serif);
    color: var(--obertura-thread);
    font-size: 1.25rem;
    letter-spacing: 0.6em;
    margin: 3rem 0;
    user-select: none;
  }
  .flourish--diamond::before { content: '◆'; }
  .flourish--triple::before  { content: '◇   ◆   ◇'; }
  .flourish--rule::before    { content: '— ◇ —'; letter-spacing: 0.3em; }

  /* ─── Cajas sobrias · Voz del Tejido / Pausa Científica ───────────
     Espejo de .marginalia / --voz / --cientifica (system.css). Viven en
     el GLOBAL del layout, NO en el <style> scoped del componente: el
     estilo scoped de un .astro usado dentro de MDX genera un selector
     `[data-astro-cid-…]` que el build de producción NO aplica al elemento
     (works-in-dev, breaks-in-prod). En global no hay requisito de cid →
     siempre aplica. Mismo patrón que .flourish (B.2). Border oro; eyebrow
     con color semántico (verde Voz · índigo Pausa · decisión 1). */
  .voz-tejido,
  .pausa-cientifica {
    border-left: 2px solid var(--obertura-thread);
    padding: 1.5rem 0 1.5rem 1.75rem;
    margin: 2.5rem 0;
    background: transparent;
  }
  .voz-tejido__kind,
  .pausa-cientifica__kind {
    font-family: 'DM Sans', var(--obertura-sans);
    font-weight: 500;
    font-size: 0.6875rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    margin: 0 0 0.25rem 0;
  }
  .voz-tejido__kind        { color: #1D9E75; }            /* verde/teal · Voz */
  .pausa-cientifica__kind  { color: var(--obertura-indigo); } /* índigo · carril científico */
  .voz-tejido__title,
  .pausa-cientifica__title {
    font-family: var(--obertura-serif);
    font-style: italic;
    font-weight: 500;
    font-size: 1.375rem;
    line-height: 1.3;
    color: var(--obertura-ink);
    margin: 0 0 1rem 0;
  }
  .voz-tejido__body,
  .pausa-cientifica__body {
    font-size: 1.0625rem;
    line-height: 1.65;
    color: var(--obertura-ink-soft);
  }
  .voz-tejido__body p,
  .pausa-cientifica__body p { margin: 0 0 1em 0; }
  .voz-tejido__body p:last-child,
  .pausa-cientifica__body p:last-child { margin-bottom: 0; }
  .pausa-cientifica__body ul { font-size: 0.95em; padding-left: 1.2rem; margin: 1rem 0; }
  .pausa-cientifica__body ul li { margin-bottom: 0.5rem; }
  .pausa-cientifica__body .ref {
    font-size: 0.85em;
    color: var(--obertura-ink-faded);
    font-style: italic;
    border-left: 1px solid var(--obertura-rule);
    padding-left: 0.9rem;
    margin: 1.2rem 0;
  }
  .pausa-cientifica__body .limit {
    font-size: 0.92em;
    margin-top: 1rem;
    padding-top: 0.9rem;
    border-top: 1px dashed var(--obertura-rule);
    color: var(--obertura-ink-soft);
  }
  .pausa-cientifica__body .limit strong { color: var(--obertura-indigo); }

  /* ─── Encabezados ────────────────────────────────────────────── */
  .obertura-main h1.book-title {
    font-family: var(--obertura-serif);
    font-weight: 500;
    font-size: clamp(2.4rem, 5vw, 3.8rem);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    text-align: center;
    margin: 0 0 0.6rem;
    line-height: 1.05;
  }
  .obertura-main h1.book-title .ampersand {
    font-style: italic;
    font-weight: 400;
    letter-spacing: 0;
    text-transform: lowercase;
    color: var(--obertura-thread);
  }

  .obertura-main h2.chapter {
    font-family: var(--obertura-serif);
    font-weight: 500;
    font-size: clamp(1.7rem, 3.5vw, 2.4rem);
    line-height: 1.15;
    margin: 5rem 0 2rem;
    letter-spacing: -0.005em;
    text-wrap: balance;
  }
  .obertura-main h2.chapter .num {
    display: block;
    font-family: var(--obertura-sans);
    font-weight: 400;
    font-size: 0.72rem;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--obertura-thread);
    margin-bottom: 0.5rem;
  }

  /* h3.sub · subtítulos de sección "kicker italic". Tamaño en em para que
     escale con el body (21px → ~30px). */
  .obertura-main h3.sub {
    font-family: var(--obertura-serif);
    font-weight: 500;
    font-style: italic;
    font-size: 1.42em;
    line-height: 1.22;
    margin: 3rem 0 1.4rem;
    color: var(--obertura-ink);
    letter-spacing: 0.003em;
    text-wrap: balance;
    padding-top: 1.2rem;
    border-top: 1px solid var(--obertura-rule-soft);
    position: relative;
  }
  .obertura-main h3.sub::before {
    content: "◆";
    position: absolute;
    top: -0.55em;
    left: 50%;
    transform: translateX(-50%);
    background: var(--obertura-paper);
    padding: 0 0.6em;
    font-size: 0.55em;
    color: var(--obertura-thread);
    font-style: normal;
    letter-spacing: 0;
  }
  .obertura-main h3.sub .num {
    font-family: var(--obertura-sans);
    font-style: normal;
    font-weight: 500;
    font-size: 0.78em;
    color: var(--obertura-ink-faded);
    margin-right: 0.55em;
    letter-spacing: 0.05em;
  }

  /* h4.sub-sub · sub-subsecciones tipo eyebrow. Italic oro con leading
     rombo. Tamaño en em para que escale con el body (21px → ~22px). */
  .obertura-main h4.sub-sub {
    font-family: var(--obertura-serif);
    font-weight: 600;
    font-style: italic;
    font-size: 1.06em;
    line-height: 1.3;
    margin: 2.4rem 0 1rem;
    color: var(--obertura-thread);
    letter-spacing: 0.01em;
    text-wrap: balance;
  }
  .obertura-main h4.sub-sub::before {
    content: "◇ ";
    color: var(--obertura-thread);
    font-style: normal;
    margin-right: 0.4em;
    opacity: 0.8;
  }
  /* Anotación parentética dentro del h4 (Nivel · descripción) · se separa
     visualmente como sub-línea muted, no italic. */
  .obertura-main h4.sub-sub .sub-sub-meta {
    display: block;
    margin-top: 0.3em;
    font-family: var(--obertura-sans);
    font-style: normal;
    font-weight: 400;
    font-size: 0.68em;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--obertura-ink-faded);
  }

  /* Citaciones sagradas · mantras / escrituras / mitos cosmogónicos
     emitidos por el parser como <blockquote class="cita">. Destacado en
     indigo con borde izquierdo, evocando el "carril contemplativo". */
  .obertura-main blockquote.cita {
    margin: 2.2rem 0 2.2rem 0.5rem;
    padding: 0.4rem 0 0.4rem 1.5rem;
    border-left: 2.5px solid var(--obertura-indigo);
    font-family: var(--obertura-serif);
    font-style: italic;
    font-size: 1.06em;
    line-height: 1.5;
    color: var(--obertura-indigo);
    text-wrap: pretty;
  }

  /* ─── Listas con marca diamante ──────────────────────── */
  .obertura-main ul.bullet,
  .obertura-main ul:not(.evidence-list):not([class]) {
    list-style: none;
    padding: 0;
    margin: 1.5rem 0;
  }
  .obertura-main ul.bullet li,
  .obertura-main ul:not(.evidence-list):not([class]) li {
    position: relative;
    padding-left: 1.6rem;
    margin-bottom: 0.8rem;
    line-height: 1.55;
  }
  .obertura-main ul.bullet li::before,
  .obertura-main ul:not(.evidence-list):not([class]) li::before {
    content: "◇";
    position: absolute;
    left: 0;
    top: 0;
    color: var(--obertura-thread);
    font-size: 0.8em;
  }

  /* ─── Blockquote ─────────────────────────────────────── */
  .obertura-main blockquote {
    margin: 1.5rem 0;
    padding: 0 1.4rem;
    border-left: 2px solid var(--obertura-thread);
    font-style: italic;
    color: var(--obertura-ink-soft);
  }

  /* ─── Eyebrow centered (UMBRAL POÉTICO, etc.) ────────── */
  .obertura-main .section-eyebrow-bold {
    font-family: var(--obertura-serif);
    font-weight: 600;
    font-size: 0.85rem;
    letter-spacing: 0.5em;
    text-transform: uppercase;
    color: var(--obertura-thread);
    text-align: center;
    margin: 2.5rem 0 1.2rem;
  }

  /* ─── Frontispiece (portada del PDF) ─────────────────── */
  .obertura-main .frontispiece {
    text-align: center;
    padding: 2rem 0 3rem;
    border-bottom: 1px solid var(--obertura-rule-soft);
    margin-bottom: 4rem;
  }
  .frontispiece-volumen {
    font-family: var(--obertura-sans);
    font-weight: 400;
    font-size: 0.78rem;
    letter-spacing: 0.4em;
    text-transform: uppercase;
    color: var(--obertura-ink-faded);
    margin: 0 0 2.5rem;
  }
  .frontispiece-ornament {
    text-align: center;
    color: var(--obertura-thread);
    margin: 4.5rem 0;
    font-size: 1.25rem;
    letter-spacing: 1.2em;
    user-select: none;
  }
  .frontispiece-kicker {
    font-family: var(--obertura-serif);
    font-weight: 600;
    font-size: 0.85rem;
    letter-spacing: 0.5em;
    text-transform: uppercase;
    color: var(--obertura-thread);
    margin: 2.5rem 0 0.8rem;
  }
  .frontispiece-subtitle {
    font-family: var(--obertura-serif);
    font-style: italic;
    font-size: 1.35rem;
    color: var(--obertura-ink);
    margin: 0;
  }
  .frontispiece-author {
    font-family: var(--obertura-serif);
    font-style: italic;
    font-size: 1.1rem;
    color: var(--obertura-ink-soft);
    margin: 1.2rem 0 0.3rem;
  }
  .frontispiece-date {
    font-family: var(--obertura-sans);
    font-size: 0.78rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--obertura-ink-faded);
  }

  /* ─── Copyright page (registro SafeCreative) ─────────── */
  .copyright-page {
    margin: 3rem auto 4rem;
    padding: 2rem 0;
    border-top: 1px solid var(--obertura-rule-soft);
    border-bottom: 1px solid var(--obertura-rule-soft);
    font-family: var(--obertura-serif);
    font-size: 0.95rem;
    line-height: 1.6;
    color: var(--obertura-ink-soft);
  }
  .copyright-page p { margin: 0.4rem 0; }
  .copyright-title {
    font-style: italic;
    margin-bottom: 1.4rem !important;
  }
  .copyright-code-num {
    font-family: var(--obertura-mono);
    font-size: 0.92em;
    color: var(--obertura-ink);
  }
  .copyright-rights { font-style: italic; margin-top: 1.4rem !important; }
  .copyright-edition {
    margin-top: 1.2rem !important;
    font-family: var(--obertura-sans);
    font-size: 0.85rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--obertura-ink-faded);
  }
  .copyright-page a {
    color: var(--obertura-indigo);
    border-bottom: 1px solid var(--obertura-rule-soft);
  }

  /* ─── Reader font-size scaler ─────────────────────────
     Migrado al sistema del libro: html[data-reader-size] (libro-reader.js).
     La Obertura conserva su escala propia (19/21/23px · default 21px ·
     sin XL · "reset prefs" aceptado en measurements.md). */
  html[data-reader-size="small"] body.obertura-body { font-size: 19px; }
  html[data-reader-size="large"] body.obertura-body { font-size: 23px; }

  /* ─── Modo noche · paleta paper-and-ink invertida ─────
     Migrado de body[data-theme="dark"] a html[data-reader-mode="night"]
     (sistema canónico del libro). Sólo redefine las vars --obertura-*
     para la columna de lectura; el chrome usa la paleta night del libro
     (system.css). El paper-grain lo provee BookReader. */
  html[data-reader-mode="night"] body.obertura-body {
    --obertura-paper:      #14110d;
    --obertura-paper-warm: #1c1812;
    --obertura-paper-deep: #221d16;
    --obertura-ink:        #e8dec9;
    --obertura-ink-soft:   #c9bfa6;
    --obertura-ink-faded:  #8b8270;
    --obertura-thread:     #d9b24a;
    --obertura-thread-deep:#b8902f;
    --obertura-indigo:     #8b95c4;
    --obertura-indigo-soft:#6e7aa8;
    --obertura-gold:       #d4a754;
    --obertura-rule:       rgba(232, 222, 201, 0.18);
    --obertura-rule-soft:  rgba(232, 222, 201, 0.08);
  }

  /* ─── Móvil ──────────────────────────────────────────── */
  @media (max-width: 640px) {
    body.obertura-body { font-size: 19px; }
    html[data-reader-size="small"] body.obertura-body { font-size: 17px; }
    html[data-reader-size="large"] body.obertura-body { font-size: 21px; }
    .obertura-main { padding: 3rem 1.2rem 6rem; }
  }
</style>
