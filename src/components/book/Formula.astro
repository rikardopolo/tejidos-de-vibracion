---
/**
 * <Formula> · cartouche tipográfica para ecuaciones del libro.
 *
 * Patrón: eyebrow "Fórmula 3.X" en cornisa + título descriptivo en serif italic,
 * la fórmula misma centrada en JetBrains Mono grande sobre fondo papel sutil,
 * y un slot opcional `donde` para la tabla de símbolos.
 *
 * Uso típico (MDX):
 *   <Formula num="3.2" titulo="Principio de Incertidumbre (heurístico)">
 *     Δx · Δp ≥ ℏ/2
 *
 *     <Fragment slot="donde">
 *     **Δx** · incertidumbre en la posición (m)
 *
 *     **Δp** · incertidumbre en el momento (kg·m/s)
 *
 *     **ℏ** · constante de Planck reducida ≈ 1.055 × 10⁻³⁴ J·s
 *     </Fragment>
 *   </Formula>
 *
 * Estilos en <style is:global> con namespace `formula__*` para sobrevivir el uso
 * dentro de MDX en producción (los <style> scoped generan selector data-astro-cid
 * que el build de prod no aplica a elementos provenientes de MDX).
 *
 * Tipografía matemática: el cuerpo acepta LaTeX vía `$$...$$` (remark-math +
 * rehype-katex, configurados en astro.config.mjs). El CSS de KaTeX se importa
 * aquí para que cargue donde haya fórmulas; basta `import` (Astro lo empaqueta).
 */
import 'katex/dist/katex.min.css';

interface Props {
  /** Número de la fórmula · ej. "3.2". */
  num: string;
  /** Título descriptivo · ej. "Principio de Incertidumbre". Opcional. */
  titulo?: string;
}
const { num, titulo } = Astro.props;
const hasDonde = Astro.slots.has('donde');
---

<figure class="formula" role="figure" aria-label={`Fórmula ${num}${titulo ? ': ' + titulo : ''}`}>
  <figcaption class="formula__caption">
    <span class="formula__kicker">Fórmula {num}</span>
    {titulo && <span class="formula__titulo">{titulo}</span>}
  </figcaption>

  <div class="formula__body">
    <slot />
  </div>

  {hasDonde && (
    <div class="formula__donde">
      <p class="formula__donde-label">Donde</p>
      <div class="formula__donde-body">
        <slot name="donde" />
      </div>
    </div>
  )}
</figure>

<style is:global>
  .formula {
    margin: 2.5rem auto;
    padding: 1.6rem 1.8rem 1.8rem;
    max-width: 38rem;
    background: rgba(212, 160, 23, 0.04);
    border-top: 1px solid rgba(182, 137, 20, 0.35);
    border-bottom: 1px solid rgba(182, 137, 20, 0.35);
    text-align: center;
  }
  .formula__caption {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    margin: 0 0 1.4rem;
  }
  .formula__kicker {
    font-family: var(--cornisa, var(--sans));
    font-size: 0.72rem;
    font-weight: 500;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--oro-suave);
  }
  .formula__titulo {
    font-family: var(--serif);
    font-style: italic;
    font-size: 1.0625rem;
    color: var(--tinta);
    line-height: 1.4;
  }
  .formula__body {
    font-family: var(--mono);
    font-size: clamp(1.05rem, 2.4vw, 1.35rem);
    line-height: 1.6;
    color: var(--tinta);
    letter-spacing: 0.01em;
    padding: 0.6rem 0;
  }
  .formula__body p {
    margin: 0.35rem 0;
    text-align: center !important;
    text-indent: 0 !important;
  }
  .formula__donde {
    margin-top: 1.4rem;
    padding-top: 1.1rem;
    border-top: 1px dotted rgba(182, 137, 20, 0.4);
    text-align: left;
  }
  .formula__donde-label {
    font-family: var(--cornisa, var(--sans));
    font-size: 0.7rem;
    font-weight: 500;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--oro-suave);
    margin: 0 0 0.8rem;
  }
  .formula__donde-body {
    font-family: var(--serif);
    font-size: 0.94rem;
    line-height: 1.55;
    color: var(--tinta-suave);
  }
  .formula__donde-body p {
    margin: 0.45rem 0;
    text-align: left !important;
    text-indent: 0 !important;
    hyphens: manual;
  }
  .formula__donde-body strong {
    font-family: var(--mono);
    font-style: normal;
    font-weight: 500;
    color: var(--tinta);
  }
  .formula__donde-body em {
    font-style: italic;
    color: var(--tinta-suave);
  }

  /* Modo noche · mantiene legibilidad y la línea oro */
  body.modo-tinta .formula {
    background: rgba(212, 160, 23, 0.06);
  }
  body.modo-tinta .formula__body { color: var(--pergamino); }
  body.modo-tinta .formula__titulo { color: var(--pergamino); }
  body.modo-tinta .formula__donde-body { color: rgba(245, 240, 228, 0.78); }
  body.modo-tinta .formula__donde-body strong { color: var(--pergamino); }

  @media (max-width: 540px) {
    .formula { padding: 1.2rem 1rem 1.4rem; margin: 1.8rem auto; }
    .formula__body { font-size: 1rem; }
  }
</style>
