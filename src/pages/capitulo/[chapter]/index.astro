---
/**
 * /capitulo/[chapter] · indice biblioteca del capítulo + fallback monolítico.
 *
 * Comportamiento smart según estado del capítulo:
 *
 * 1. Si el capítulo tiene piezas en `chapter-sections` (estado `published` o
 *    `fragmento-permanente`) → renderiza la BIBLIOTECA del capítulo: lista
 *    navegable de piezas con header sticky + TOC editorial.
 *
 * 2. Si no hay piezas (chapter-sections vacío para este capítulo) →
 *    renderiza el header del capítulo + BloquePuerta (espera para N1,
 *    bloqueado para N0). Este es el FALLBACK MONOLÍTICO · misma UX que
 *    el `[slug].astro` antiguo. Aplica para:
 *    - Cap. 1 con `status: "fragmento-permanente"` antes de migración (PR-B)
 *    - Cap. 2 y Cap. 3 en gestación (sin chapter-sections planeadas todavía)
 *
 * Patrón paralelo a `pages/obertura/index.astro` (biblioteca de Obertura).
 * Reemplaza el antiguo `pages/capitulo/[slug].astro`.
 *
 * Sprint shell-redesign (preview/chapters-1-2-3): usa CapituloLayout y
 * marcadores compactos por tipo de pieza (pieceMarker).
 */
import { getCollection, getEntry, render } from 'astro:content';
import CapituloLayout from '@/layouts/CapituloLayout.astro';
import BloquePuerta from '@/components/book/BloquePuerta.astro';
import { getAcceso, puedeAcceder, gatingActivo, type Nivel } from '@/lib/gating';
import { romanize } from '@/lib/utils';
import { pieceMarker, type PieceKind } from '@/lib/piece-num';

export const prerender = false;

const { chapter } = Astro.params;
if (!chapter) return Astro.redirect('/indice');

const chapterEntry = await getEntry('book', chapter);
if (!chapterEntry || chapterEntry.data.kind !== 'capitulo') {
  return Astro.redirect('/indice');
}

const acceso = gatingActivo() ? getAcceso(Astro.cookies) : { nivel: 1 as Nivel, slugs: [] };
const nivel = acceso.nivel;
const data = chapterEntry.data;
const chapterNum = data.chapter ?? 0;
const romanChapter = romanize(chapterNum);
const capitulo = `Capítulo ${romanChapter}`;

// Buscar todas las piezas del capítulo en chapter-sections.
//
// El filtro NO aplica `status` porque la visibilidad pública la decide
// el status del CAPÍTULO PADRE (ver `[section].astro` para racional).
// El campo `status` por pieza queda para tracking editorial interno
// pero NO afecta el gating runtime.
const allSections = await getCollection('chapter-sections', ({ data: d }) =>
  d.chapter === chapter
);
const sections = allSections.sort((a, b) => a.data.order - b.data.order);
const hasSections = sections.length > 0;

// Fallback monolítico (sin chapter-sections): mismo comportamiento que el
// antiguo [slug].astro. Cap. 1 con status 'fragmento-permanente' siempre
// muestra BloquePuerta (esCap1Publicado=false). Cap. 2/3 idem.
//
// PREVIEW BRANCH ONLY (preview/chapters-1-2-3 · NO MERGE A MAIN):
// en cualquier rama Vercel distinta de main relajamos chapterNum===1
// para permitir revisar el contenido monolitico de Cap.2 y Cap.3 tal
// como esta en main, sin migrar a chapter-sections.
const branchRef = (typeof process !== 'undefined' && process.env)
  ? (process.env.VERCEL_GIT_COMMIT_REF ?? '')
  : '';
const esPreviewBranch = branchRef !== '' && branchRef !== 'main';
const esCapPublicadoMonolitico = !hasSections && data.status === 'published'
  && (chapterNum === 1 || esPreviewBranch);
// Gating data-driven: exige el nivel declarado por el capítulo (default 1) y,
// si pertenece a un producto de pago, el slug en el scope del token de compra.
// Con los defaults de Acto I (nivelRequerido=1, sin productoSlug) equivale al
// histórico `nivel >= 1` → no-regresión.
const verContenido = puedeAcceder(acceso, data.nivelRequerido, data.productoSlug)
  && esCapPublicadoMonolitico;
const tipoBloquePuerta = nivel === 0 ? 'cap-bloqueado' : 'cap-espera';

let Content: any = null;
if (verContenido) {
  const rendered = await render(chapterEntry);
  Content = rendered.Content;
}
const leaf = (slug: string) => slug.split('/').pop() ?? slug;
---

<CapituloLayout
  title={`Cap. ${romanChapter} · ${data.title} · Tejidos de Vibración`}
  description={`${data.subtitle ? data.subtitle + ' · ' : ''}Capítulo ${romanChapter} de Tejidos de Vibración, un libro de física cuántica y conciencia por Ricardo Polo`}
  chapter={chapter}
  chapterLabel={capitulo}
  chapterTitle={data.title}
  nivel={nivel}
  pageId={`capitulo-${chapterNum}`}
  robots={data.status === 'published' ? undefined : 'noindex,follow'}
>
  <article class="measure">
    <header class="piece-header">
      <p class="eyebrow">Acto {data.act} · Capítulo {romanChapter}</p>
      <h1 class="piece-title">{data.title}</h1>
      {data.subtitle && <p class="piece-subtitle">{data.subtitle}</p>}
    </header>

    <div class="flourish flourish--rule"></div>

    {hasSections ? (
      <Fragment>
        {/* BIBLIOTECA · piezas navegables del capítulo */}
        <p class="section-eyebrow">Las {sections.length} piezas del capítulo</p>
        <ol class="cap-biblioteca">
          {sections.map((s) => (
            <li class="cap-biblioteca__item">
              <a href={`/capitulo/${chapter}/${leaf(s.id)}`} class="cap-biblioteca__link">
                <span class="cap-biblioteca__num">{pieceMarker({ kind: s.data.kind as PieceKind, num: s.data.num })}</span>
                <span class="cap-biblioteca__body">
                  <span class="cap-biblioteca__title">{s.data.title}</span>
                  {s.data.subtitle && <em class="cap-biblioteca__sub">{s.data.subtitle}</em>}
                </span>
              </a>
            </li>
          ))}
        </ol>
      </Fragment>
    ) : (
      <Fragment>
        {/* FALLBACK MONOLÍTICO · sin piezas en chapter-sections aún. */}
        {Content && (
          <section class="prose dropcap section-gap">
            <Content />
          </section>
        )}

        <BloquePuerta tipo={tipoBloquePuerta} capitulo={capitulo} />
      </Fragment>
    )}
  </article>
</CapituloLayout>

<style>
  /* Biblioteca del capítulo · estilos scoped. */
  .cap-biblioteca {
    list-style: none;
    padding: 0;
    margin: 2rem 0 4rem;
  }
  .cap-biblioteca__item {
    border-bottom: 1px solid var(--pergamino-2);
  }
  .cap-biblioteca__item:first-child {
    border-top: 1px solid var(--pergamino-2);
  }
  .cap-biblioteca__link {
    display: grid;
    grid-template-columns: 4.5rem 1fr;
    column-gap: 1.5rem;
    align-items: baseline;
    padding: 1.25rem 0;
    text-decoration: none;
    color: var(--tinta);
    transition: background 180ms ease, padding 180ms ease;
  }
  .cap-biblioteca__link:hover {
    background: var(--pergamino-2);
    padding-left: 0.75rem;
  }
  .cap-biblioteca__num {
    font-family: var(--mono);
    font-size: 0.85rem;
    color: var(--oro-suave);
    letter-spacing: 0.04em;
    text-align: center;
  }
  .cap-biblioteca__title {
    font-family: var(--serif);
    font-weight: 500;
    font-size: 1.2rem;
    line-height: 1.3;
  }
  .cap-biblioteca__sub {
    display: block;
    font-family: var(--serif);
    font-style: italic;
    font-size: 0.95rem;
    color: var(--reposo);
    margin-top: 0.2rem;
  }
</style>
