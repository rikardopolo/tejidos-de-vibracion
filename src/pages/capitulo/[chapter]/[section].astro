---
/**
 * /capitulo/[chapter]/[section] · ruta dinámica para piezas individuales
 * de un capítulo del libro.
 *
 * Migrada en patrón paralelo a `/obertura/[slug]` pero con doble nivel
 * de path para preservar `/capitulo/<chapter>/<section>` como URL canónica
 * (decisión arquitectónica B1 · ver PROMPT-CAP1-BIBLIOTECA-FIGURAS-2026-05-18.md).
 *
 * Source de piezas: colección `chapter-sections`.
 *   - Carpeta: src/content/chapter-sections/<chapter>/<section>.mdx
 *   - Frontmatter: chapter, kind, num, title, subtitle, order, headerLabel, status
 *
 * Gating idéntico al de la Obertura:
 *   - status 'published' + nivel >= 1 → contenido completo
 *   - status 'fragmento-permanente' o nivel < 1 → BloquePuerta espera/bloqueado
 *
 * Bot allowlist replicada del Obertura/[slug] · search engines + LLM
 * crawlers + social unfurlers bypasean el gating.
 *
 * Sprint shell-redesign (preview/chapters-1-2-3): usa CapituloLayout
 * (header minimalista + breadcrumb dinámico + LECTURA) y PaginacionCards.
 */
import { getCollection, getEntry, render } from 'astro:content';
import CapituloLayout from '@/layouts/CapituloLayout.astro';
import BloquePuerta from '@/components/book/BloquePuerta.astro';
import PaginacionCards from '@/components/book/PaginacionCards.astro';
import { getAcceso, puedeAcceder, gatingActivo, type Nivel } from '@/lib/gating';
import { romanize } from '@/lib/utils';
import { pieceOrnament, type PieceKind } from '@/lib/piece-num';

export const prerender = false;

const { chapter, section } = Astro.params;
if (!chapter || !section) return Astro.redirect('/indice');

// Bot allowlist · permite indexación + previews sin cookie.
const ua = Astro.request.headers.get('user-agent') ?? '';
const isBot = /bot|crawl|spider|googlebot|bingbot|gptbot|claudebot|perplexitybot|google-extended|oai-searchbot|anthropic-ai|cohere-ai|yandex|baiduspider|duckduckbot|applebot|facebookexternalhit|twitterbot|linkedinbot|whatsapp|telegrambot|slackbot|discord|mojeekbot|opengraph|preview|unfurl|metainspector|embed/i.test(ua);

// Cargar la pieza solicitada.
const entry = await getEntry('chapter-sections', `${chapter}/${section}`);
if (!entry || entry.data.chapter !== chapter) {
  return new Response('Pieza no encontrada', { status: 404 });
}

// Verificar que el capítulo padre existe.
const chapterEntry = await getEntry('book', chapter);
if (!chapterEntry || chapterEntry.data.kind !== 'capitulo') {
  return Astro.redirect('/indice');
}

const chapterNum = chapterEntry.data.chapter ?? 0;
const romanChapter = romanize(chapterNum);
const capitulo = `Capítulo ${romanChapter}`;

// Nivel del lector + decisión de acceso.
//
// IMPORTANTE · el gating lee el status del CAPÍTULO PADRE
// (`book/<chapter>.mdx`), NO el de la pieza individual.
//
// Razón editorial: el capítulo es la unidad publicada. En junio 2026 un
// solo cambio en `book/cap-1-universo-sinfonia.mdx` (status published)
// activa las 9 piezas simultáneamente · cero fricción de mantenimiento.
//
// El campo `status` en el frontmatter de cada pieza queda para tracking
// editorial interno (draft/review/published) pero NO afecta el gating
// runtime. Lo único que define visibilidad pública es el status del
// capítulo padre.
const acceso = isBot
  ? { nivel: 1 as Nivel, slugs: [] }
  : (gatingActivo() ? getAcceso(Astro.cookies) : { nivel: 1 as Nivel, slugs: [] });
const nivel = acceso.nivel;
// Gating data-driven · requisito efectivo = el MAYOR entre el del capítulo
// padre (unidad publicada) y el de la pieza; el productoSlug de la pieza tiene
// prioridad sobre el del capítulo. Con los defaults de Acto I (nivelRequerido=1,
// sin productoSlug) esto equivale al histórico `nivel >= 1` → no-regresión.
const nivelRequerido = Math.max(
  chapterEntry.data.nivelRequerido,
  entry.data.nivelRequerido,
) as Nivel;
const productoSlug = entry.data.productoSlug ?? chapterEntry.data.productoSlug;
const tieneAcceso = chapterEntry.data.status === 'published'
  && puedeAcceder(acceso, nivelRequerido, productoSlug);
const tipoBloquePuerta = nivel === 0 ? 'cap-bloqueado' : 'cap-espera';

let Content: any = null;
if (tieneAcceso) {
  const rendered = await render(entry);
  Content = rendered.Content;
}

const { title, subtitle, headerLabel, kind, num } = entry.data;

// Resolver prev/next entre piezas del mismo capítulo.
//
// NO se filtra por `status` de la pieza · la visibilidad la decide el
// status del CAPÍTULO PADRE (igual que en index.astro · biblioteca).
// El campo status por pieza es tracking editorial interno y las piezas
// se crean en 'draft' por defecto; filtrarlo aquí dejaba prev/next vacío
// y rompía la navegación. Alineado con el query de la biblioteca.
const allSections = await getCollection('chapter-sections', ({ data: d }) =>
  d.chapter === chapter
);
const sorted = allSections.sort((a, b) => a.data.order - b.data.order);
const idx = sorted.findIndex(s => s.id === entry.id);
const prevEntry = idx > 0 ? sorted[idx - 1] : null;
const nextEntry = idx >= 0 && idx < sorted.length - 1 ? sorted[idx + 1] : null;

const leaf = (slug: string) => slug.split('/').pop() ?? slug;
const toAdjacent = (e: typeof entry | null) =>
  e ? { slug: leaf(e.id), kind: e.data.kind as PieceKind, num: e.data.num, title: e.data.title } : null;
const prev = toAdjacent(prevEntry);
const next = toAdjacent(nextEntry);

// Breadcrumb central del header · "◆ §2.1 · Cap. 2" (decisiones 2+3).
const ornament = pieceOrnament(kind as PieceKind);
const pieceLabel = kind === 'numbered' && num
  ? `§${num}`
  : ({ portada: 'Portada', umbral: 'Umbral', anclaje: 'Anclaje', cierre: 'Cierre' } as Record<string, string>)[kind] ?? '';
const breadcrumbText = `${pieceLabel} · Cap. ${chapterNum}`;
---

<CapituloLayout
  title={`${title} · Cap. ${romanChapter} · Tejidos de Vibración`}
  description={subtitle ?? `${headerLabel} · Capítulo ${romanChapter}`}
  chapter={chapter}
  chapterLabel={capitulo}
  chapterTitle={chapterEntry.data.title}
  currentSlug={section}
  breadcrumbOrnament={ornament}
  breadcrumbText={breadcrumbText}
  nivel={nivel}
  pageId={`capitulo-${chapterNum}-${section}`}
>
  <article class={`ca-lectura kind-${kind}`}>
    {/* Eyebrow del cuerpo eliminado (sub-tarea 3.5): el breadcrumb sticky
        del CapituloLayout ya comunica "◆ §N · Cap. N" de forma persistente.
        El index biblioteca SÍ conserva su eyebrow (no tiene breadcrumb).

        Portadas (kind='portada') omiten el header h1/subtitle/flourish:
        su contenido MDX ya renderiza <Frontispicio> con el título de la
        sección, y duplicar el h1 estructural producía un doble título
        editorialmente indeseado. Las demás piezas conservan su header. */}
    {kind !== 'portada' && (
      <>
        <header class="piece-header">
          <h1 class="piece-title">{title}</h1>
          {subtitle && <p class="piece-subtitle">{subtitle}</p>}
        </header>

        <div class="flourish flourish--rule"></div>
      </>
    )}

    {tieneAcceso && Content ? (
      <section class="prose dropcap section-gap">
        <Content />
      </section>
    ) : (
      <BloquePuerta tipo={tipoBloquePuerta} capitulo={capitulo} />
    )}

    {tieneAcceso && <PaginacionCards chapter={chapter} prev={prev} next={next} />}
  </article>
</CapituloLayout>
