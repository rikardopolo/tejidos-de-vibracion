---
/**
 * BookReader · shell de lectura base compartido por la Obertura y los
 * capítulos del libro (refactor de deduplicación · 2026-05-31).
 *
 * Absorbe TODO el chrome común que antes estaba duplicado entre
 * OberturaLayout y CapituloLayout:
 *   - documento standalone (<!doctype html>) + <head> parametrizado (SEO)
 *   - script pre-paint de preferencias de lectura (tdv-reader-* en <html>)
 *   - reading-progress · thread-strip · paper-grain
 *   - header sticky de 3 slots (TOC · breadcrumb/back · LECTURA)
 *   - panel de reader-controls (#reader-controls) + /libro-reader.js
 *   - comportamiento de chrome (is-scrolled, cierre de TOC) en /book-chrome.js
 *
 * Cada layout-wrapper (OberturaLayout / CapituloLayout) inyecta vía slots
 * + props: su TOC, su breadcrumb/back-link, su tipografía y su SEO.
 *
 * Nota de naming: las clases del chrome usan prefijo `book-*`. La clase del
 * <main> es per-wrapper (`mainClass`: cap-main / obertura-main) porque la
 * columna de lectura y su tipografía difieren legítimamente.
 *
 * Reader-controls canónico = patrón del libro (A-/A/A+ · ☀/☾,
 * data-reader-size/data-reader-mode en <html>, cableado por libro-reader.js).
 */
import '@/styles/global.css';
import SchemaJsonLd from '@/components/SchemaJsonLd.astro';
import { SITE } from '@/lib/seo';

interface Props {
  /** Título del <head>. */
  title: string;
  /** Descripción meta. */
  description?: string;
  /** Canonical absoluto · default: SITE + pathname. */
  canonical?: string;
  /** Contenido de <meta robots>. Default: indexable. */
  robots?: string;
  /** Emitir alternates hreflang (es-CO / es / x-default). */
  hreflang?: boolean;
  /** Open Graph. `image` presente ⇒ se emiten también las Twitter cards. */
  og?: {
    type?: string;
    siteName: string;
    locale: string;
    image?: string;
    imageAlt?: string;
  };
  /** Bloques JSON-LD · cada uno se renderiza vía <SchemaJsonLd>. */
  schemas?: Record<string, unknown>[];
  /** Nivel de acceso (gating) · propagado a body[data-nivel]. */
  nivel?: 0 | 1 | 2;
  /** id de página · body[data-page]. */
  pageId?: string;
  /** Clase del <body> (ej. 'capitulo-body' / 'obertura-body'). */
  bodyClass?: string;
  /** Clase del <main> de lectura (ej. 'cap-main' / 'obertura-main'). */
  mainClass?: string;
  /** Breadcrumb central del header (slot center). Omitir para usar header-center. */
  breadcrumb?: { ornament?: string; text?: string };
  /**
   * Contexto de rastreo de lectura first-party. Presente solo en páginas de
   * sección real (no en índices/portadas). Emite data-track-* en <body> y
   * carga /reading-tracker.js. `chapter` es la unidad ('obertura' | 'cap-N-...').
   */
  track?: { surface: 'obertura' | 'capitulo'; chapter: string; section: string };
}

const {
  title,
  description,
  canonical,
  robots = 'index,follow,max-image-preview:large,max-snippet:-1',
  hreflang = false,
  og = { type: 'article', siteName: 'Tejidos de Vibración', locale: 'es_ES' },
  schemas = [],
  nivel = 1,
  pageId,
  bodyClass,
  mainClass = 'book-main',
  breadcrumb,
  track,
} = Astro.props;

const canonicalUrl = canonical ?? new URL(Astro.url.pathname, SITE).toString();
const ogType = og.type ?? 'article';
const hasImage = Boolean(og.image);
const hasBreadcrumb = Boolean(breadcrumb?.text);
---

<!doctype html>
<html lang="es">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title}</title>
  {description && <meta name="description" content={description} />}

  <meta name="robots" content={robots} />
  <link rel="canonical" href={canonicalUrl} />

  {hreflang && (
    <>
      <link rel="alternate" hreflang="es-CO" href={canonicalUrl} />
      <link rel="alternate" hreflang="es" href={canonicalUrl} />
      <link rel="alternate" hreflang="x-default" href={canonicalUrl} />
    </>
  )}

  <!-- Open Graph -->
  <meta property="og:type" content={ogType} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:title" content={title} />
  {description && <meta property="og:description" content={description} />}
  <meta property="og:locale" content={og.locale} />
  <meta property="og:site_name" content={og.siteName} />
  {hasImage && (
    <>
      <meta property="og:image" content={og.image} />
      <meta property="og:image:width" content="1200" />
      <meta property="og:image:height" content="630" />
      {og.imageAlt && <meta property="og:image:alt" content={og.imageAlt} />}
    </>
  )}

  {/* Twitter · solo cuando hay imagen social */}
  {hasImage && (
    <>
      <meta name="twitter:card" content="summary_large_image" />
      <meta name="twitter:title" content={title} />
      {description && <meta name="twitter:description" content={description} />}
      <meta name="twitter:image" content={og.image} />
    </>
  )}

  <!-- Preload fonts (subset hints) · self-hosted @fontsource -->
  <link rel="preload" as="font" type="font/woff2"
    href="/fonts/eb-garamond-latin-400-normal.woff2" crossorigin="anonymous" />
  <link rel="preload" as="font" type="font/woff2"
    href="/fonts/inter-latin-400-normal.woff2" crossorigin="anonymous" />

  <!-- JSON-LD · SSR -->
  {schemas.map((s) => <SchemaJsonLd schema={s} />)}

  <!-- Reader prefs aplicadas antes del primer paint (evita FOUC) -->
  <script is:inline>
    (function () {
      try {
        var s = localStorage.getItem('tdv-reader-size') || 'default';
        var m = localStorage.getItem('tdv-reader-mode') || 'day';
        document.documentElement.setAttribute('data-reader-size', s);
        document.documentElement.setAttribute('data-reader-mode', m);
      } catch (e) {}
    })();
  </script>

  <!-- Scroll al top en CADA carga · cada pieza empieza desde el inicio.
       INLINE en <head> (no deferred): corre en toda carga, sin depender de
       book-chrome.js. Cubre: 1) scrollRestoration='manual' desactiva la
       restauración automática del navegador; 2) 'pageshow' fuerza top en
       carga normal Y en restauración desde bfcache (back/forward), donde
       los scripts defer NO se re-ejecutan. Maneja Capítulos y Obertura. -->
  <script is:inline>
    (function () {
      if ('scrollRestoration' in history) {
        try { history.scrollRestoration = 'manual'; } catch (e) {}
      }
      var toTop = function () { window.scrollTo(0, 0); };
      // Antes del primer paint (si ya hay layout) + tras cargar + bfcache.
      toTop();
      window.addEventListener('pageshow', toTop);
      window.addEventListener('DOMContentLoaded', toTop);
    })();
  </script>

  <slot name="head" />
</head>
<body
  class={bodyClass}
  data-page={pageId}
  data-nivel={nivel}
  data-track-surface={track?.surface}
  data-track-chapter={track?.chapter}
  data-track-section={track?.section}
>
  <a href="#main-content" class="skip-link">Saltar al contenido</a>

  <!-- Reading progress bar · top del viewport -->
  <div class="book-progress" id="book-progress" aria-hidden="true"></div>
  <!-- Thread strip lateral · hilo del Tejedor en oro -->
  <div class="book-thread" aria-hidden="true"></div>

  <!-- ── Header chrome · TOC · breadcrumb/back · LECTURA ─────────────── -->
  <header class="book-chrome" id="book-chrome">
    <div class="book-chrome__slot book-chrome__slot--left">
      <slot name="toc" />
    </div>

    <div class="book-chrome__slot book-chrome__slot--center">
      <slot name="header-center">
        {hasBreadcrumb && (
          <span class="book-breadcrumb">
            {breadcrumb?.ornament && <span class="book-breadcrumb__orn" aria-hidden="true">{breadcrumb.ornament}</span>}
            <span class="book-breadcrumb__text">{breadcrumb?.text}</span>
          </span>
        )}
      </slot>
    </div>

    <div class="book-chrome__slot book-chrome__slot--right">
      <button id="reader-controls-trigger" class="book-chrome__btn" aria-label="Controles de lectura" aria-expanded="false">
        <span class="book-chrome__btn-icon" aria-hidden="true">⊕</span>
        <span class="book-chrome__btn-label">Lectura</span>
      </button>
    </div>
  </header>

  <!-- Reader panel · #reader-controls cableado por /libro-reader.js -->
  <aside id="reader-controls" class="reader-controls book-reader" hidden>
    <p class="reader-controls__title">Lectura</p>
    <div class="reader-controls__group">
      <span class="reader-controls__label">Tamaño</span>
      <button data-action="text-smaller" aria-label="Texto más pequeño">A-</button>
      <button data-action="text-default" aria-label="Texto tamaño normal">A</button>
      <button data-action="text-larger" aria-label="Texto más grande">A+</button>
    </div>
    <div class="reader-controls__group">
      <span class="reader-controls__label">Modo</span>
      <button data-action="mode-day" aria-label="Modo día">☀</button>
      <button data-action="mode-night" aria-label="Modo noche">☾</button>
    </div>
  </aside>

  <main id="main-content" class={mainClass} tabindex="-1">
    <slot />
  </main>

  <script src="/libro-reader.js" defer></script>
  <script src="/book-chrome.js" defer></script>
  {track && <script src="/reading-tracker.js" defer></script>}

  <style is:global>
    /* ── Paper grain · radial gradients sutiles en oro/índigo ─────── */
    body::before {
      content: "";
      position: fixed;
      inset: 0;
      pointer-events: none;
      background:
        radial-gradient(ellipse at 18% 8%, rgba(212, 160, 23, 0.025) 0%, transparent 55%),
        radial-gradient(ellipse at 82% 82%, rgba(45, 27, 105, 0.018) 0%, transparent 55%);
      z-index: 0;
    }

    /* ── Reading progress bar ─────────────────────────────────────── */
    .book-progress {
      position: fixed;
      top: 0; left: 0;
      height: 2px;
      width: 100%;
      background: var(--oro-suave);
      z-index: 100;
      transform: scaleX(0);
      transform-origin: left center;
      transition: transform 0.1s ease-out;
    }

    /* ── Thread strip lateral · hilo en oro ───────────────────────── */
    .book-thread {
      position: fixed;
      left: 0; top: 0; bottom: 0;
      width: 3px;
      background: linear-gradient(180deg,
        transparent 0%,
        rgba(182, 137, 20, 0.12) 10%,
        rgba(182, 137, 20, 0.22) 50%,
        rgba(182, 137, 20, 0.12) 90%,
        transparent 100%);
      pointer-events: none;
      z-index: 1;
    }

    /* ── Header chrome ────────────────────────────────────────────── */
    .book-chrome {
      position: sticky;
      top: 0;
      z-index: 80;
      display: grid;
      grid-template-columns: 1fr auto 1fr;
      align-items: center;
      gap: 1rem;
      padding: 0.85rem 1.4rem;
      background: linear-gradient(180deg, var(--pergamino) 0%, var(--pergamino) 72%, transparent 100%);
      backdrop-filter: blur(3px);
      transition: box-shadow 0.2s ease, border-color 0.2s ease;
      border-bottom: 1px solid transparent;
    }
    .book-chrome.is-scrolled {
      border-bottom-color: var(--pergamino-2);
      box-shadow: 0 2px 14px rgba(26, 22, 18, 0.05);
    }
    .book-chrome__slot { display: flex; align-items: center; min-width: 0; }
    .book-chrome__slot--left { justify-content: flex-start; }
    .book-chrome__slot--center { justify-content: center; }
    .book-chrome__slot--right { justify-content: flex-end; }

    /* Pills TOC / LECTURA */
    .book-chrome__btn {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      padding: 0.5rem 0.95rem;
      background: rgba(242, 234, 213, 0.6);
      border: 1px solid var(--oro-fantasma);
      border-radius: 3px;
      color: var(--tinta);
      font-family: var(--cornisa, var(--sans));
      font-size: 0.7rem;
      letter-spacing: 0.22em;
      text-transform: uppercase;
      cursor: pointer;
      transition: border-color 0.2s, background 0.2s;
    }
    .book-chrome__btn:hover {
      border-color: var(--oro-suave);
      background: var(--pergamino);
    }
    .book-chrome__btn-icon { color: var(--oro-suave); font-size: 0.9rem; line-height: 1; }

    /* Breadcrumb central · ornamento dinámico + texto */
    .book-breadcrumb {
      display: inline-flex;
      align-items: baseline;
      gap: 0.55rem;
      font-family: var(--cornisa, var(--sans));
      font-size: 0.7rem;
      letter-spacing: 0.26em;
      text-transform: uppercase;
      color: var(--reposo);
      white-space: nowrap;
      overflow: hidden;
      text-overflow: ellipsis;
      max-width: 100%;
    }
    .book-breadcrumb__orn { color: var(--oro-suave); letter-spacing: 0; }

    /* ── Reader panel · dropdown desde la pill LECTURA ───────────── */
    .book-reader.reader-controls {
      position: fixed;
      top: 3.6rem;
      right: 1.4rem;
      bottom: auto;
      left: auto;
      z-index: 91;
    }

    /* ── Móvil ───────────────────────────────────────────────────── */
    @media (max-width: 640px) {
      .book-chrome { padding: 0.7rem 1rem; gap: 0.5rem; }
      .book-chrome__btn-label { display: none; }
      .book-breadcrumb { font-size: 0.62rem; letter-spacing: 0.18em; }
      .book-reader.reader-controls { right: 1rem; top: 3.4rem; }
    }

    /* ── Reduced motion ──────────────────────────────────────────── */
    @media (prefers-reduced-motion: reduce) {
      .book-progress { transition: none; }
    }
  </style>

  <script is:inline>
    /* Reading progress · scaleX según scroll. */
    (function () {
      var bar = document.getElementById('book-progress');
      if (!bar) return;
      var update = function () {
        var h = document.documentElement;
        var max = h.scrollHeight - h.clientHeight;
        var ratio = max > 0 ? h.scrollTop / max : 0;
        bar.style.transform = 'scaleX(' + ratio + ')';
      };
      document.addEventListener('scroll', update, { passive: true });
      update();
    })();
  </script>
</body>
</html>
