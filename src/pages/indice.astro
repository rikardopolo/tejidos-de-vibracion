---
/**
 * /indice · Tabla de contenidos del Volumen I
 * Mirrors handoff indice.html design.
 * Caps. I–III se cargan desde la colección `book`;
 * Caps. IV–X están hardcoded (en gestación, sin MDX aún).
 */
import { getCollection } from 'astro:content';
import LecturaLarga from '@/layouts/LecturaLarga.astro';
import TocEntry from '@/components/book/TocEntry.astro';
import LitLink from '@/components/book/LitLink.astro';

// Slug → href map for published chapters
const SLUG_MAP: Record<number, string> = {
  1: '/capitulo/cap-1-universo-sinfonia',
  2: '/capitulo/cap-2-ciencia-escuchar',
  3: '/capitulo/cap-3-mundo-cuantico',
};

// Acto I · mes de apertura por capítulo (metadato editorial). El ESTADO
// (soon vs abierto) NO vive aquí: se deriva del frontmatter `status` de cada
// MDX más abajo, la misma fuente única que gobierna el gating y el sitemap.
const ACTO_I = [
  { n: 1, roman: 'I', mes: 'agosto' },
  { n: 2, roman: 'II', mes: 'septiembre' },
  { n: 3, roman: 'III', mes: 'octubre' },
];

// Load chapters visibles en el índice · 'published' renderiza contenido,
// 'fragmento-permanente' renderiza BloquePuerta 'espera' (mismo runtime
// behavior que un cap N1 no publicado · ver capitulo/[slug].astro).
const allChapters = await getCollection('book', ({ data }) =>
  data.kind === 'capitulo' &&
  (data.status === 'published' || data.status === 'fragmento-permanente')
);
const publishedByNumber = new Map(
  allChapters.map((e) => [e.data.chapter as number, e.data])
);

// Gestating chapters (no MDX yet — hardcoded per spec)
const gestatingChapters = [
  { num: 4, roman: 'IV', title: 'La biología del campo coherente', subtitle: 'Corazón, células y los ritmos que el cuerpo comparte con el mundo' },
  { num: 5, roman: 'V',  title: 'Neurociencia de la frecuencia',  subtitle: 'Ondas cerebrales, atención y el cerebro como instrumento' },
  { num: 6, roman: 'VI', title: 'Estados expandidos de consciencia', subtitle: 'Lo que ocurre cuando la red por defecto se silencia' },
  { num: 7, roman: 'VII',  title: 'El problema del observador',   subtitle: 'Por qué la consciencia no se deja medir desde afuera' },
  { num: 8, roman: 'VIII', title: 'El campo relacional',          subtitle: 'Lo que ocurre entre dos consciencias atentas' },
  { num: 9, roman: 'IX',   title: 'Filosofía de la ciencia vibracional', subtitle: 'Los límites del lenguaje científico ante la experiencia' },
  { num: 10, roman: 'X',  title: 'El tejedor consciente',         subtitle: 'Vivir como si la mirada importara, porque importa' },
];
---

<LecturaLarga
  robots="index,follow"
  title="Índice · Volumen I · Tejidos de Vibración"
  description="Índice del Volumen I de Tejidos de Vibración. Tres actos, diez capítulos sobre la física vibracional, la biología del campo coherente y la consciencia."
  pageId="indice"
>
  <article class="measure pt-5">
    <header>
      <h1 class="title-1">Índice</h1>
      <p class="meta">Volumen I · Tejidos de Vibración</p>
    </header>

    <p style="font-family: var(--serif); font-style: italic; font-size: 1.0625rem; line-height: 1.6; color: var(--tinta-suave); max-width: 36rem; margin: 1.5rem 0 0;">Disponible hoy: la Obertura completa. En camino: los capítulos del Acto I, uno a uno. Tu correo es la entrada a todo.</p>

    <!-- Obertura -->
    <TocEntry
      num="—"
      title="Obertura"
      subtitle="El tejedor consciente despierta"
      href="/obertura"
    />

    <!-- Acto I · Fundamentos -->
    <section class="toc-act">
      <p class="toc-act__cue">Acto I</p>
      <h2 class="toc-act__title">
        Fundamentos<span class="toc-act__title-tail">La vibración primordial</span>
      </h2>

      {/*
        Estados del Acto I DERIVADOS del frontmatter `status` de cada MDX
        (fuente única de verdad · la misma que gobierna el gating runtime y el
        sitemap):
        - status 'fragmento-permanente' → soon=true · badge "Libre · abre en {mes}"
        - status 'published'            → soon=false · badge "Libre · requiere registro" · link activo
        Los caps IV-X siguen `gestating` (Acto II/III · pagos).

        Para ABRIR un capítulo del Acto I: cambiar SOLO su MDX a status:
        "published" (un edit) → /indice, el gating y el sitemap se actualizan
        juntos. Los meses viven en ACTO_I (frontmatter, arriba).
      */}
      {ACTO_I.map(({ n, roman, mes }) => {
        const data = publishedByNumber.get(n);
        if (!data) return <TocEntry num={roman} title={`Capítulo ${roman}`} subtitle="" gestating />;
        const soon = data.status !== 'published';
        const access = soon ? `Libre · abre en ${mes}` : 'Libre · requiere registro';
        return (
          <TocEntry
            num={roman}
            title={data.title}
            subtitle={data.subtitle ?? ''}
            href={SLUG_MAP[n]}
            access={access}
            soon={soon}
          />
        );
      })}
    </section>

    <!-- Acto II · Cuerpo -->
    <section class="toc-act">
      <p class="toc-act__cue">Acto II</p>
      <h2 class="toc-act__title">
        Cuerpo<span class="toc-act__title-tail">La biología que escucha</span>
      </h2>

      {gestatingChapters.filter((c) => c.num >= 4 && c.num <= 6).map((c) => (
        <TocEntry
          num={c.roman}
          title={c.title}
          subtitle={c.subtitle}
          gestating
        />
      ))}
    </section>

    <!-- Acto III · Tejedor -->
    <section class="toc-act">
      <p class="toc-act__cue">Acto III</p>
      <h2 class="toc-act__title">
        Tejedor<span class="toc-act__title-tail">La mirada que teje</span>
      </h2>

      {gestatingChapters.filter((c) => c.num >= 7).map((c) => (
        <TocEntry
          num={c.roman}
          title={c.title}
          subtitle={c.subtitle}
          gestating
        />
      ))}
    </section>

    {/* CTA de pre-venta DESPUBLICADO hasta Live Mode (25-jun-2026): el botón de
        compra de /comprar/preventa aún no cobra (envs Lemon Squeezy live pendientes),
        así que no se enlaza en público. La página sigue existiendo. Para reactivar,
        restaurar la <section class="toc-preventa"> con el <a href="/comprar/preventa">
        desde el commit c58d8f5 (squash del checkout). */}

    <!-- Aparato del libro -->
    <section class="mt-7">
      <p class="eyebrow">Aparato del libro</p>
      <ul style="list-style: none; padding: 0; margin: 1.5rem 0 0 0; font-family: var(--serif); font-size: 1.0625rem; line-height: 2;">
        <li>
          <a href="https://tejidosderealidad.com/pensadores" class="lit-link-secondary" style="color: var(--tinta);">
            Anexo C · La Constelación de Pensadores
          </a>
          <span class="meta"> — vive en el portal hermano</span>
        </li>
        <li>
          <a href="https://tejidosderealidad.com/simuladores" class="lit-link-secondary" style="color: var(--tinta);">
            Anexo D · El Laboratorio de Simuladores
          </a>
          <span class="meta"> — vive en el portal hermano</span>
        </li>
        <li>
          <a href="/colofon" class="lit-link-secondary" style="color: var(--tinta);">
            Colofón · Linaje, herramientas y agradecimientos
          </a>
        </li>
      </ul>
    </section>

    <!-- CTA final -->
    <p class="center mt-6 mb-6">
      <LitLink href="/obertura">Empezar por la Obertura</LitLink>
    </p>

  </article>
</LecturaLarga>
