---
/**
 * /obertura/[slug] · ruta dinámica para piezas individuales de la Obertura.
 *
 * Migrada desde el portal `tejidos-de-realidad` el 2026-05-18.
 *
 * Renderiza un capítulo o interludio de la Obertura con:
 *   - Header sticky con número del capítulo
 *   - Reading progress bar
 *   - Layout paper-and-ink dedicado
 *   - Navegación prev/next al final
 *   - Auth gate por cookie HMAC `tejedor-access` (sistema del libro)
 *
 * Slugs válidos · derivados del nombre del archivo en `content/obertura/`:
 *   00-frontispicio · 01-anclaje · interludio-i · 02-meta-observador · ...
 *   ... · interludio-iii · 10-sintesis · 11-cierre
 */
import OberturaLayout from '@/layouts/OberturaLayout.astro';
import BloquePuerta from '@/components/book/BloquePuerta.astro';
import FormularioTejedor from '@/components/book/FormularioTejedor.astro';
import { getCollection, getEntry, render } from 'astro:content';
import { getAcceso, puedeAcceder, gatingActivo, type Nivel } from '@/lib/gating';
import { SITE, breadcrumb, wrapGraph } from '@/lib/seo';

export const prerender = false;

/**
 * Piezas de acceso público · Nivel 0 (sin cookie).
 * Las demás piezas (12 de 15) requieren Nivel 1 · cookie `tejedor-access`.
 * Decisión documentada en PROMPT-MIGRACION-OBERTURA-2026-05-18.md FASE 4.
 */
const PIEZAS_PUBLICAS = new Set([
  '00-frontispicio',
  '01-anclaje',
  'interludio-i',
]);

// Bot allowlist · search engines + LLM crawlers + social unfurlers + validators.
// Bypass del gating · sirve contenido completo para indexación y previews.
const ua = Astro.request.headers.get('user-agent') ?? '';
const isBot = /bot|crawl|spider|googlebot|bingbot|gptbot|claudebot|perplexitybot|google-extended|oai-searchbot|anthropic-ai|cohere-ai|yandex|baiduspider|duckduckbot|applebot|facebookexternalhit|twitterbot|linkedinbot|whatsapp|telegrambot|slackbot|discord|mojeekbot|opengraph|preview|unfurl|metainspector|embed/i.test(ua);

const { slug } = Astro.params;
if (!slug) {
  return Astro.redirect('/obertura');
}

const entry = await getEntry('obertura', slug);
if (!entry) {
  return new Response('Capítulo no encontrado', { status: 404 });
}

// Resolver nivel y derivar acceso a la pieza.
// nivelRequerido es data-driven: 0 para piezas públicas, 1 para el resto de
// la Obertura (Acto I). La comparación pasa por puedeAcceder, que también
// exigiría scope de producto si alguna pieza declarara uno (hoy ninguna).
const esPublica = PIEZAS_PUBLICAS.has(slug);
const nivelRequerido: Nivel = esPublica ? 0 : 1;
// Bots ven todo · gatingActivo() permite override por env · si no, default Nivel 1
const acceso = isBot ? { nivel: 1 as Nivel, slugs: [] } : (gatingActivo() ? getAcceso(Astro.cookies) : { nivel: 1 as Nivel, slugs: [] });
const nivel = acceso.nivel;
const tieneAcceso = puedeAcceder(acceso, nivelRequerido);

// Solo renderizar contenido si tiene acceso · piezas Nivel 1 muestran
// header + BloquePuerta cuando el lector está en Nivel 0 (patrón cap-2/3).
let Content: any = null;
if (tieneAcceso) {
  const rendered = await render(entry);
  Content = rendered.Content;
}

const { title, subtitle, headerLabel, chapterNum, kind, publishedAt, authors } = entry.data;

// Resolver prev/next desde la colección completa
const all = await getCollection('obertura', ({ data }) => data.status === 'published');
all.sort((a, b) => a.data.order - b.data.order);
const idx = all.findIndex((e) => e.id === slug);
const prev = idx > 0 ? all[idx - 1] : null;
const next = idx < all.length - 1 ? all[idx + 1] : null;

// ───────────────────────────────────────────────────────────
// Schema.org · Article + BreadcrumbList por pieza
// ───────────────────────────────────────────────────────────
const canonicalPath = `/obertura/${slug}`;
const description = subtitle ?? `Capítulo ${chapterNum} de la Obertura del Volumen I`;
const datePublishedIso = (publishedAt instanceof Date ? publishedAt : new Date('2026-01-01'))
  .toISOString();

// kind=interludio → Article (más etéreo, breve, no técnico)
// kind=capitulo/frontispicio → Article + Chapter (parte del libro)
const articleType = kind === 'interludio' ? 'Article' : ['Article', 'Chapter'];

const pieceSchema = wrapGraph([
  {
    '@type': articleType,
    '@id': `${SITE}${canonicalPath}#article`,
    headline: title,
    ...(subtitle ? { alternativeHeadline: subtitle } : {}),
    description,
    url: `${SITE}${canonicalPath}`,
    image: 'https://tejidosdevibracion.com/og/og-obertura.jpg',
    datePublished: datePublishedIso,
    dateModified: datePublishedIso,
    inLanguage: 'es',
    author: authors.map((name) =>
      name === 'Ricardo Polo'
        ? { '@id': `${SITE}/sobre-el-libro#person` }
        : { '@type': 'Person', name },
    ),
    publisher: { '@id': `${SITE}/#organization` },
    isPartOf: { '@id': `${SITE}/obertura#article` },
    // Paywall structured data (Google) · las piezas cerradas sirven el texto
    // completo a los bots (allowlist arriba) pero el humano ve el muro; marcar
    // isAccessibleForFree:false + hasPart legitima ese bypass (evita cloaking).
    isAccessibleForFree: esPublica,
    ...(esPublica
      ? {}
      : {
          hasPart: {
            '@type': 'WebPageElement',
            isAccessibleForFree: false,
            cssSelector: '.obertura-piece',
          },
        }),
    mainEntityOfPage: `${SITE}${canonicalPath}`,
    position: idx + 1,
  },
  breadcrumb(
    [
      { name: 'Inicio', href: '/' },
      { name: 'Índice', href: '/indice' },
      { name: 'Obertura', href: '/obertura' },
      { name: title, href: canonicalPath },
    ],
    `${canonicalPath}#breadcrumb`,
  ),
]);
---

<OberturaLayout
  title={`${title} · Tejidos de Vibración`}
  description={description}
  headerLabel={headerLabel}
  currentSlug={slug}
  schemas={[pieceSchema]}
  nivel={nivel}
>
  <article class={`obertura-piece kind-${kind}`}>
    {tieneAcceso && Content ? (
      <>
        {kind !== 'frontispicio' && (
          <header class="piece-header">
            <h1 class="piece-title">{title}</h1>
            {subtitle && <p class="piece-subtitle">{subtitle}</p>}
          </header>
        )}
        <Content />
      </>
    ) : (
      <header class="piece-locked-header">
        <p class="locked-eyebrow">{headerLabel}</p>
        <h1 class="locked-title">{title}</h1>
        {subtitle && <p class="locked-subtitle">{subtitle}</p>}
      </header>
    )}
  </article>

  {/* Captura · lector ANÓNIMO (nivel 0) leyendo una pieza PÚBLICA (los bots
      tienen nivel 1 → excluidos; las piezas cerradas ya muestran BloquePuerta). */}
  {tieneAcceso && nivel === 0 && (
    <aside class="pieza-captura">
      <p class="pieza-captura__eyebrow">Cruza el umbral</p>
      <p class="pieza-captura__linea">La Obertura completa —las quince piezas— es libre para los tejedores registrados. Un nombre y un correo. Eso es todo.</p>
      <FormularioTejedor id="form-obertura-pieza" variant="inline" />
    </aside>
  )}

  {!tieneAcceso && (
    <BloquePuerta tipo="obertura-pieza" />
  )}

  {!tieneAcceso && (
    <p class="lectura-libre-hint">
      Mientras tanto, de lectura libre — sin registro:
      <a href="/obertura/00-frontispicio">Frontispicio</a>
      <span aria-hidden="true"> · </span>
      <a href="/obertura/01-anclaje">Anclaje Experiencial</a>
    </p>
  )}

  {tieneAcceso && (
    <nav class="prev-next" aria-label="Navegación entre capítulos">
      <div class="pn-cell pn-cell--prev">
        {prev ? (
          <a href={`/obertura/${prev.id}`}>
            <span class="pn-cue">← Anterior · {prev.data.chapterNum}</span>
            <span class="pn-title">{prev.data.title}</span>
          </a>
        ) : (
          <a href="/obertura"><span class="pn-cue">← Biblioteca</span></a>
        )}
      </div>

      <div class="pn-cell pn-cell--center">
        <span class="pn-cue">Obertura</span>
      </div>

      <div class="pn-cell pn-cell--next">
        {next ? (
          <a href={`/obertura/${next.id}`}>
            <span class="pn-cue">Siguiente · {next.data.chapterNum} →</span>
            <span class="pn-title">{next.data.title}</span>
          </a>
        ) : (
          <a href="/obertura"><span class="pn-cue">Biblioteca →</span></a>
        )}
      </div>
    </nav>
  )}
</OberturaLayout>

<style>
  /* Nav inferior · 3 columnas sin cajas, baseline (rediseño Umbral) */
  .prev-next {
    margin-top: 5rem;
    padding-top: 1.6rem;
    border-top: 1px solid var(--obertura-rule);
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: baseline;
    gap: 1.5rem;
  }
  .pn-cell--prev { text-align: left; }
  .pn-cell--center { text-align: center; }
  .pn-cell--next { text-align: right; }
  .pn-cell a { text-decoration: none; display: block; }
  .pn-cue {
    display: block;
    font-family: var(--obertura-sans);
    font-size: 0.66rem;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--reposo);
  }
  .pn-cell a:hover .pn-cue { color: var(--oro-texto); }
  .pn-title, .pn-mid {
    display: block;
    font-family: var(--obertura-serif);
    font-style: italic;
    font-size: 1.0625rem;
    color: var(--obertura-ink);
    margin-top: 0.375rem;
    line-height: 1.2;
  }
  .pn-cell a:hover .pn-title { color: var(--obertura-thread-deep); }

  @media (max-width: 640px) {
    .prev-next { grid-template-columns: 1fr; gap: 1.25rem; }
    .pn-cell--prev, .pn-cell--next { text-align: center; }
  }

  /* Header de pieza bloqueada · Nivel 0 viendo pieza Nivel 1 */
  .piece-locked-header {
    text-align: center;
    margin: 2rem 0 0;
    padding: 0 0 1rem;
  }
  .locked-eyebrow {
    font-family: var(--obertura-sans);
    font-size: 0.72rem;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--obertura-thread);
    margin: 0 0 1.2rem;
  }
  .locked-title {
    font-family: var(--obertura-serif);
    font-weight: 500;
    font-size: clamp(1.7rem, 3.5vw, 2.4rem);
    line-height: 1.2;
    color: var(--obertura-ink);
    margin: 0 0 0.5rem;
    text-wrap: balance;
  }
  .locked-subtitle {
    font-family: var(--obertura-serif);
    font-style: italic;
    font-size: 1.15rem;
    color: var(--obertura-ink-faded);
    margin: 0;
    text-wrap: balance;
  }
  /* Pista «de lectura libre» bajo la puerta · da a los anónimos un camino a las
     piezas gratuitas (00/01) sin registro. */
  .lectura-libre-hint {
    text-align: center;
    font-family: var(--obertura-sans);
    font-size: 0.8rem;
    letter-spacing: 0.04em;
    color: var(--reposo);
    margin: 2.5rem auto 0;
    max-width: 34rem;
  }
  .lectura-libre-hint a {
    color: var(--oro-texto);
    text-decoration: none;
    border-bottom: 1px solid color-mix(in srgb, var(--oro-texto) 40%, transparent);
    white-space: nowrap;
  }
  .lectura-libre-hint a:hover { color: var(--oro-suave); border-bottom-color: var(--oro-suave); }

  /* Captura bajo una pieza pública · lector anónimo (nivel 0) */
  .pieza-captura {
    margin: 4rem auto 0;
    max-width: 32rem;
    padding-top: 2rem;
    border-top: 1px solid var(--obertura-rule);
    text-align: center;
  }
  .pieza-captura__eyebrow {
    font-family: var(--obertura-sans);
    font-size: 0.72rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--obertura-thread);
    margin: 0 0 0.75rem;
  }
  .pieza-captura__linea {
    font-family: var(--obertura-serif);
    font-style: italic;
    font-size: 1.05rem;
    line-height: 1.5;
    color: var(--obertura-ink-faded);
    margin: 0 0 1.5rem;
    text-wrap: pretty;
  }
</style>
