---
/**
 * TocEntry · entrada del índice del libro.
 *
 * Tres estados visuales mutuamente excluyentes (con precedencia):
 *   1. published (default) · enlace activo con número y título · semántica: "escrito y disponible"
 *   2. soon                · `<span>` no clickeable · opacity 0.5 · badge access nítido
 *                            semántica: "escrito, aún no disponible · libre con registro"
 *   3. gestating           · `<span>` no clickeable · opacity 0.5 · sin badge
 *                            semántica: "no escrito / en gestación"
 *
 * Precedencia: si se pasan `soon` y `gestating` simultáneamente, `soon` gana
 * (es el estado más informativo · indica que la pieza existe pero abre después).
 *
 * Prop `access` opcional · renderiza badge `<span class="toc-entry__access">`
 * con el copy de nivel de acceso (ej. "Libre · requiere registro",
 * "Libre · abre en julio"). El badge mantiene legibilidad sobre contenedores
 * opacos (estados soon/gestating · ver system.css).
 */

interface Props {
  num: string;
  title: string;
  subtitle: string;
  href?: string;
  gestating?: boolean;
  /** Pieza escrita pero aún no disponible · libre con registro al abrir. */
  soon?: boolean;
  /** Badge editorial de nivel de acceso · texto literal mostrado bajo el subtitle. */
  access?: string;
}

const { num, title, subtitle, href, gestating = false, soon = false, access } = Astro.props;

// Precedencia: soon > gestating > published
const isSoon = soon;
const isGestating = !isSoon && gestating;
const isActive = !isSoon && !isGestating && !!href;

// `any` evita el falso positivo de TS con tags polimórficos (a/span) + spread
// de atributos condicionales · solo afecta tipos, el valor runtime es correcto.
const Tag: any = isActive ? 'a' : 'span';
const modifierClass = isSoon
  ? ' toc-entry--soon'
  : isGestating
    ? ' toc-entry--gestating'
    : '';
const extraAttrs = (isSoon || isGestating) ? { 'aria-disabled': 'true' } : {};
const hrefAttr = isActive ? { href } : {};
---

<Tag
  class={`toc-entry${modifierClass}`}
  {...hrefAttr}
  {...extraAttrs}
>
  <span class="toc-entry__num">{num}</span>
  <span class="toc-entry__body">
    <span class="toc-entry__title">{title}</span>
    <span class="toc-entry__sub">{subtitle}</span>
    {access && <span class="toc-entry__access">{access}</span>}
  </span>
</Tag>
