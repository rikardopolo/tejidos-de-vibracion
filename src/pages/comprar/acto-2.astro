---
// src/pages/comprar/acto-2.astro
// Pre-venta · Acto II — El Observador en el Campo (caps V-VII).
// Landing de captura de interés. Checkout real (Lemon Squeezy) → Sep 2026.
// Mientras tanto: el form postea a /api/preventa → Brevo (atributo
// FUENTE=preventa-acto-2). Layout LecturaLarga = nav + footer del sitio.
import LecturaLarga from '@/layouts/LecturaLarga.astro';

const SEO = {
  title: 'Acto II · Pre-venta — Tejidos de Vibración',
  description:
    'Tres capítulos sobre neurociencia de la conciencia, estados expandidos y el problema del observador. Disponible en septiembre 2026 · $26 USD.',
};
---

<LecturaLarga title={SEO.title} description={SEO.description} pageId="comprar-acto-2">
  <article class="preventa measure pt-5">

    <!-- ── HERO ─────────────────────────────────────────────── -->
    <header class="pv-hero">
      <p class="eyebrow">Tejidos de Vibración · Volumen I</p>
      <h1 class="pv-titulo">
        Acto II<span class="pv-titulo-sub">El Observador en el Campo</span>
      </h1>
      <p class="pv-bajada">
        Tres capítulos sobre la neurociencia de la conciencia, los estados
        expandidos y la pregunta que cambia todo: ¿qué significa realmente
        observar?
      </p>
      <p class="pv-precio-bloque">
        <span class="pv-precio">$26 USD</span>
        <span class="pv-precio-nota">· tres capítulos · formato digital</span>
      </p>
      <p class="pv-disponibilidad">
        Disponible en septiembre&nbsp;2026 · registra tu interés ahora y
        recibirás aviso el día que abra.
      </p>
    </header>

    <div class="flourish flourish--rule"></div>

    <!-- ── CAPÍTULOS ─────────────────────────────────────────── -->
    <section class="pv-capitulos" aria-label="Qué encontrarás">
      <p class="eyebrow">Qué encontrarás</p>

      <article class="pv-card">
        <span class="pv-cap-num">Cap. V</span>
        <h2 class="pv-cap-titulo">Neurociencia de la Frecuencia</h2>
        <p class="pv-cap-sub">El cerebro como instrumento vibracional</p>
        <p class="pv-cap-desc">
          Ondas cerebrales, arrastre de frecuencia, la Default Mode Network y
          la percepción predictiva: cómo el cerebro construye —más que
          recibe— la realidad.
        </p>
      </article>

      <article class="pv-card">
        <span class="pv-cap-num">Cap. VI</span>
        <h2 class="pv-cap-titulo">Estados Expandidos de Conciencia</h2>
        <p class="pv-cap-sub">Cartografía neurocientífica de lo extraordinario</p>
        <p class="pv-cap-desc">
          Hipnagogia, meditación profunda, estados de flujo y dilatación
          temporal: lo que la neuroimagen moderna revela sobre los bordes de
          la experiencia ordinaria.
        </p>
      </article>

      <article class="pv-card">
        <span class="pv-cap-num">Cap. VII</span>
        <h2 class="pv-cap-titulo">El Problema del Observador</h2>
        <p class="pv-cap-sub">El nudo central de la mecánica cuántica</p>
        <p class="pv-cap-desc">
          Qué significa medir, qué colapsa y qué no, y por qué la pregunta
          sobre el rol de la conciencia en la física sigue abierta —
          honestamente abierta.
        </p>
      </article>
    </section>

    <div class="flourish flourish--rule"></div>

    <!-- ── FORMULARIO DE INTERÉS ─────────────────────────────── -->
    <section class="pv-form-seccion" aria-label="Avísame cuando esté disponible">
      <p class="eyebrow">Avísame cuando esté disponible</p>
      <p class="pv-form-bajada">
        Deja tu nombre y correo. Sin compromisos: solo recibirás un mensaje
        el día que el Acto II abra.
      </p>

      <form id="preventa-form" class="pv-form" novalidate>
        <div class="pv-form-fila">
          <label for="nombre" class="pv-form-label">Nombre</label>
          <input id="nombre" name="nombre" type="text" class="pv-form-input"
            placeholder="Tu nombre" required autocomplete="given-name" />
        </div>
        <div class="pv-form-fila">
          <label for="email" class="pv-form-label">Correo electrónico</label>
          <input id="email" name="email" type="email" class="pv-form-input"
            placeholder="tu@correo.com" required autocomplete="email" />
        </div>
        <!-- honeypot anti-spam · debe quedar vacío -->
        <div class="pv-hp" aria-hidden="true">
          <label for="website">No rellenar</label>
          <input id="website" name="website" type="text" tabindex="-1" autocomplete="off" />
        </div>
        <button type="submit" class="pv-form-btn" id="preventa-btn">
          Avísame en septiembre
        </button>
        <p class="pv-form-legal">
          Tu correo no se comparte con nadie. Puedes darte de baja en
          cualquier momento.
        </p>
      </form>

      <div id="preventa-ok" class="pv-form-ok" hidden>
        <p>✓&nbsp; Listo. Te escribiremos cuando el Acto II esté disponible.</p>
      </div>
      <div id="preventa-error" class="pv-form-error" hidden>
        <p>Algo salió mal. Intenta de nuevo en un momento.</p>
      </div>
    </section>

    <!-- ── PUENTE AL ACTO I ──────────────────────────────────── -->
    <section class="pv-puente">
      <p class="pv-puente-texto">
        Mientras el Acto II llega, el Acto I está disponible de forma libre:
        la Obertura y los primeros capítulos te esperan.
      </p>
      <a href="/recibir" class="pv-puente-cta">Comenzar desde el principio →</a>
    </section>

  </article>
</LecturaLarga>

<!-- ── SCRIPT DE ENVÍO (Astro lo empaqueta a /_astro → CSP-safe) ── -->
<script>
  const form = document.getElementById('preventa-form') as HTMLFormElement | null;
  const btn  = document.getElementById('preventa-btn') as HTMLButtonElement | null;
  const ok   = document.getElementById('preventa-ok') as HTMLElement | null;
  const err  = document.getElementById('preventa-error') as HTMLElement | null;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (!btn) return;

    const nombre  = (form.elements.namedItem('nombre')  as HTMLInputElement).value.trim();
    const email   = (form.elements.namedItem('email')   as HTMLInputElement).value.trim();
    const website = (form.elements.namedItem('website') as HTMLInputElement).value;

    if (!nombre || !email) return;

    btn.disabled = true;
    btn.textContent = 'Enviando…';
    if (err) err.hidden = true;

    try {
      const res = await fetch('/api/preventa', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ nombre, email, website }),
      });

      if (res.ok) {
        form.hidden = true;
        if (ok) ok.hidden = false;
      } else {
        throw new Error('non-ok');
      }
    } catch {
      if (err) err.hidden = false;
      btn.disabled = false;
      btn.textContent = 'Avísame en septiembre';
    }
  });
</script>

<style>
  /* Tokens canónicos del sitio (tokens.css): --pergamino --tinta --oro
     --oro-suave --indigo --verde --reposo --serif --sans. Sin hex duros. */

  .preventa { padding-bottom: var(--gap-xl, 6rem); }

  /* ── HERO ─────────────────────────────────────────────────── */
  .pv-hero { text-align: center; padding: var(--gap-md, 2rem) 0 var(--gap-lg, 4rem); }

  .pv-titulo {
    font-family: var(--serif);
    font-size: clamp(2.4rem, 6vw, 3.8rem);
    font-weight: 400;
    line-height: var(--lh-tight, 1.2);
    color: var(--indigo);
    margin: 0.25rem 0 0.5rem;
  }
  .pv-titulo-sub {
    display: block;
    font-size: clamp(1.3rem, 3.5vw, 1.9rem);
    font-style: italic;
    color: var(--oro);
    margin-top: 0.3rem;
  }
  .pv-bajada {
    font-family: var(--serif);
    font-size: var(--fs-body-lg, 1.25rem);
    line-height: var(--lh-body, 1.7);
    max-width: 36rem;
    margin: 1.75rem auto 0;
  }
  .pv-precio-bloque {
    margin-top: var(--gap-md, 2rem);
    display: flex; align-items: baseline; justify-content: center; gap: 0.5rem;
  }
  .pv-precio { font-family: var(--serif); font-size: 2.2rem; font-weight: 500; color: var(--indigo); }
  .pv-precio-nota { font-family: var(--sans); font-size: 0.82rem; color: var(--reposo); }
  .pv-disponibilidad {
    font-family: var(--sans); font-size: 0.85rem; color: var(--reposo); margin-top: 0.75rem;
  }

  /* ── CAPÍTULOS ─────────────────────────────────────────────── */
  .pv-capitulos {
    padding: var(--gap-lg, 4rem) 0;
    display: flex; flex-direction: column; gap: var(--gap-md, 2rem);
  }
  .pv-card {
    padding: 1.75rem 2rem;
    border-left: 4px solid var(--oro);
    background: var(--oro-fantasma, rgba(212, 160, 23, 0.12));
  }
  .pv-cap-num {
    font-family: var(--sans); font-size: 0.72rem; letter-spacing: 0.12em;
    text-transform: uppercase; color: var(--oro-suave); display: block; margin-bottom: 0.4rem;
  }
  .pv-cap-titulo {
    font-family: var(--serif); font-size: var(--fs-h3, 1.5rem); font-weight: 500;
    color: var(--indigo); margin: 0 0 0.2rem;
  }
  .pv-cap-sub { font-family: var(--serif); font-style: italic; color: var(--reposo); margin: 0 0 0.8rem; }
  .pv-cap-desc { font-family: var(--serif); font-size: var(--fs-body, 1.1875rem); line-height: var(--lh-body, 1.7); }

  /* ── FORMULARIO ────────────────────────────────────────────── */
  .pv-form-seccion { padding: var(--gap-lg, 4rem) 0; }
  .pv-form-bajada {
    font-family: var(--serif); font-size: var(--fs-body, 1.1875rem);
    line-height: var(--lh-body, 1.7); margin: 0.5rem 0 2rem;
  }
  .pv-form { display: flex; flex-direction: column; gap: 1.25rem; max-width: 30rem; }
  .pv-form-fila { display: flex; flex-direction: column; gap: 0.4rem; }
  .pv-form-label { font-family: var(--sans); font-size: 0.8rem; color: var(--reposo); letter-spacing: 0.04em; }
  .pv-form-input {
    background: #fff;
    border: 1px solid var(--oro-fantasma, rgba(212, 160, 23, 0.4));
    padding: 0.65rem 0.85rem;
    font-family: var(--serif); font-size: var(--fs-body, 1.1875rem);
    color: var(--tinta); outline: none; transition: border-color 0.2s var(--ease-editorial, ease);
  }
  .pv-form-input:focus { border-color: var(--oro); }
  /* honeypot: fuera de pantalla, no visible ni tabulable */
  .pv-hp { position: absolute; left: -9999px; width: 1px; height: 1px; overflow: hidden; }
  .pv-form-btn {
    background: var(--indigo); color: #fff; border: none;
    padding: 0.85rem 1.75rem; font-family: var(--sans); font-size: 0.9rem;
    letter-spacing: 0.04em; cursor: pointer; align-self: flex-start;
    transition: background 0.2s var(--ease-editorial, ease);
  }
  .pv-form-btn:hover:not(:disabled) { background: var(--oro-suave); }
  .pv-form-btn:disabled { opacity: 0.6; cursor: not-allowed; }
  .pv-form-legal { font-family: var(--sans); font-size: 0.75rem; color: var(--reposo); margin-top: 0.25rem; }
  .pv-form-ok {
    padding: 1.25rem 1.5rem; border-left: 4px solid var(--verde);
    background: color-mix(in srgb, var(--verde) 10%, var(--pergamino));
    font-family: var(--serif); font-size: var(--fs-body, 1.1875rem); margin-top: 1rem;
  }
  .pv-form-error {
    padding: 1.25rem 1.5rem; border-left: 4px solid #c0392b;
    background: color-mix(in srgb, #c0392b 8%, var(--pergamino));
    font-family: var(--serif); margin-top: 1rem;
  }

  /* ── PUENTE ─────────────────────────────────────────────────── */
  .pv-puente { padding: var(--gap-lg, 4rem) 0 0; text-align: center; }
  .pv-puente-texto {
    font-family: var(--serif); font-size: var(--fs-body, 1.1875rem);
    line-height: var(--lh-body, 1.7); color: var(--reposo);
    max-width: 32rem; margin: 0 auto 1.25rem;
  }
  .pv-puente-cta {
    font-family: var(--sans); font-size: 0.9rem; color: var(--oro);
    text-decoration: underline; text-underline-offset: 3px; transition: color 0.2s;
  }
  .pv-puente-cta:hover { color: var(--oro-suave); }

  @media (max-width: 600px) {
    .pv-card { padding: 1.25rem; }
    .pv-form-btn { align-self: stretch; text-align: center; }
    .pv-precio { font-size: 1.9rem; }
  }
</style>
