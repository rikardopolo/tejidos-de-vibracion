---
/**
 * <MapaConceptual> · diagrama SVG con la síntesis de la Obertura.
 *
 * 3 capacidades centrales (Meta-Observador, Interferómetro, Universo
 * Participativo) + 5 territorios laterales + 5 voces tutelares.
 *
 * Usado en cap. 10-sintesis. SVG inline para que escale en cualquier
 * viewport sin perder calidad.
 */
---

<div class="mapa-conceptual">
  <svg viewBox="0 0 720 540" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Mapa conceptual de la Obertura">
    <defs>
      <style>
        .lbl { font-family: 'EB Garamond', serif; fill: var(--obertura-ink); font-size: 16px; }
        .lblsm { font-family: 'Inter', sans-serif; fill: #6b5f4d; font-size: 10px; letter-spacing: 0.18em; text-transform: uppercase; }
        .em { font-style: italic; fill: #8b2e2e; }
        .ind { fill: #1f2547; }
        .gold { fill: #9c7a2a; }
      </style>
    </defs>

    <g style="stroke: var(--obertura-ink); stroke-opacity: 0.06; stroke-width: 0.5;">
      <line x1="60" y1="20" x2="60" y2="520" />
      <line x1="180" y1="20" x2="180" y2="520" />
      <line x1="360" y1="20" x2="360" y2="520" />
      <line x1="540" y1="20" x2="540" y2="520" />
      <line x1="660" y1="20" x2="660" y2="520" />
    </g>

    <circle cx="360" cy="270" r="60" fill="#ebe1cb" stroke="#8b2e2e" stroke-width="1.5" />
    <circle cx="360" cy="270" r="68" fill="none" stroke="#8b2e2e" stroke-width="0.5" stroke-dasharray="2 4" />
    <text x="360" y="262" class="lbl em" text-anchor="middle" font-size="18" font-weight="600">Tejedor</text>
    <text x="360" y="284" class="lbl em" text-anchor="middle" font-size="18" font-weight="600">Consciente</text>

    <g>
      <circle cx="180" cy="180" r="46" fill="rgba(139,46,46,0.06)" stroke="#8b2e2e" stroke-width="1" />
      <text x="180" y="178" class="lbl" text-anchor="middle" font-weight="600">Meta-</text>
      <text x="180" y="196" class="lbl" text-anchor="middle" font-weight="600">Observador</text>
      <text x="180" y="240" class="lblsm" text-anchor="middle">Presenciar</text>
    </g>

    <g>
      <circle cx="540" cy="180" r="46" fill="rgba(31,37,71,0.06)" stroke="#1f2547" stroke-width="1" />
      <text x="540" y="178" class="lbl ind" text-anchor="middle" font-weight="600">Interfero-</text>
      <text x="540" y="196" class="lbl ind" text-anchor="middle" font-weight="600">metro</text>
      <text x="540" y="240" class="lblsm" text-anchor="middle">Discriminar</text>
    </g>

    <g>
      <circle cx="360" cy="430" r="46" fill="rgba(156,122,42,0.08)" stroke="#9c7a2a" stroke-width="1" />
      <text x="360" y="428" class="lbl gold" text-anchor="middle" font-weight="600">Universo</text>
      <text x="360" y="446" class="lbl gold" text-anchor="middle" font-weight="600">participativo</text>
      <text x="360" y="490" class="lblsm" text-anchor="middle">Participar</text>
    </g>

    <g stroke="#8b2e2e" stroke-width="1" fill="none" opacity="0.4">
      <line x1="220" y1="210" x2="305" y2="252" />
      <line x1="500" y1="210" x2="415" y2="252" />
      <line x1="360" y1="330" x2="360" y2="384" />
    </g>

    <g class="lblsm">
      <text x="50" y="60" text-anchor="start">i · Cuerpo</text>
      <text x="50" y="120" text-anchor="start">ii · Emoción</text>
      <text x="50" y="380" text-anchor="start">iii · Mente</text>
      <text x="50" y="440" text-anchor="start">iv · Vínculos</text>
      <text x="50" y="500" text-anchor="start">v · Vibración</text>
    </g>

    <g class="lblsm">
      <text x="670" y="60" text-anchor="end">Krishnamurti</text>
      <text x="670" y="120" text-anchor="end">Varela</text>
      <text x="670" y="380" text-anchor="end">Wheeler</text>
      <text x="670" y="440" text-anchor="end">Bohm</text>
      <text x="670" y="500" text-anchor="end">Weil</text>
    </g>

    <rect x="20" y="20" width="680" height="500" fill="none" stroke="#8b2e2e" stroke-opacity="0.2" stroke-width="0.5" />
  </svg>
</div>

<style>
  .mapa-conceptual {
    margin: 2.5rem 0 3rem;
    padding: 1.5rem;
    background: rgba(235, 225, 203, 0.4);
    border-radius: 4px;
    text-align: center;
  }
  .mapa-conceptual svg {
    max-width: 100%;
    height: auto;
  }
</style>
