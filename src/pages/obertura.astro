---
import { getEntry } from 'astro:content';
import LecturaLarga from '@/layouts/LecturaLarga.astro';
import BloquePuerta from '@/components/book/BloquePuerta.astro';
import { getNivel, gatingActivo } from '@/lib/gating';

export const prerender = false;

const obertura = await getEntry('book', 'obertura');
if (!obertura) throw new Error('Obertura entry not found');
const { Content } = await obertura.render();
const data = obertura.data;

const nivel = gatingActivo() ? getNivel(Astro.cookies) : 1;
---

<LecturaLarga
  title={`${data.title} · ${data.subtitle} · Tejidos de Vibración`}
  description="Obertura del Volumen I de Tejidos de Vibración. Por Ricardo Polo · Orion."
  pageId="obertura"
  ogImage="/og/obertura.png"
>
  <article class="measure" style="padding-top: 5rem;">
    <header class="stack-sm">
      <p class="eyebrow">Volumen I · Apertura</p>
      <h1 class="title-1">{data.title}</h1>
      <p class="title-1__sub">{data.subtitle}</p>
    </header>

    <div class="flourish flourish--rule"></div>

    <section class="prose dropcap section-gap">
      <Content />
    </section>

    <!-- Bloque-puerta para Nivel 0 (oculto en Nivel 1+ via CSS) -->
    <BloquePuerta tipo="obertura" />

    <!-- Banner para Nivel 1+ (se muestra solo cuando data-nivel >= 1) -->
    <section class="banner-umbral-cruzado">
      <p class="banner-umbral-cruzado__intro">◆</p>
      <h2>Has cruzado el umbral</h2>
      <p>El Capítulo 1 está abierto para ti.</p>
      <a class="lit-link lit-link--lg" href="/capitulo/cap-1-universo-sinfonia">Empezar el Capítulo 1 →</a>
    </section>
  </article>
</LecturaLarga>
