---
/**
 * CapituloLayout · wrapper delgado sobre <BookReader> para los capítulos
 * del libro (refactor de deduplicación · 2026-05-31).
 *
 * Todo el chrome (header de 3 slots, reading-progress, thread-strip,
 * paper-grain, reader-controls, scaffold + pre-paint) vive en BookReader.
 * Este wrapper sólo inyecta:
 *   - su TOC (CapituloToc) en el slot izquierdo del header
 *   - su breadcrumb central (◆ §N · Cap. N)
 *   - su SEO (index,follow heredado de BookReader · OG "Tejidos de Vibración" · sin schema)
 *   - sus overrides de cuerpo (.prose justify+hyphens · .measure h2)
 *
 * El cuerpo de lectura (.prose, .measure, .marginalia) y la tipografía
 * vienen de system.css (importado por BookReader vía global.css).
 *
 * SEO: indexable (index,follow) por el default de BookReader — los capítulos
 * son contenido público del libro.
 */
import BookReader from '@/layouts/BookReader.astro';
import CapituloToc from '@/components/book/CapituloToc.astro';
import CapituloRail from '@/components/book/CapituloRail.astro';
import { chapterOgAlt, chapterOgImage } from '@/lib/seo';

interface Props {
  /** Título HTML del <head>. */
  title: string;
  /** Descripción meta. */
  description: string;
  /** Slug del capítulo (para CapituloToc). */
  chapter: string;
  /** Etiqueta del capítulo (ej. "Capítulo II") · título del panel TOC. */
  chapterLabel?: string;
  /** Título canónico del capítulo para OG alt. */
  chapterTitle?: string;
  /** Slug-hoja de la pieza actual · highlight en el TOC. */
  currentSlug?: string;
  /** Breadcrumb central del header · omitir en el índice del capítulo. */
  breadcrumbOrnament?: string;
  breadcrumbText?: string;
  /** Nivel de acceso (gating) · propagado a body[data-nivel]. */
  nivel?: 0 | 1 | 2 | 3;
  pageId?: string;
}

const {
  title,
  description,
  chapter,
  chapterLabel,
  chapterTitle,
  currentSlug,
  breadcrumbOrnament,
  breadcrumbText,
  nivel = 1,
  pageId,
} = Astro.props;

const resolvedChapterLabel = chapterLabel ?? 'Capítulo';
const ogImage = chapterOgImage(chapter);
const ogImageAlt = chapterOgAlt(resolvedChapterLabel, chapterTitle ?? title);
---

<BookReader
  title={title}
  description={description}
  og={{
    type: 'article',
    siteName: 'Tejidos de Vibración',
    locale: 'es_ES',
    image: ogImage,
    imageAlt: ogImageAlt,
  }}
  nivel={nivel}
  pageId={pageId}
  bodyClass="capitulo-body"
  mainClass={currentSlug ? 'cap-main cap-main--pieza' : 'cap-main'}
  breadcrumb={breadcrumbText ? { ornament: breadcrumbOrnament, text: breadcrumbText } : undefined}
  track={currentSlug ? { surface: 'capitulo', chapter, section: currentSlug } : undefined}
>
  <CapituloToc slot="toc" chapter={chapter} current={currentSlug} chapterLabel={chapterLabel} />
  {/* Raíl lateral permanente (escritorio) · solo en piezas de lectura, no en
      la biblioteca (index sin currentSlug). El ☰ CapituloToc queda de fallback
      móvil. Análogo a PieceRail de la Obertura (OberturaLayout:83). */}
  {currentSlug && (
    <CapituloRail chapter={chapter} current={currentSlug} chapterLabel={chapterLabel} />
  )}
  <slot />
</BookReader>

<style is:global>
  /* ── Main · columna de lectura del capítulo ──────────────────── */
  .cap-main {
    position: relative;
    z-index: 1;
    padding: 2.5rem 1.5rem 6rem;
  }

  /* ── Header ceremonial de pieza · formato «Umbral» (F1) ─────────
     Portado de OberturaLayout `.piece-title`/`.piece-subtitle` con tokens
     del libro (--serif, --oro-titulo). Scoped a `.capitulo-body` para no
     tocar la Obertura ni subir reglas a system.css global. Sustituye al
     `.title-1`/`.title-1__sub` genérico (3rem, --oro brillante). */
  .capitulo-body .piece-header { margin: 0 0 2.25rem; }
  .capitulo-body .piece-title {
    font-family: var(--serif);
    font-weight: 600;
    font-size: clamp(2.6rem, 4vw, 3.375rem);
    line-height: 1.05;
    letter-spacing: -0.005em;
    color: var(--oro-titulo);
    margin: 0;
    text-wrap: balance;
  }
  .capitulo-body .piece-subtitle {
    font-family: var(--serif);
    font-style: italic;
    font-size: 1.5rem;
    line-height: 1.3;
    color: var(--tinta);
    margin: 0.75rem 0 0;
    text-wrap: balance;
  }

  /* ── Eyebrow de la biblioteca del capítulo · hueco real (F0) ────
     `.section-eyebrow` se usaba en index.astro sin ninguna regla CSS
     (solo existía `.section-eyebrow-bold` de la Obertura) → se veía como
     párrafo plano. Reusa el patrón de `.eyebrow`. */
  .capitulo-body .section-eyebrow {
    font-family: var(--sans);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--reposo);
    margin: 0 0 0.5rem;
  }

  /* ── Retícula raíl│columna · formato «Umbral» (F2) ──────────────
     Portado 1:1 de OberturaLayout .obertura-main--pieza / .piece-rail con
     tokens del libro. SOLO en piezas de lectura (mainClass lleva --pieza);
     la biblioteca (index · cap-main a secas) NO lo hereda. El raíl lo
     inyecta CapituloLayout (CapituloRail) como hermano del <article>. */
  .cap-main--pieza {
    max-width: 62rem;
    margin: 0 auto;
    padding: 3.25rem 1.5rem 6rem;
    display: grid;
    grid-template-columns: [rail] 12.25rem [content] minmax(0, 41.25rem);
    column-gap: 4rem;
    justify-content: center;
    align-items: start;
  }
  .cap-main--pieza > :not(.piece-rail) { grid-column: content; min-width: 0; }

  /* Raíl izquierdo (sticky) */
  .piece-rail {
    grid-column: rail;
    position: sticky;
    top: 5.5rem;
    align-self: start;
    font-family: var(--sans);
  }
  .piece-rail__eyebrow {
    font-size: 0.6875rem;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--oro-texto);
    margin: 0;
  }
  .piece-rail__list { list-style: none; padding: 0; margin: 1.4rem 0 0; }
  .piece-rail__item a {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    padding: 0.28rem 0 0.28rem 0.65rem;
    border-left: 2px solid transparent;
    text-decoration: none;
    color: var(--reposo);
    font-size: 0.78rem;
    line-height: 1.35;
    transition: color 0.15s;
  }
  .piece-rail__item a:hover { color: var(--tinta); }
  .piece-rail__num {
    font-family: var(--mono);
    font-size: 0.6875rem;
    color: var(--reposo-claro);
    flex-shrink: 0;
  }
  .piece-rail__name { min-width: 0; }
  .piece-rail__item.is-current a {
    border-left-color: var(--oro-suave);
    color: var(--tinta);
    font-weight: 500;
  }
  .piece-rail__item.is-current .piece-rail__num { color: var(--oro-texto); }

  /* La portada (kind='portada') conserva su composición ceremonial: escapa
     la retícula y oculta el raíl (su MDX ya renderiza <Frontispicio>). */
  .cap-main--pieza:has(.kind-portada) {
    display: block;
    max-width: var(--col);
    padding: 2.5rem 1.5rem 6rem;
  }
  .cap-main--pieza:has(.kind-portada) .piece-rail { display: none; }

  /* Responsive · <1100px el raíl vuelve al ☰ del header (CapituloToc). */
  @media (max-width: 68.75rem) {
    .cap-main--pieza {
      display: block;
      max-width: var(--col);
      padding: 2.5rem 1.5rem 6rem;
    }
    .cap-main--pieza .piece-rail { display: none; }
  }

  /* ── Justify + hyphens · SOLO cuerpo .prose (decisión 4) ──────── */
  .capitulo-body .prose > p {
    text-align: justify;
    text-justify: inter-word;
    hyphens: auto;
    -webkit-hyphens: auto;
  }
  /* No justificar la última línea suelta de párrafos cortos en mobile */
  @media (max-width: 480px) {
    .capitulo-body .prose > p { text-align: left; }
  }

  /* ── Divisores de sección (h2 del cuerpo) · sub-tarea 3.5 ──────
     system.css aplica `.measure h2 { text-transform: lowercase }` con
     inicial mayúscula. En capítulos el texto fuente ya viene en caja
     correcta desde el DOCX · respetarlo. Scoped a `.capitulo-body`. */
  .capitulo-body .measure h2 { text-transform: none; }
  .capitulo-body .measure h2::first-letter { text-transform: none; }

  /* ── Móvil ───────────────────────────────────────────────────── */
  @media (max-width: 640px) {
    .cap-main { padding: 2rem 1.2rem 5rem; }
  }
</style>
