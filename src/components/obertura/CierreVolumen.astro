---
/**
 * <CierreVolumen> · marca de cierre del volumen.
 *
 * Pieza ornamental al final del cap. 11 · "Fin del Volumen i · Obertura"
 * + ornamento ◇ ◆ ◇ + firma del autor.
 */
---

<p class="fin-volumen">Fin del Volumen i · Obertura</p>

<div class="ornament-final" aria-hidden="true">◇   ◆   ◇</div>

<p class="firma-cierre">
  Ricardo Polo · Orion<br />
  <span>Tejidos de Vibración</span>
</p>

<style>
  .fin-volumen {
    text-align: center;
    font-family: var(--obertura-sans);
    font-size: 0.7rem;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--obertura-ink-faded);
    margin-top: 6rem;
  }
  .ornament-final {
    text-align: center;
    color: var(--obertura-thread);
    margin: 4.5rem 0;
    font-size: 1.25rem;
    letter-spacing: 1.2em;
    user-select: none;
  }
  .firma-cierre {
    text-align: center;
    font-family: var(--obertura-serif);
    font-style: italic;
    color: var(--obertura-ink-faded);
    font-size: 0.95rem;
  }
  .firma-cierre span {
    font-size: 0.78rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    font-style: normal;
  }
</style>
