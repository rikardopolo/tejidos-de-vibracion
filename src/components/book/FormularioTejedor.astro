---
/**
 * FormularioTejedor.astro — Captura nombre + correo + consentimiento + honeypot.
 * Form de registro CANÓNICO del sitio (usado en /recibir, gate de Obertura y
 * pre-venta). Envía POST al endpoint indicado vía /formulario-tejedor.js.
 *
 * Props:
 *   id: para distinguir múltiples instancias en una misma página (default "form-tejedor")
 *   variant: "inline" (compacto, para BloqueRegistro) o "page" (centrado, para /recibir)
 *   endpoint: API destino (default "/api/leads/libro" · DOI flow en Brevo)
 *   submitText: texto del botón (default "Entrar al tejido")
 *   successText: mensaje tras envío exitoso
 *   consentText: prefijo del consentimiento (antes del enlace a privacidad)
 */
export interface Props {
  id?: string;
  variant?: 'inline' | 'page';
  endpoint?: string;
  submitText?: string;
  successText?: string;
  consentText?: string;
}
const {
  id = 'form-tejedor',
  variant = 'inline',
  endpoint = '/api/leads/libro',
  submitText = 'Entrar al tejido',
  successText = 'Revisa tu correo. Te enviamos un link para confirmar.',
  consentText = 'Acepto recibir los capítulos por correo y que se registre mi avance de lectura para mejorar el libro. Conozco la',
} = Astro.props;
---

<form id={id} class={`form-tejedor form-tejedor--${variant}`} novalidate
      data-tejedor-form data-endpoint={endpoint} data-submit-text={submitText}
      data-success-text={successText}>
  <label class="form-tejedor__field">
    <span class="form-tejedor__label">Nombre</span>
    <input type="text" name="nombre" required minlength="2" maxlength="100"
           placeholder="tu nombre" autocomplete="given-name" />
  </label>

  <label class="form-tejedor__field">
    <span class="form-tejedor__label">Correo</span>
    <input type="email" name="correo" required maxlength="254"
           placeholder="tu correo" autocomplete="email" />
  </label>

  <label class="form-tejedor__consent">
    <input type="checkbox" name="acepto" required />
    <span>{consentText} <a href="/privacidad" class="lit-link">política de privacidad</a>.</span>
  </label>

  <input type="text" name="website" tabindex="-1" autocomplete="off"
         aria-hidden="true" class="form-tejedor__honeypot" />

  <button type="submit" class="form-tejedor__submit">{submitText}</button>

  <p class="form-tejedor__nota">
    Sin spam. Sin venta de datos. Cada correo trae link de baja con un click.
  </p>

  <p class={`form-tejedor__status form-tejedor__status--${id}`} role="status" aria-live="polite" data-status-for={id}></p>
</form>

<script src="/formulario-tejedor.js" defer></script>
