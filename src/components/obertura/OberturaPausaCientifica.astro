---
/**
 * <PausaCientifica> (Obertura) · adaptador delgado sobre <Marginalia>.
 *
 * Refactor de deduplicación (2026-05-31): UNA sola base de cajas
 * (Marginalia · system.css GLOBAL → prod-safe). Mapea la API histórica
 * (title/level/levelLabel) al kind 'pausa-cientifica' (eyebrow índigo).
 *
 * El índigo propio de la Obertura (#1f2547) se preserva con un override
 * scoped a `.obertura-body .marginalia--cientifica .marginalia__kind` en
 * OberturaLayout. `level`/`levelLabel` se ignoran (compat · ya no se
 * renderizaba el badge). Ningún MDX usa `.ref`/`.limit` (verificado).
 */
import Marginalia from '@/components/book/Marginalia.astro';

interface Props {
  /** Título del bloque científico. */
  title: string;
  /** Nivel de evidencia · CONSERVADO por compat · ya no se renderiza. */
  level?: 1 | 2 | 3 | 4;
  /** Etiqueta de nivel · CONSERVADO por compat · ya no se renderiza. */
  levelLabel?: string;
}

const { title } = Astro.props;
---

<Marginalia kind="pausa-cientifica" titulo={title} label="Pausa Científica">
  <slot />
</Marginalia>
