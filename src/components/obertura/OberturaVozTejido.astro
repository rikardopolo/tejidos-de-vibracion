---
/**
 * <VozTejido> · semblanza biográfica de un autor citado (Obertura).
 *
 * Sprint unificación de estilo · decisión 3 (B3a · restyle in-place).
 * Migrado del formato ELABORADO (avatar circular de iniciales + panel
 * gradiente + centrado + borde carmesí) al formato SOBRIO de Capítulos
 * (border-left + eyebrow con color semántico), para unificar el look.
 *
 * El eyebrow conserva su color semántico (verde/teal · Voz del Tejido).
 * El borde izquierdo va en oro como el resto de las cajas del libro.
 *
 * Compat: `portrait` se mantiene en la interfaz (las piezas la pasan)
 * pero ya NO se renderiza el avatar · el nombre + fechas pasan al título.
 */

interface Props {
  /** Iniciales del autor · CONSERVADO por compat · ya no se renderiza. */
  portrait?: string;
  /** Nombre completo. */
  name: string;
  /** Fechas de vida (ej. "1842 — 1910"). */
  dates?: string;
}

const { name, dates } = Astro.props;
const titulo = dates ? `${name} (${dates})` : name;
---

<aside class="voz-tejido">
  <p class="voz-tejido__kind">Voz del Tejido</p>
  <h3 class="voz-tejido__title">{titulo}</h3>
  <div class="voz-tejido__body">
    <slot />
  </div>
</aside>

<style>
  /* Formato sobrio · espejo de .marginalia / .marginalia--voz (system.css).
     Borde oro; eyebrow verde (semantico de Voz). Tokens obertura para
     funcionar bajo OberturaLayout (standalone, sin system.css). */
  .voz-tejido {
    border-left: 2px solid var(--obertura-thread);
    padding: 1.5rem 0 1.5rem 1.75rem;
    margin: 2.5rem 0;
    background: transparent;
  }
  .voz-tejido__kind {
    font-family: 'DM Sans', var(--obertura-sans);
    font-weight: 500;
    font-size: 0.6875rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #1D9E75; /* verde/teal · color semantico de Voz (decision 1) */
    margin: 0 0 0.25rem 0;
  }
  .voz-tejido__title {
    font-family: var(--obertura-serif);
    font-style: italic;
    font-weight: 500;
    font-size: 1.375rem;
    line-height: 1.3;
    color: var(--obertura-ink);
    margin: 0 0 1rem 0;
  }
  .voz-tejido__body {
    font-size: 1.0625rem;
    line-height: 1.65;
    color: var(--obertura-ink-soft);
  }
  .voz-tejido__body :global(p) { margin: 0 0 1em 0; }
  .voz-tejido__body :global(p:last-child) { margin-bottom: 0; }
</style>
