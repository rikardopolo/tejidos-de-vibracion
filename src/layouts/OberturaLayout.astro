---
/**
 * OberturaLayout · wrapper delgado sobre <BookReader> para la Obertura.
 * (refactor de deduplicación · 2026-05-31)
 *
 * Todo el chrome común (header de 3 slots, reading-progress, thread-strip,
 * paper-grain, reader-controls, pre-paint de prefs) vive en BookReader.
 * Este wrapper sólo inyecta:
 *   - su TOC (OberturaToc) en el slot izquierdo del header
 *   - su breadcrumb central (◆ {headerLabel}) · omitido en el índice
 *   - su SEO (hreflang · OG og-obertura.jpg · base schema + schemas · indexable)
 *   - su tipografía/paleta propias (EB Garamond · vars --obertura-* ·
 *     frontispiece · copyright · h2.chapter / h3.sub / h4.sub-sub · flourishes)
 *
 * Prefs de lectura migradas al sistema canónico del libro:
 *   - tamaño:  html[data-reader-size="small|default|large"]  (libro-reader.js)
 *   - modo:    html[data-reader-mode="day|night"]
 * La Obertura conserva su escala propia (19/21/23px · sin XL) y su paleta
 * "night" propia, vía overrides scoped a `.obertura-body`.
 *
 * La estética paper-and-ink (EB Garamond · acentos en hilo oro · indigo de
 * los carriles científicos) se conserva intacta en la columna de lectura;
 * sólo el chrome se unifica con los Capítulos.
 */
import BookReader from '@/layouts/BookReader.astro';
import OberturaToc from '@/components/obertura/OberturaToc.astro';
import PieceRail from '@/components/obertura/PieceRail.astro';
import { baseSchemaGraph, DEFAULT_OG_IMAGE } from '@/lib/seo';

interface Props {
  /** Título HTML para el <head>. */
  title: string;
  /** Descripción meta. */
  description?: string;
  /** Etiqueta del breadcrumb · "00 · Frontispicio", "Interludio i", etc.
   *  Omitir en el índice de la Obertura (no muestra breadcrumb). */
  headerLabel?: string;
  /** Slug actual · highlightea la pieza activa en el TOC. */
  currentSlug?: string;
  /** Schema.org JSON-LD adicional · array de bloques. */
  schemas?: Record<string, unknown>[];
  /** Nivel de acceso del lector (0=anónimo, 1=tejedor, 2=suscriptor).
   *  Se propaga a body[data-nivel="..."] para CSS de gating. Default: 1. */
  nivel?: 0 | 1 | 2 | 3;
}

const {
  title,
  description,
  headerLabel,
  currentSlug,
  schemas = [],
  nivel = 1,
} = Astro.props;

// OG image · `/og/og-obertura.jpg` (1200x630 paper-and-ink). Compartida por la
// biblioteca y las piezas de la Obertura.
const ogImage = DEFAULT_OG_IMAGE;
// Schema.org base · Organization + WebSite + Person · misma fuente que antes.
const baseGraph = baseSchemaGraph();
const allSchemas = [{ '@context': 'https://schema.org', '@graph': baseGraph }, ...schemas];
---

<BookReader
  title={title}
  description={description}
  hreflang={true}
  og={{
    type: 'article',
    siteName: 'Tejidos de Vibración',
    locale: 'es_CO',
    image: ogImage,
    imageAlt: `${title} · Obertura del Volumen I · Tejidos de Vibración`,
  }}
  schemas={allSchemas}
  nivel={nivel}
  bodyClass="obertura-body"
  mainClass={currentSlug ? 'obertura-main obertura-main--pieza' : 'obertura-main'}
  breadcrumb={headerLabel ? { ornament: '◆', text: headerLabel } : undefined}
  track={currentSlug ? { surface: 'obertura', chapter: 'obertura', section: currentSlug } : undefined}
>
  <OberturaToc slot="toc" current={currentSlug} />
  {currentSlug && <PieceRail current={currentSlug} />}
  <slot />
</BookReader>

<style is:global>
  /* ─── Custom properties Obertura ─────────────────────────────
     Sub-paleta paper-and-ink de la Obertura · armonizada con el canon
     Pergamino del libro (2026-05-18 · migración portal→libro · Opción C).
     - Alineados al canon Pergamino: paper, paper-warm, ink, ink-soft
     - Preservados con identidad paper-and-ink: ink-faded (cálido), gold (apagado)
     - Canon intocable: thread (Hilo del Tejedor) + sus 5 variantes alpha
     Ver decisión documentada en CANON.md sección "Sub-paleta Obertura". */
  :root {
    --obertura-paper: #f2ead5;         /* alineado al canon --pergamino */
    --obertura-paper-warm: #e5dbbe;    /* alineado al canon --pergamino-2 */
    --obertura-paper-deep: #e2d5b8;    /* preservado · profundidad propia */
    --obertura-ink: #1a1a1a;           /* alineado al canon --tinta */
    --obertura-ink-soft: #3a3530;      /* alineado al canon --tinta-suave */
    --obertura-ink-faded: #6b5f4d;     /* PRESERVADO · faded cálido sobre paper */
    /* Sprint unificación de estilo · el "hilo" del chrome migra de
       carmesí (#8b2e2e) a ORO para unificar con Capítulos. Los colores
       semánticos de las cajas (indigo abajo · teal/verde) se conservan. */
    --obertura-thread: #B68914;        /* oro-suave · era carmesí #8b2e2e */
    --obertura-thread-deep: #8a6a10;   /* oro deep · era #5a1818 */
    /* Variantes alpha del hilo · ahora en oro rgb(182,137,20) */
    --obertura-thread-hover: rgba(182, 137, 20, 0.05);    /* hover de TOC/nav-links */
    --obertura-thread-ambient: rgba(182, 137, 20, 0.03);  /* gradient ambient sutil */
    --obertura-thread-soft: rgba(182, 137, 20, 0.08);     /* bg PausaReflexiva */
    --obertura-thread-mark: rgba(182, 137, 20, 0.10);     /* bg badge VozTejido */
    --obertura-thread-quote: rgba(182, 137, 20, 0.32);    /* border-left blockquotes */
    --obertura-indigo: #1f2547;
    --obertura-indigo-soft: #3b446e;
    --obertura-gold: #9c7a2a;          /* PRESERVADO · oro apagado p/ indicadores epistémicos */
    --obertura-rule: rgba(26, 22, 18, 0.18);
    --obertura-rule-soft: rgba(26, 22, 18, 0.08);

    --obertura-serif: 'EB Garamond', 'EB Garamond Fallback', 'Iowan Old Style', Georgia, serif;
    --obertura-sans: 'Inter', 'Inter Fallback', -apple-system, BlinkMacSystemFont, sans-serif;
    --obertura-mono: 'JetBrains Mono', 'SF Mono', Menlo, monospace;

    /* measure unificado al Capítulo (--col 42rem · ~72ch). Era 34rem. */
    --obertura-col: 42rem;
    --obertura-rhythm: 1.5rem;
  }

  /* ─── Cuerpo de la Obertura ───────────────────────────────────
     Scoped a `.obertura-body` para ganar a las reglas de `body` de
     system.css (importado por BookReader vía global.css). */
  body.obertura-body {
    background: var(--obertura-paper);
    color: var(--obertura-ink);
    font-family: var(--obertura-serif);
    /* Unificado al Capítulo: misma base (19px / 1.7) vía tokens del libro.
       El reader-size lo maneja html[data-reader-size] → --fs-body (system.css),
       idéntico a Capítulos. Era 21px / 1.62 propio. */
    font-size: var(--fs-body);
    line-height: var(--lh-body);
    font-feature-settings: "kern", "liga", "onum";
    -webkit-font-smoothing: antialiased;
    text-rendering: optimizeLegibility;
  }

  /* ─── Main · columna de lectura ──────────────────────────────── */
  .obertura-main {
    position: relative;
    z-index: 1;
    max-width: var(--obertura-col);
    margin: 0 auto;
    /* padding unificado a .cap-main (era 4rem/8rem). */
    padding: 2.5rem 1.5rem 6rem;
  }

  /* ═══════════════════════════════════════════════════════════════
     REDISEÑO «UMBRAL» · retícula de pieza (raíl | lectura | marginalia)
     Solo en /obertura/[slug] (mainClass --pieza); el índice /obertura NO lo
     hereda. Reestructura la columna única en 3 zonas SIN tocar el MDX: el raíl
     es un elemento inyectado por el layout; las marginalia (hijas directas del
     .obertura-piece) FLOTAN al margen derecho. Especificidad 2-clases → gana a
     las reglas base sin depender del orden. ═══════════════════════════════════ */
  .obertura-main--pieza {
    max-width: 78rem;
    padding: 3.25rem 4rem 6rem;
    display: grid;
    grid-template-columns: [rail] 12.25rem [content] minmax(0, 1fr);
    column-gap: 4rem;
    align-items: start;
  }
  .obertura-main--pieza > :not(.piece-rail) { grid-column: content; min-width: 0; }

  /* ── Raíl izquierdo (sticky) ───────────────────────────────── */
  .piece-rail {
    grid-column: rail;
    position: sticky;
    top: 5.5rem;
    align-self: start;
    font-family: var(--obertura-sans);
  }
  .piece-rail__eyebrow {
    font-size: 0.6875rem; font-weight: 500; letter-spacing: 0.2em;
    text-transform: uppercase; color: var(--oro-texto); margin: 0;
  }
  .piece-rail__list { list-style: none; padding: 0; margin: 1.4rem 0 0; }
  .piece-rail__item a {
    display: flex; align-items: baseline; gap: 0.5rem;
    padding: 0.28rem 0 0.28rem 0.65rem;
    border-left: 2px solid transparent;
    text-decoration: none; color: var(--reposo);
    font-size: 0.78rem; line-height: 1.35; transition: color 0.15s;
  }
  .piece-rail__item a:hover { color: var(--obertura-ink); }
  .piece-rail__num {
    font-family: var(--obertura-mono); font-size: 0.6875rem;
    color: var(--reposo-claro); flex-shrink: 0;
  }
  .piece-rail__item.is-current a {
    border-left-color: var(--obertura-thread);
    color: var(--obertura-ink); font-weight: 500;
  }
  .piece-rail__item.is-current .piece-rail__num { color: var(--oro-texto); }
  .piece-rail__collapsed {
    font-size: 0.6875rem; letter-spacing: 0.12em; text-transform: uppercase;
    color: var(--reposo-claro); margin: 1.85rem 0 0;
  }
  .piece-rail__foot {
    font-size: 0.72rem; line-height: 1.7; color: var(--reposo-claro);
    margin: 2.25rem 0 0;
  }

  /* ── Columna de lectura (660) + marginalia flotante al margen ── */
  .obertura-main--pieza .obertura-piece > *,
  .obertura-main--pieza .obertura-piece > figure { max-width: 41.25rem; }
  .obertura-main--pieza .obertura-piece::after { content: ''; display: block; clear: both; }
  .obertura-main--pieza .obertura-piece > .marginalia {
    float: right;
    clear: right;
    width: 18.5rem;
    max-width: 18.5rem;
    margin: 0.5rem 0 1.75rem 2.5rem;
    padding: 0.25rem 0 0.25rem 1.375rem;
    border-left: 2px solid var(--obertura-thread);
  }
  .obertura-main--pieza .obertura-piece > .marginalia--cientifica { border-left-color: var(--obertura-indigo); }
  .obertura-main--pieza .obertura-piece > .marginalia--voz { border-left-color: var(--verde); }
  /* rótulos de voz · AA (D3): oro/verde de texto oscurecidos */
  .obertura-main--pieza .marginalia .marginalia__kind { color: var(--oro-texto); }
  .obertura-main--pieza .marginalia--voz .marginalia__kind { color: var(--verde-texto); }

  /* ── Encabezado de pieza abierta (title oro + subtítulo) ────── */
  .piece-header { margin: 0 0 2.25rem; }
  .piece-title {
    font-family: var(--obertura-serif); font-weight: 600;
    font-size: clamp(2.6rem, 4vw, 3.375rem); line-height: 1.05;
    letter-spacing: -0.005em; color: var(--oro-titulo); margin: 0;
    text-wrap: balance;
  }
  .piece-subtitle {
    font-family: var(--obertura-serif); font-style: italic;
    font-size: 1.5rem; line-height: 1.3; color: var(--obertura-ink);
    margin: 0.75rem 0 0; text-wrap: balance;
  }
  .piece-header__orn { text-align: left; margin: 1.75rem 0 0; font-size: 0.85rem; letter-spacing: 0; }
  /* el título de la pieza lo pone .piece-header (frontmatter); ocultamos el
     eyebrow-título que el MDX abre, para no duplicarlo. */
  .obertura-main--pieza .obertura-piece > .section-eyebrow-bold { display: none; }
  /* D2 · cuerpo de lectura alineado a la izquierda (sin justify ni hyphens auto) */
  .obertura-main--pieza .obertura-piece > p { text-align: left; hyphens: manual; -webkit-hyphens: manual; }

  /* El frontispicio (00) conserva su composición ceremonial centrada · queda
     FUERA de la retícula (su rediseño oro + colofón-a-marginalia es aparte). */
  .obertura-main--pieza:has(.kind-frontispicio) {
    display: block;
    max-width: var(--obertura-col);
    padding: 2.5rem 1.5rem 6rem;
  }
  .obertura-main--pieza:has(.kind-frontispicio) .piece-rail { display: none; }

  /* ── Responsive · <1100px raíl vuelve al ☰, marginalia al flujo ── */
  @media (max-width: 68.75rem) {
    .obertura-main--pieza {
      display: block;
      max-width: var(--obertura-col);
      padding: 2.5rem 1.5rem 6rem;
    }
    .piece-rail { display: none; }
    .obertura-main--pieza .obertura-piece > .marginalia {
      float: none; clear: none; width: auto; max-width: none;
      margin: 2.5rem 0; padding: 1rem 0 1rem 1.5rem;
    }
  }

  /* ─── Tipografía base ──────────────────────────────────────────
     Párrafo justificado + hyphens auto, idéntico al cuerpo .prose del
     Capítulo. Las cajas Marginalia lo revierten a ragged-right (abajo). */
  .obertura-main p {
    margin: 0 0 var(--obertura-rhythm);
    text-align: justify;
    text-justify: inter-word;
    text-wrap: pretty;
    hyphens: auto;
    -webkit-hyphens: auto;
  }
  .obertura-main p.lead {
    font-size: 1.18em;
    line-height: 1.55;
    color: var(--obertura-ink-soft);
  }
  .obertura-main p.dropcap::first-letter,
  .obertura-main p.lead.dropcap::first-letter {
    font-family: var(--obertura-serif);
    font-weight: 600;
    font-size: 4.4em;
    line-height: 0.85;
    float: left;
    padding: 0.05em 0.12em 0 0;
    color: var(--obertura-thread);
    font-style: italic;
  }

  .obertura-main em,
  .obertura-main i { font-style: italic; }
  .obertura-main strong,
  .obertura-main b { font-weight: 600; color: var(--obertura-ink); }

  /* ─── Separadores .flourish ───────────────────────────────────
     Emitidos por remark-separators.mjs (B.2) al gildar los literales
     standalone (— ◇ —, ◆, ◇ ◆ ◇). En oro vía --obertura-thread.
     Capítulos define lo mismo en system.css · misma apariencia. */
  .flourish {
    text-align: center;
    font-family: var(--obertura-serif);
    color: var(--obertura-thread);
    font-size: 1.25rem;
    letter-spacing: 0.6em;
    margin: 3rem 0;
    user-select: none;
  }
  .flourish--diamond::before { content: '◆'; }
  .flourish--triple::before  { content: '◇   ◆   ◇'; }
  .flourish--rule::before    { content: '— ◇ —'; letter-spacing: 0.3em; }

  /* ─── Cajas · base Marginalia (system.css global · prod-safe) ──────
     Refactor de deduplicación: las 3 cajas de la Obertura (Voz del Tejido,
     Pausa Científica, Pausa Reflexiva) son adaptadores sobre <Marginalia>.
     El markup `.marginalia*` se estila en system.css (GLOBAL → sin el bug
     de scoped-styles-en-MDX que rompía en prod). Aquí sólo se preserva la
     paleta paper-and-ink de la Obertura:
       - borde oro-suave (#B68914 día / #d9b24a noche) vs --oro del libro
       - eyebrow índigo propio de la Obertura (#1f2547 día / #8b95c4 noche)
     El eyebrow verde de Voz (#1D9E75) ya coincide con --verde (sin override).
     La Pausa Reflexiva adopta el formato sobrio (sin fondo ni disco). */
  .obertura-body .marginalia { border-left-color: var(--obertura-thread); }
  .obertura-body .marginalia--cientifica .marginalia__kind { color: var(--obertura-indigo); }

  /* Cajas Marginalia en la Obertura · ragged-right sin guiones automáticos.
     Mismo patrón que el bloque en system.css (que no se importa aquí). */
  .marginalia .marginalia__body p,
  .marginalia .marginalia__body li,
  .marginalia .marginalia__content p,
  .marginalia .marginalia__content li {
    text-align: left;
    hyphens: manual;
    -webkit-hyphens: manual;
  }

  /* ─── Encabezados ────────────────────────────────────────────── */
  .obertura-main h1.book-title {
    font-family: var(--obertura-serif);
    font-weight: 500;
    font-size: clamp(2.4rem, 5vw, 3.8rem);
    letter-spacing: 0.18em;
    text-transform: uppercase;
    text-align: center;
    margin: 0 0 0.6rem;
    line-height: 1.05;
  }
  .obertura-main h1.book-title .ampersand {
    font-style: italic;
    font-weight: 400;
    letter-spacing: 0;
    text-transform: lowercase;
    color: var(--obertura-thread);
  }

  .obertura-main h2.chapter {
    font-family: var(--obertura-serif);
    font-weight: 500;
    font-size: clamp(1.7rem, 3.5vw, 2.4rem);
    line-height: 1.15;
    margin: 5rem 0 2rem;
    letter-spacing: -0.005em;
    text-wrap: balance;
  }
  .obertura-main h2.chapter .num {
    display: block;
    font-family: var(--obertura-sans);
    font-weight: 400;
    font-size: 0.72rem;
    letter-spacing: 0.32em;
    text-transform: uppercase;
    color: var(--obertura-thread);
    margin-bottom: 0.5rem;
  }

  /* h3.sub · subtítulos de sección "kicker italic". Tamaño en em para que
     escale con el body (21px → ~30px). */
  .obertura-main h3.sub {
    font-family: var(--obertura-serif);
    font-weight: 500;
    font-style: italic;
    font-size: 1.42em;
    line-height: 1.22;
    margin: 3rem 0 1.4rem;
    color: var(--obertura-ink);
    letter-spacing: 0.003em;
    text-wrap: balance;
    padding-top: 1.2rem;
    border-top: 1px solid var(--obertura-rule-soft);
    position: relative;
  }
  .obertura-main h3.sub::before {
    content: "◆";
    position: absolute;
    top: -0.55em;
    left: 50%;
    transform: translateX(-50%);
    background: var(--obertura-paper);
    padding: 0 0.6em;
    font-size: 0.55em;
    color: var(--obertura-thread);
    font-style: normal;
    letter-spacing: 0;
  }
  .obertura-main h3.sub .num {
    font-family: var(--obertura-sans);
    font-style: normal;
    font-weight: 500;
    font-size: 0.78em;
    color: var(--obertura-ink-faded);
    margin-right: 0.55em;
    letter-spacing: 0.05em;
  }

  /* h4.sub-sub · sub-subsecciones tipo eyebrow. Italic oro con leading
     rombo. Tamaño en em para que escale con el body (21px → ~22px). */
  .obertura-main h4.sub-sub {
    font-family: var(--obertura-serif);
    font-weight: 600;
    font-style: italic;
    font-size: 1.06em;
    line-height: 1.3;
    margin: 2.4rem 0 1rem;
    color: var(--obertura-thread);
    letter-spacing: 0.01em;
    text-wrap: balance;
  }
  .obertura-main h4.sub-sub::before {
    content: "◇ ";
    color: var(--obertura-thread);
    font-style: normal;
    margin-right: 0.4em;
    opacity: 0.8;
  }
  /* Anotación parentética dentro del h4 (Nivel · descripción) · se separa
     visualmente como sub-línea muted, no italic. */
  .obertura-main h4.sub-sub .sub-sub-meta {
    display: block;
    margin-top: 0.3em;
    font-family: var(--obertura-sans);
    font-style: normal;
    font-weight: 400;
    font-size: 0.68em;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--obertura-ink-faded);
  }

  /* Citaciones sagradas · mantras / escrituras / mitos cosmogónicos
     emitidos por el parser como <blockquote class="cita">. Destacado en
     indigo con borde izquierdo, evocando el "carril contemplativo". */
  .obertura-main blockquote.cita {
    margin: 2.2rem 0 2.2rem 0.5rem;
    padding: 0.4rem 0 0.4rem 1.5rem;
    border-left: 2.5px solid var(--obertura-indigo);
    font-family: var(--obertura-serif);
    font-style: italic;
    font-size: 1.06em;
    line-height: 1.5;
    color: var(--obertura-indigo);
    text-wrap: pretty;
  }

  /* ─── Listas con marca diamante ──────────────────────── */
  .obertura-main ul.bullet,
  .obertura-main ul:not(.evidence-list):not([class]) {
    list-style: none;
    padding: 0;
    margin: 1.5rem 0;
  }
  .obertura-main ul.bullet li,
  .obertura-main ul:not(.evidence-list):not([class]) li {
    position: relative;
    padding-left: 1.6rem;
    margin-bottom: 0.8rem;
    line-height: 1.55;
  }
  .obertura-main ul.bullet li::before,
  .obertura-main ul:not(.evidence-list):not([class]) li::before {
    content: "◇";
    position: absolute;
    left: 0;
    top: 0;
    color: var(--obertura-thread);
    font-size: 0.8em;
  }

  /* ─── Blockquote ─────────────────────────────────────── */
  .obertura-main blockquote {
    margin: 1.5rem 0;
    padding: 0 1.4rem;
    border-left: 2px solid var(--obertura-thread);
    font-style: italic;
    color: var(--obertura-ink-soft);
  }

  /* ─── Eyebrow centered (UMBRAL POÉTICO, etc.) ────────── */
  .obertura-main .section-eyebrow-bold {
    font-family: var(--obertura-serif);
    font-weight: 600;
    font-size: 0.85rem;
    letter-spacing: 0.5em;
    text-transform: uppercase;
    color: var(--obertura-thread);
    text-align: center;
    margin: 2.5rem 0 1.2rem;
  }

  /* ─── Frontispiece (portada del PDF) ─────────────────── */
  .obertura-main .frontispiece {
    text-align: center;
    padding: 2rem 0 3rem;
    border-bottom: 1px solid var(--obertura-rule-soft);
    margin-bottom: 4rem;
  }
  .frontispiece-volumen {
    font-family: var(--obertura-sans);
    font-weight: 400;
    font-size: 0.78rem;
    letter-spacing: 0.4em;
    text-transform: uppercase;
