---
/**
 * <VozTejido> · semblanza biográfica de un autor citado (Obertura).
 *
 * Sprint unificación de estilo · decisión 3 (B3a · restyle in-place).
 * Migrado del formato ELABORADO (avatar circular de iniciales + panel
 * gradiente + centrado + borde carmesí) al formato SOBRIO de Capítulos
 * (border-left + eyebrow con color semántico), para unificar el look.
 *
 * El eyebrow conserva su color semántico (verde/teal · Voz del Tejido).
 * El borde izquierdo va en oro como el resto de las cajas del libro.
 *
 * Compat: `portrait` se mantiene en la interfaz (las piezas la pasan)
 * pero ya NO se renderiza el avatar · el nombre + fechas pasan al título.
 */

interface Props {
  /** Iniciales del autor · CONSERVADO por compat · ya no se renderiza. */
  portrait?: string;
  /** Nombre completo. */
  name: string;
  /** Fechas de vida (ej. "1842 — 1910"). */
  dates?: string;
}

const { name, dates } = Astro.props;
const titulo = dates ? `${name} (${dates})` : name;
---

<aside class="voz-tejido">
  <p class="voz-tejido__kind">Voz del Tejido</p>
  <h3 class="voz-tejido__title">{titulo}</h3>
  <div class="voz-tejido__body">
    <slot />
  </div>
</aside>

{/* Estilos en el GLOBAL de OberturaLayout (.voz-tejido*), NO scoped aquí:
    el <style> scoped de un .astro usado dentro de MDX genera un selector
    [data-astro-cid-…] que el build de producción no aplica → caja sin
    estilo en prod. Ver OberturaLayout `<style is:global>`. */}
