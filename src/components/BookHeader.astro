---
/**
 * BookHeader · barra de navegación sticky del libro.
 * El resaltado de página activa se detecta con Astro.url.pathname (sin JS).
 * El comportamiento .is-scrolled se añade via /libro-init.js.
 *
 * Responsive: en desktop el nav va inline; en móvil (≤720px) colapsa a un
 * menú desplegable nativo <details> (sin JS · CSP-safe) con los 6 ítems.
 */

const path = Astro.url.pathname;

function isCurrent(href: string): boolean {
  if (href === '/') return path === '/';
  if (href.includes('#')) return false;   // anclas (El Tejedor) no marcan página
  return path === href || path.startsWith(href + '/');
}

const links = [
  { href: '/indice', label: 'Índice' },
  { href: '/obertura', label: 'Obertura' },
  { href: '/recibir', label: 'Recibir' },
  { href: '/comunidad', label: 'Comunidad' },
  { href: '/sobre-el-libro', label: 'Sobre el libro' },
  { href: '/sobre-el-libro#el-tejedor', label: 'El Tejedor' },
];
---

<header class="book-header" id="book-header">
  <div class="book-header__inner">
    <a class="book-header__mark" href="/"><em>Tejidos de</em> Vibración</a>

    <!-- Desktop · nav inline -->
    <nav class="book-header__nav" aria-label="Navegación principal">
      {links.map((l) => (
        <a href={l.href} aria-current={isCurrent(l.href) ? 'page' : undefined}>{l.label}</a>
      ))}
    </nav>

    <!-- Móvil · menú desplegable (nativo, sin JS) -->
    <details class="book-header__menu">
      <summary class="book-header__toggle" aria-label="Abrir menú de navegación">
        <span aria-hidden="true">☰</span>
      </summary>
      <nav class="book-header__menu-panel" aria-label="Navegación principal">
        {links.map((l) => (
          <a href={l.href} aria-current={isCurrent(l.href) ? 'page' : undefined}>{l.label}</a>
        ))}
      </nav>
    </details>
  </div>
</header>
<div class="progress-rail" id="progress-rail" aria-hidden="true"></div>
