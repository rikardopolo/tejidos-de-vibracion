---
/**
 * <PausaCientifica> · contenido científico citable (Obertura).
 *
 * Sprint unificación de estilo · decisión 3 (B3a · restyle in-place).
 * Migrado del formato ELABORADO (doble borde índigo arriba/abajo + panel
 * + label mono con ▸ + badge de nivel de evidencia) al formato SOBRIO de
 * Capítulos (border-left + eyebrow índigo), para unificar el look.
 *
 * El eyebrow conserva su color semántico (índigo · carril científico).
 * El badge "Nivel N · …" se RETIRA · coherente con la limpieza de
 * andamiaje epistémico (la línea "Nivel de evidencia" se elimino del
 * contenido en la tarea previa).
 *
 * Compat: `level`/`levelLabel` se mantienen en la interfaz (las piezas
 * los pasan) pero ya NO se renderiza el badge.
 */

interface Props {
  /** Título del bloque científico. */
  title: string;
  /** Nivel de evidencia · CONSERVADO por compat · ya no se renderiza. */
  level?: 1 | 2 | 3 | 4;
  /** Etiqueta de nivel · CONSERVADO por compat · ya no se renderiza. */
  levelLabel?: string;
}

const { title } = Astro.props;
---

<aside class="pausa-cientifica">
  <p class="pausa-cientifica__kind">Pausa Científica</p>
  <h3 class="pausa-cientifica__title">{title}</h3>
  <div class="pausa-cientifica__body">
    <slot />
  </div>
</aside>

<style>
  /* Formato sobrio · espejo de .marginalia / .marginalia--cientifica.
     Borde oro; eyebrow indigo (semantico del carril cientifico). */
  .pausa-cientifica {
    border-left: 2px solid var(--obertura-thread);
    padding: 1.5rem 0 1.5rem 1.75rem;
    margin: 2.5rem 0;
    background: transparent;
  }
  .pausa-cientifica__kind {
    font-family: 'DM Sans', var(--obertura-sans);
    font-weight: 500;
    font-size: 0.6875rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--obertura-indigo); /* indigo · color semantico del carril */
    margin: 0 0 0.25rem 0;
  }
  .pausa-cientifica__title {
    font-family: var(--obertura-serif);
    font-style: italic;
    font-weight: 500;
    font-size: 1.375rem;
    line-height: 1.3;
    color: var(--obertura-ink);
    margin: 0 0 1rem 0;
  }
  .pausa-cientifica__body {
    font-size: 1.0625rem;
    line-height: 1.65;
    color: var(--obertura-ink-soft);
  }
  .pausa-cientifica__body :global(p) { margin: 0 0 1.2em 0; }
  .pausa-cientifica__body :global(ul) { font-size: 0.95em; padding-left: 1.2rem; margin: 1rem 0; }
  .pausa-cientifica__body :global(ul li) { margin-bottom: 0.5rem; }
  .pausa-cientifica__body :global(.ref) {
    font-size: 0.85em;
    color: var(--obertura-ink-faded);
    font-style: italic;
    border-left: 1px solid var(--obertura-rule);
    padding-left: 0.9rem;
    margin: 1.2rem 0;
  }
  .pausa-cientifica__body :global(.limit) {
    font-size: 0.92em;
    margin-top: 1rem;
    padding-top: 0.9rem;
    border-top: 1px dashed var(--obertura-rule);
    color: var(--obertura-ink-soft);
  }
  .pausa-cientifica__body :global(.limit strong) { color: var(--obertura-indigo); }
</style>
