---
import '../styles/global.css';
import { OG_IMAGE_HEIGHT, OG_IMAGE_TYPE, OG_IMAGE_WIDTH, baseSchemaGraph, canonicalFor, resolveOgImage } from '@/lib/seo';

import ebGaramond400 from '@fontsource/eb-garamond/files/eb-garamond-latin-400-normal.woff2?url';
import ebGaramond400i from '@fontsource/eb-garamond/files/eb-garamond-latin-400-italic.woff2?url';

const HOME_OG_IMAGE_PATH = '/og/og-home.jpg';
const HOME_OG_IMAGE_ALT = 'Tejidos de Vibración · Volumen I';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  ogImageAlt?: string;
  bodyClass?: string;
  pageId?: string;
  jsonLd?: Record<string, unknown>;
  robots?: string;
  nivel?: 0 | 1 | 2 | 3;
}

const {
  title,
  description,
  canonical,
  ogImage = HOME_OG_IMAGE_PATH,
  ogImageAlt = HOME_OG_IMAGE_ALT,
  bodyClass,
  pageId,
  jsonLd,
  robots = 'noindex,nofollow,noarchive',
  nivel = 0,
} = Astro.props;

const canonicalUrl = canonical ?? canonicalFor(Astro.url.pathname);
const ogImageUrl = resolveOgImage(ogImage);

// Grafo base (Organization + WebSite + Person) en TODA página estática que use
// este layout — no solo un WebSite mínimo. El jsonLd por página (si se pasa) se
// emite como bloque adicional; sus @id (p.ej. sobre-el-libro#person) resuelven
// contra este grafo.
const baseGraph = { '@context': 'https://schema.org', '@graph': baseSchemaGraph() };
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />

    {/* Preload de las caras críticas del cuerpo (EB Garamond 400 normal + itálica).
        Vite dedupe: la misma URL hasheada que pide @fontsource vía CSS → el preload
        se usa, no se desperdicia. Solo 2: precargar las 6 penalizaría. */}
    <link rel="preload" href={ebGaramond400} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={ebGaramond400i} as="font" type="font/woff2" crossorigin />

    <title>{title}</title>
    <meta name="description" content={description} />

    {/* robots · default noindex (404 + páginas de utilidad: privacidad, buscar,
        confirmación). Las páginas públicas pasan robots="index,follow" por prop.
        Obertura/capítulos son indexables vía BookReader. LecturaLarga reenvía
        esta prop → su default también es noindex salvo opt-in explícito. */}
    <meta name="robots" content={robots} />

    <link rel="canonical" href={canonicalUrl} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:image:width" content={String(OG_IMAGE_WIDTH)} />
    <meta property="og:image:height" content={String(OG_IMAGE_HEIGHT)} />
    <meta property="og:image:type" content={OG_IMAGE_TYPE} />
    <meta property="og:image:alt" content={ogImageAlt} />
    <meta property="og:locale" content="es_CO" />
    <meta property="og:site_name" content="Tejidos de Vibración" />

    <!-- Twitter / X -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />
    <meta name="twitter:image:alt" content={ogImageAlt} />

    <!-- JSON-LD · grafo base siempre + schema de página si lo hay -->
    <script type="application/ld+json" set:html={JSON.stringify(baseGraph)} />
    {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}
  </head>
  <body class={bodyClass} data-page={pageId} data-nivel={nivel}>
    <a href="#main-content" class="skip-link">Saltar al contenido</a>
    <slot />
  </body>
</html>
