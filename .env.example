# Brevo (lead capture libro · Double Opt-In)
BREVO_API_KEY=
BREVO_LISTA_LIBRO=
BREVO_TEMPLATE_DOI=
BREVO_TEMPLATE_BIENVENIDA=

# Gating · tokens de acceso HMAC
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ACCESS_TOKEN_SECRET=

# Supabase · backbone UNIFICADO de seguimiento (MISMO proyecto que el portal TDR).
# Server-only: persiste el ciclo de vida del suscriptor (lead/confirmación) y la
# lectura del libro (reading_events / reading_progress). NO afecta la CSP (la CSP
# es de navegador; las llamadas servidor→Supabase ocurren fuera de él).
# Requiere haber aplicado supabase/migrations/20260602120000_subscriber_tracking.sql
# del repo tejidos-de-realidad sobre ese proyecto.
PUBLIC_SUPABASE_URL=
SUPABASE_SECRET_KEY=

# Feature flags
GATING_ACTIVO=true
SUSCRIPCION_ACTIVA=false
COMUNIDAD_ACTIVA=false

# Site
PUBLIC_SITE_URL=https://tejidosdevibracion.com
SITE_URL=https://tejidosdevibracion.com
