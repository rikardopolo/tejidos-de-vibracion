---
/**
 * /obertura · biblioteca · TOC de las 15 piezas de la Obertura.
 *
 * Migrada desde el portal `tejidos-de-realidad` el 2026-05-18.
 * Auth gate · cookie `tejedor-access` HMAC firmada (sistema del libro).
 *
 * Estructura editorial:
 *   i.   Apertura     · 00 · 01 · interludio i
 *   ii.  Capacidades  · 02 · 03 · interludio ii · 04
 *   iii. Marco        · 05 · 06 · 07 · 08 · 09
 *   iv.  Cierre       · interludio iii · 10 · 11
 */
import OberturaLayout from '@/layouts/OberturaLayout.astro';
import { getCollection } from 'astro:content';
import { getNivel, gatingActivo } from '@/lib/gating';

export const prerender = false;

/**
 * Piezas de acceso público · Nivel 0 (sin cookie).
 * Las demás 12 piezas requieren Nivel 1 · marcadas en la biblioteca con
 * un indicador visual sutil ◆ apagado (oro fantasma).
 */
const PIEZAS_PUBLICAS = new Set([
  '00-frontispicio',
  '01-anclaje',
  'interludio-i',
]);

// La biblioteca es Nivel 0 público · todas las piezas se listan, las
// bloqueadas reciben un indicador visual. El gating real ocurre en [slug].astro
// al entrar a piezas Nivel 1.
//
// Bot allowlist · search engines + LLM crawlers + social unfurlers + validators.
const ua = Astro.request.headers.get('user-agent') ?? '';
const isBot = /bot|crawl|spider|googlebot|bingbot|gptbot|claudebot|perplexitybot|google-extended|oai-searchbot|anthropic-ai|cohere-ai|yandex|baiduspider|duckduckbot|applebot|facebookexternalhit|twitterbot|linkedinbot|whatsapp|telegrambot|slackbot|discord|mojeekbot|opengraph|preview|unfurl|metainspector|embed/i.test(ua);

// Resolver nivel · biblioteca pública para todos · solo se usa para propagar a CSS.
const nivel = isBot ? 1 : (gatingActivo() ? getNivel(Astro.cookies) : 1);

const allEntries = await getCollection('obertura', ({ data }) => data.status === 'published');
allEntries.sort((a, b) => a.data.order - b.data.order);

const sectionMeta = {
  apertura: { num: 'i', heading: 'Apertura', sub: 'Cruzar el umbral' },
  capacidades: { num: 'ii', heading: 'Las tres capacidades', sub: 'Presenciar · discriminar · participar' },
  marco: { num: 'iii', heading: 'Marco y compromiso', sub: 'Cómo se lee, qué se afirma' },
  cierre: { num: 'iv', heading: 'Cierre', sub: 'Lo que queda despierto' },
} as const;

type SectionKey = keyof typeof sectionMeta;
const sectionOrder: SectionKey[] = ['apertura', 'capacidades', 'marco', 'cierre'];

const grouped = sectionOrder.map((key) => ({
  key,
  meta: sectionMeta[key],
  entries: allEntries.filter((e) => e.data.section === key),
}));
---

<OberturaLayout
  title="Tejidos de Vibración · Obertura · Biblioteca"
  description="Biblioteca de la Obertura del Volumen I · 11 capítulos + 3 interludios musicales · Tejidos de Vibración."
  schemas={[
    {
      '@context': 'https://schema.org',
      '@graph': [
        {
          '@type': 'Article',
          '@id': 'https://tejidosdevibracion.com/obertura#article',
          headline: 'Obertura · Tejidos de Vibración',
          alternativeHeadline: 'Capítulo de apertura del Volumen I',
          url: 'https://tejidosdevibracion.com/obertura',
          description: 'Obertura del libro Tejidos de Vibración · Volumen I. 11 capítulos + 3 interludios musicales. Acceso gratuito.',
          image: 'https://www.tejidosdevibracion.com/og/og-obertura.jpg',
          datePublished: '2026-01-01T00:00:00-05:00',
          dateModified: '2026-04-29T00:00:00-05:00',
          inLanguage: 'es',
          author: { '@id': 'https://tejidosdevibracion.com/sobre-el-libro#person' },
          publisher: { '@id': 'https://tejidosdevibracion.com/#organization' },
          isPartOf: { '@id': 'https://tejidosdevibracion.com/obertura#book' },
          isAccessibleForFree: true,
          mainEntityOfPage: 'https://tejidosdevibracion.com/obertura',
          // Outbound citations · linaje intelectual del libro. Mix de
          // referencias filosóficas (Stanford), físicas (Wikipedia) y
          // recursos didácticos (MIT OCW, Feynman Lectures).
          citation: [
            { '@type': 'CreativeWork', url: 'https://plato.stanford.edu/entries/qm/', name: 'Quantum Mechanics · Stanford Encyclopedia of Philosophy' },
            { '@type': 'CreativeWork', url: 'https://plato.stanford.edu/entries/consciousness/', name: 'Consciousness · Stanford Encyclopedia of Philosophy' },
            { '@type': 'CreativeWork', url: 'https://plato.stanford.edu/entries/qt-consciousness/', name: 'Quantum Approaches to Consciousness · Stanford Encyclopedia' },
            { '@type': 'CreativeWork', url: 'https://en.wikipedia.org/wiki/Cymatics', name: 'Cymatics · Wikipedia' },
            { '@type': 'CreativeWork', url: 'https://en.wikipedia.org/wiki/Atomic_orbital', name: 'Atomic orbital · Wikipedia' },
            { '@type': 'CreativeWork', url: 'https://en.wikipedia.org/wiki/Double-slit_experiment', name: 'Double-slit experiment · Wikipedia' },
            { '@type': 'CreativeWork', url: 'https://en.wikipedia.org/wiki/Magnetocardiography', name: 'Magnetocardiography · Wikipedia' },
            {
              '@type': 'CreativeWork',
              url: 'https://www.feynmanlectures.caltech.edu/III_toc.html',
              name: 'The Feynman Lectures Vol. III · Quantum Mechanics',
              author: { '@type': 'Person', name: 'Richard Feynman' },
            },
          ],
          // hasPart · señal explícita de la estructura del libro como
          // recursos referenciados (los 6 simuladores son experimentos del
          // libro). Esto le dice a Google: "este Article tiene partes
          // identificables, que son aplicaciones interactivas".
          hasPart: [
            { '@id': 'https://tejidosderealidad.com/simuladores/cymatica#resource' },
            { '@id': 'https://tejidosderealidad.com/simuladores/orbitales#resource' },
            { '@id': 'https://tejidosderealidad.com/simuladores/campo-cuantico#resource' },
            { '@id': 'https://tejidosderealidad.com/simuladores/doble-rendija#resource' },
            { '@id': 'https://tejidosderealidad.com/simuladores/tejido#resource' },
            { '@id': 'https://tejidosderealidad.com/simuladores/constelacion#resource' },
          ],
        },
        {
          '@type': 'Book',
          '@id': 'https://tejidosdevibracion.com/obertura#book',
          name: 'Tejidos de Vibración · Volumen I',
          alternativeHeadline: 'Manual V5.2',
          author: { '@id': 'https://tejidosdevibracion.com/sobre-el-libro#person' },
          publisher: { '@id': 'https://tejidosdevibracion.com/#organization' },
          inLanguage: 'es',
          bookFormat: 'https://schema.org/EBook',
          url: 'https://tejidosdevibracion.com/',
          datePublished: '2026',
          abstract: 'Volumen I de la serie Tejidos de Realidad. Tres actos sobre física, conciencia y cymática, acompañados de un laboratorio interactivo de seis simuladores.',
        },
        {
          '@type': 'BreadcrumbList',
          '@id': 'https://tejidosdevibracion.com/obertura#breadcrumb',
          itemListElement: [
            { '@type': 'ListItem', position: 1, name: 'Inicio', item: 'https://tejidosdevibracion.com/' },
            { '@type': 'ListItem', position: 2, name: 'Índice', item: 'https://tejidosdevibracion.com/indice' },
            { '@type': 'ListItem', position: 3, name: 'Obertura', item: 'https://tejidosdevibracion.com/obertura' },
          ],
        },
      ],
    },
  ]}
  nivel={nivel}
>
  <header class="biblio-hero vib-stage">
    <canvas id="c-6a" aria-hidden="true"></canvas>
    <p class="biblio-eyebrow">Volumen I · Tejidos de Vibración</p>
    <h1 class="biblio-h1">Obertura</h1>
    <p class="biblio-sub">El Tejedor Consciente Despierta</p>
    <p class="biblio-cta">
      <a href="/obertura/00-frontispicio" class="biblio-cta-link">Empezar por el Frontispicio</a>
    </p>
  </header>

  <div class="biblio-meta">
    <span>Quince piezas · Tres interludios</span>
    <span class="biblio-meta-dot" aria-hidden="true">◆</span>
    <span>Tiempo de lectura · 22 minutos</span>
  </div>

  <div class="toc toc--grid">
    {grouped.map((group) => group.entries.length > 0 && (
      <section class="toc-section">
        <p class="heading">{group.meta.num} · {group.meta.heading}</p>
        <p class="heading-sub">{group.meta.sub}</p>
        <ol>
          {group.entries.map((entry) => {
            const esPublica = PIEZAS_PUBLICAS.has(entry.id);
            const esBloqueada = !esPublica && nivel < 1;
            const esInterludio = entry.data.kind === 'interludio';
            return (
              <li class={`${esBloqueada ? 'is-locked' : ''} ${esInterludio ? 'is-interludio' : ''}`.trim()}>
                <a
                  href={`/obertura/${entry.id}`}
                  aria-label={esBloqueada ? `${entry.data.title} · requiere registro` : undefined}
                >
                  <span class="num">{entry.data.chapterNum}</span>
                  <span class="body">
                    {entry.data.title}
                    {entry.data.subtitle && <em>{entry.data.subtitle}</em>}
                  </span>
                  {esPublica ? (
                    <span class="estado estado--libre">De lectura libre</span>
                  ) : esBloqueada ? (
                    <span class="estado estado--correo">Con tu correo</span>
                  ) : (
                    <span class="arrow" aria-hidden="true">→</span>
                  )}
                </a>
              </li>
            );
          })}
        </ol>
      </section>
    ))}
  </div>

  <footer class="biblio-pie">
    <p class="biblio-puerta">La Obertura completa — las quince piezas, los tres interludios, el mapa conceptual — es libre para los tejedores registrados. Un nombre y un correo. Eso es todo.</p>
    <form class="form-tejedor form-tejedor--linea biblio-form" action="/recibir" method="get">
      <input type="email" name="correo" placeholder="tu@correo.com"
             aria-label="Tu correo" maxlength="254" autocomplete="email" />
      <button type="submit" class="form-tejedor__submit">Entrar al tejido&nbsp;&rarr;</button>
    </form>
    <p class="form-tejedor__nota biblio-form-nota">Sin spam. Sin venta de datos.</p>
  </footer>
</OberturaLayout>

<!-- Ondas ambientales del héroe · preset c-6a de vib-hero.js (externo · CSP) -->
<script is:inline src="/js/vib-hero.js"></script>

<style>
  /* ── Héroe · ondas c-6a + H1 «Obertura» ─────────────────── */
  .biblio-hero {
    position: relative;
    isolation: isolate;
    text-align: center;
    padding: clamp(1.5rem, 4vw, 3rem) 0 clamp(2rem, 5vw, 3.5rem);
    min-height: min(380px, 46vh);
    margin-bottom: 2.5rem;
  }
  .biblio-hero > :not(#c-6a) { position: relative; z-index: 1; }
  #c-6a {
    position: absolute;
    inset: 0;
    z-index: 0;
    width: 100%;
    height: calc(100% + 3rem);
    top: -1.5rem;
    pointer-events: none;
  }
  .biblio-eyebrow {
    font-family: var(--obertura-sans);
    font-weight: 500;
    font-size: 0.72rem;
    letter-spacing: 0.28em;
    text-transform: uppercase;
    color: var(--oro-texto);
    margin: 0 0 1.25rem;
  }
  .biblio-h1 {
    font-family: var(--obertura-serif);
    font-weight: 600;
    font-size: clamp(3.5rem, 9vw, 6.5rem);
    letter-spacing: -0.015em;
    color: var(--oro-titulo);
    line-height: 1;
    margin: 0;
  }
  .biblio-sub {
    font-family: var(--obertura-serif);
    font-style: italic;
    font-size: clamp(1.2rem, 2.2vw, 1.5rem);
    color: var(--obertura-ink);
    margin: 1rem 0 0;
  }
  .biblio-cta { margin: 2rem 0 0; }
  .biblio-cta-link {
    font-family: var(--obertura-serif);
    font-size: 1.375rem;
    color: var(--obertura-ink);
    text-decoration: none;
    border-bottom: 1px solid var(--oro-titulo);
    padding-bottom: 0.4rem;
    transition: color 0.16s var(--ease-editorial, ease), border-color 0.16s, padding-bottom 0.16s;
  }
  .biblio-cta-link:hover {
    color: var(--oro-suave);
    border-color: var(--oro-suave);
    padding-bottom: 0.55rem;
  }

  /* ── Franja meta ─────────────────────────────────────────── */
  .biblio-meta {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    font-family: var(--obertura-sans);
    font-size: 0.7rem;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: var(--obertura-ink-faded);
    padding: 1.1rem 0;
    border-top: 1px solid var(--obertura-rule-soft);
    border-bottom: 1px solid var(--obertura-rule-soft);
    margin-bottom: 3.5rem;
  }
  .biblio-meta-dot { color: var(--obertura-thread); font-size: 0.6rem; }

  /* ── TOC · 4 grupos en 2×2 ───────────────────────────────── */
  .toc--grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    column-gap: clamp(2.5rem, 5vw, 5rem);
    row-gap: 3rem;
    align-items: start;
  }
  .toc-section { margin: 0; }
  .toc-section .heading {
    font-family: var(--obertura-sans);
    font-weight: 500;
    font-size: 0.72rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--oro-texto);
    margin: 0 0 0.3rem;
  }
  .toc-section .heading-sub {
    font-family: var(--obertura-serif);
    font-style: italic;
    font-size: 1.02rem;
    color: var(--obertura-ink-faded);
    margin: 0 0 1.2rem;
  }
  .toc-section ol { list-style: none; padding: 0; margin: 0; }
  .toc-section li { margin: 0; }
  .toc-section a {
    display: grid;
    grid-template-columns: 2.4rem 1fr auto;
    align-items: baseline;
    gap: 0.9rem;
    padding: 0.7rem 0.3rem;
    text-decoration: none;
    color: var(--obertura-ink);
    border-bottom: 1px solid var(--obertura-rule-soft);
    transition: padding 0.2s;
  }
  .toc-section a:hover { padding-left: 0.7rem; }
  .toc-section a:hover .body { text-decoration: underline; text-decoration-color: var(--obertura-thread); text-underline-offset: 3px; }
  .toc-section .num {
    font-family: var(--obertura-mono);
    font-size: 0.78rem;
    color: var(--oro-texto);
    letter-spacing: 0.03em;
  }
  .toc-section .body {
    font-family: var(--obertura-serif);
    font-size: 1.25rem;
    font-weight: 600;
    line-height: 1.25;
  }
  .toc-section .body em {
    display: block;
    font-style: italic;
    font-weight: 400;
    font-size: 0.9rem;
    color: var(--obertura-ink-faded);
    margin-top: 0.1rem;
  }
  .toc-section .is-interludio .body {
    font-weight: 500;
    font-style: italic;
    font-size: 1.15rem;
  }
  /* estados de acceso · derivados del nivel real, no hardcodeados */
  .toc-section .estado {
    font-family: var(--obertura-serif);
    font-style: italic;
    font-size: 0.82rem;
    text-align: right;
    white-space: nowrap;
  }
  .toc-section .estado--libre { color: var(--oro-texto); }
  .toc-section .estado--correo { color: var(--obertura-ink-faded); }
  .toc-section .is-locked { opacity: 0.55; transition: opacity 0.2s; }
  .toc-section .is-locked:hover { opacity: 0.85; }
  .toc-section .arrow {
    font-family: var(--obertura-serif);
    color: var(--obertura-thread);
    font-size: 1rem;
    transition: transform 0.2s;
  }
  .toc-section a:hover .arrow { transform: translateX(4px); }

  /* ── Pie · frase de la puerta + captura de correo ────────── */
  .biblio-pie {
    margin-top: 4.5rem;
    padding-top: 2.5rem;
    border-top: 1px solid var(--obertura-rule-soft);
    text-align: center;
  }
  .biblio-puerta {
    font-family: var(--obertura-serif);
    font-size: 1.0625rem;
    line-height: 1.6;
    color: var(--obertura-ink-soft);
    max-width: 34rem;
    margin: 0 auto 1.75rem;
    text-wrap: pretty;
  }
  .biblio-form { margin: 0 auto; }
  .biblio-form-nota { text-align: center; margin-top: 0.5rem; }

  /* ── Responsive: grupos a 1 columna ──────────────────────── */
  @media (max-width: 46rem) {
    .toc--grid { grid-template-columns: 1fr; row-gap: 2.5rem; }
  }
</style>
