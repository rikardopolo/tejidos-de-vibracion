---
/**
 * LecturaLarga · layout para páginas de lectura larga (capítulos, obertura, etc.)
 * Extiende Base con: header sticky, progress rail, footer, BookToc, ReaderControls
 * y scripts de comportamiento CSP-safe.
 *
 * Lee cookies para determinar el Nivel de acceso y lo propaga a Base via data-nivel.
 */
import Base from './Base.astro';
import BookHeader from '../components/BookHeader.astro';
import BookFooter from '../components/BookFooter.astro';
import BookToc from '../components/book/BookToc.astro';
import ReaderControls from '../components/book/ReaderControls.astro';
import { getNivel, gatingActivo } from '@/lib/gating';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  bodyClass?: string;
  pageId?: string;
  jsonLd?: Record<string, unknown>;
}

const { title, description, canonical, ogImage, bodyClass, pageId, jsonLd } = Astro.props;

const nivel = gatingActivo() ? await getNivel(Astro.cookies) : 1;
---

<Base
  title={title}
  description={description}
  canonical={canonical}
  ogImage={ogImage}
  bodyClass={bodyClass}
  pageId={pageId}
  jsonLd={jsonLd}
  nivel={nivel}
>
  <BookHeader />

  <div class="progress-rail" id="progress-rail" aria-hidden="true"></div>

  <main id="main-content" tabindex="-1">
    <slot />
  </main>

  <BookFooter />

  <BookToc />
  <ReaderControls />

  <script src="/libro-init.js" defer></script>
  <script src="/libro-reader.js" defer></script>
  <script src="/libro-toc.js" defer></script>
</Base>
