---
import LecturaLarga from '@/layouts/LecturaLarga.astro';
import FormularioTejedor from '@/components/book/FormularioTejedor.astro';
import { getNivel, gatingActivo } from '@/lib/gating';

export const prerender = false;

const nivel = gatingActivo() ? getNivel(Astro.cookies) : 1;
---
<LecturaLarga
  title="Pertenecer al tejido · Tejidos de Vibración"
  description="Un nombre y un correo. La primera forma de pertenecer al tejido y recibir los capítulos a medida que se tejen."
  pageId="recibir"
>
  <article class="measure" style="padding-top: 5rem;">
    <header>
      <p class="eyebrow">Tejidos de Vibración</p>
      <h1 class="title-1">Pertenecer al tejido</h1>
    </header>

    {nivel === 0 ? (
      <>
        <div class="prose">
          <p class="no-indent">
            Un nombre y un correo. Con eso, la Obertura se abre completa, los capítulos publicados se desbloquean,
            y empezás a recibir las entregas nuevas a medida que se tejen.
          </p>
          <p>
            Es la primera forma de pertenecer. No la única — pero es la que abre la puerta.
          </p>
        </div>
        <div class="recibir-form-wrap">
          <FormularioTejedor id="form-tejedor-recibir" variant="page" />
        </div>
      </>
    ) : (
      <div class="prose">
        <p class="no-indent">Ya estás dentro del tejido.</p>
        <p>
          La Obertura y los capítulos publicados están abiertos. Cada nueva entrega te llegará al correo.
        </p>
        <p style="margin-top:3rem;">
          <a class="lit-link" href="/obertura">Empezar por la Obertura →</a>
        </p>
      </div>
    )}
  </article>
</LecturaLarga>
